# Rails Configuration
RAILS_MASTER_KEY=your_rails_master_key_here

# Database
POSTGRES_PASSWORD=your_postgres_password_here
DB_HOST=your_db_host_here

# Admin Configuration
ADMIN_EMAILS=admin@example.com

# Beta rollout — set to "true" to skip payment and activate users immediately on signup
BETA_MODE=true

# Google Services
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
# Production: export GOOGLE_CREDENTIALS_JSON=$(cat config/google_credentials.json) before kamal deploy
GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"rado-fitness-sheets",...}'

# Google OAuth for Mobile Authentication
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Firebase Cloud Messaging (Push Notifications)
# Option A (production): set credentials[:firebase][:service_account_json] in Rails encrypted credentials
# Option B (development): place the Firebase service account JSON at config/firebase_credentials.json
# Option C (CI/env-only): paste the full service account JSON as a single-line string below
# FIREBASE_CREDENTIALS_JSON='{"type":"service_account","project_id":"your-project",...}'

# Docker/Container Registry
KAMAL_REGISTRY_PASSWORD=your_registry_password_here
