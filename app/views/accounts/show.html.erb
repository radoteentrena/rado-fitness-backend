<% content_for :title, "Mi Cuenta — Rado Fitness" %>

<div class="min-h-screen bg-black pt-32 pb-20">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <%# Page header %>
    <div class="mb-12 border-b border-graphite pb-8">
      <p class="text-xs font-display font-semibold uppercase tracking-[0.2em] text-saffron mb-2">
        Panel de cliente
      </p>

      <h1 class="text-4xl sm:text-5xl font-display font-bold uppercase text-white">
        HOLA, <%= current_user.first_name.upcase %>
      </h1>
    </div>

    <% if current_user.promoter? %>
      <div class="flex border-b-2 border-graphite mb-8">
        <%= link_to "Mi Perfil", account_path,
              class: "px-6 py-3 text-xs font-black uppercase tracking-widest transition-colors #{@tab == 'profile' ? 'text-saffron border-b-2 border-saffron -mb-px' : 'text-graphite hover:text-white'}" %>
        <%= link_to "Mi Campaña", account_path(tab: "campaign"),
              class: "px-6 py-3 text-xs font-black uppercase tracking-widest transition-colors #{@tab == 'campaign' ? 'text-saffron border-b-2 border-saffron -mb-px' : 'text-graphite hover:text-white'}" %>
      </div>
    <% end %>

    <% if !current_user.promoter? || @tab == "profile" %>
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">

      <%# Left column: profile + subscription %>
      <div class="lg:col-span-2 space-y-6">

        <%# Profile card %>
        <div class="border-2 border-graphite p-6">
          <h2 class="text-xs font-display font-bold uppercase tracking-widest text-saffron mb-6">
            Tu perfil
          </h2>

          <div class="space-y-4">
            <div>
              <p class="text-[10px] font-display uppercase tracking-widest text-gray-600 mb-1">Nombre</p>
              <p class="text-white font-body font-medium"><%= current_user.name %></p>
            </div>

            <div class="border-t border-graphite pt-4">
              <p class="text-[10px] font-display uppercase tracking-widest text-gray-600 mb-1">Email</p>
              <p class="text-white font-body font-medium break-all"><%= current_user.email %></p>
            </div>

            <div class="border-t border-graphite pt-4">
              <p class="text-[10px] font-display uppercase tracking-widest text-gray-600 mb-1">Teléfono</p>
              <p class="text-white font-body font-medium"><%= current_user.phone %></p>
            </div>

            <div class="border-t border-graphite pt-4">
              <p class="text-[10px] font-display uppercase tracking-widest text-gray-600 mb-1">Plan</p>
              <% if current_user.plan_tier.present? %>
                <span class="inline-block border-2 border-saffron px-3 py-1 text-xs font-display font-black uppercase tracking-widest text-saffron">
                  <%= current_user.plan_tier.humanize %>
                </span>
              <% else %>
                <p class="text-gray-500 font-body text-sm">Sin plan asignado</p>
              <% end %>
            </div>
          </div>

          <p class="mt-6 text-[11px] text-gray-600 font-body leading-relaxed">
            Para modificar tu nombre, email o teléfono contactá a Rado directamente.
          </p>
        </div>

        <%# Subscription card %>
        <div class="border-2 border-graphite p-6">
          <h2 class="text-xs font-display font-bold uppercase tracking-widest text-saffron mb-6">
            Suscripción
          </h2>

          <% if @subscription %>
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <p class="text-[10px] font-display uppercase tracking-widest text-gray-600">Estado</p>
                <% status_styles = {
                  "active"   => "border-green-500 text-green-400",
                  "pending"  => "border-saffron text-saffron",
                  "past_due" => "border-red-500 text-red-400",
                  "canceled" => "border-graphite text-gray-500"
                } %>
                <span class="border-2 <%= status_styles[@subscription.status] || "border-graphite text-gray-400" %> px-2 py-0.5 text-[10px] font-display font-black uppercase tracking-wider">
                  <%= @subscription.status.humanize %>
                </span>
              </div>

              <div class="border-t border-graphite pt-4 flex items-center justify-between">
                <p class="text-[10px] font-display uppercase tracking-widest text-gray-600">Plan</p>
                <p class="text-white font-body text-sm font-medium"><%= @subscription.plan_tier.humanize %></p>
              </div>

              <% if @subscription.frequency.present? %>
                <div class="border-t border-graphite pt-4 flex items-center justify-between">
                  <p class="text-[10px] font-display uppercase tracking-widest text-gray-600">Frecuencia</p>
                  <p class="text-white font-body text-sm font-medium"><%= @subscription.frequency.humanize %></p>
                </div>
              <% end %>

              <% if @subscription.active? %>
                <div class="border-t border-graphite pt-6">
                  <%= button_to account_cancellation_request_path,
                        method: :post,
                        data: { turbo_confirm: "¿Seguro que querés solicitar la cancelación? Rado se pondrá en contacto para confirmar." },
                        class: "w-full text-center border-2 border-red-600 text-red-500 py-3 text-xs font-display font-black uppercase tracking-widest hover:bg-red-600 hover:text-white transition-all duration-150 hover:-translate-y-px hover:-translate-x-px hover:shadow-[4px_4px_0px_0px_#dc2626] active:translate-y-px active:translate-x-px active:shadow-none" do %>
                    Solicitar cancelación
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-gray-500 font-body text-sm leading-relaxed">
              No tenés una suscripción activa en este momento.
            </p>
          <% end %>
        </div>

      </div>

      <%# Right column: password change %>
      <div class="lg:col-span-3">
        <div class="border-2 border-graphite p-6 sm:p-8">
          <h2 class="text-xs font-display font-bold uppercase tracking-widest text-saffron mb-6">
            Cambiar contraseña
          </h2>

          <%= form_with model: current_user, url: account_path, method: :patch, class: "space-y-6" do |f| %>

            <% if current_user.errors.any? %>
              <div class="border-2 border-red-500 bg-red-500/10 px-4 py-3">
                <ul class="space-y-1">
                  <% current_user.errors.full_messages.each do |msg| %>
                    <li class="text-red-400 text-sm font-body"><%= msg %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div>
              <%= f.label :current_password, "Contraseña actual",
                    class: "block text-[10px] font-display uppercase tracking-widest text-gray-400 mb-2" %>
              <%= f.password_field :current_password,
                    autocomplete: "current-password",
                    class: "w-full bg-black border-2 border-graphite text-white font-body text-sm px-4 py-3 focus:outline-none focus:border-saffron transition-colors placeholder-gray-700",
                    placeholder: "••••••••" %>
            </div>

            <div>
              <%= f.label :password, "Nueva contraseña",
                    class: "block text-[10px] font-display uppercase tracking-widest text-gray-400 mb-2" %>
              <%= f.password_field :password,
                    autocomplete: "new-password",
                    class: "w-full bg-black border-2 border-graphite text-white font-body text-sm px-4 py-3 focus:outline-none focus:border-saffron transition-colors placeholder-gray-700",
                    placeholder: "Mínimo 8 caracteres" %>
            </div>

            <div>
              <%= f.label :password_confirmation, "Confirmar nueva contraseña",
                    class: "block text-[10px] font-display uppercase tracking-widest text-gray-400 mb-2" %>
              <%= f.password_field :password_confirmation,
                    autocomplete: "new-password",
                    class: "w-full bg-black border-2 border-graphite text-white font-body text-sm px-4 py-3 focus:outline-none focus:border-saffron transition-colors placeholder-gray-700",
                    placeholder: "Repetí la nueva contraseña" %>
            </div>

            <div class="pt-2">
              <%= f.submit "GUARDAR CONTRASEÑA",
                    class: "w-full sm:w-auto border-2 border-saffron bg-saffron text-black py-4 px-10 text-xs font-display font-black uppercase tracking-widest hover:bg-yellow-400 transition-all duration-150 hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[6px_6px_0px_0px_#ffffff] active:translate-y-1 active:translate-x-1 active:shadow-none cursor-pointer" %>
            </div>

          <% end %>
        </div>
      </div>

    </div>
    <% end %>

    <% if current_user.promoter? && @tab == "campaign" %>
      <div class="grid grid-cols-3 gap-4 mb-8">
        <div class="border-2 border-graphite p-5">
          <div class="text-graphite text-xs uppercase tracking-widest mb-2">Clientes referidos</div>
          <div class="text-4xl font-black text-white"><%= @promo_links.sum { |l| l.promo_conversions.count } %></div>
        </div>
        <div class="border-2 border-graphite p-5">
          <div class="text-graphite text-xs uppercase tracking-widest mb-2">Ganado total</div>
          <div class="text-4xl font-black text-saffron">US$<%= "%.2f" % (@total_cents / 100.0) %></div>
        </div>
        <div class="border-2 border-saffron p-5">
          <div class="text-saffron text-xs uppercase tracking-widest mb-2">Por cobrar</div>
          <div class="text-4xl font-black text-saffron">US$<%= "%.2f" % (@pending_cents / 100.0) %></div>
        </div>
      </div>

      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xs font-black uppercase tracking-widest text-graphite">Mis enlaces</h2>
        <%= form_with url: promo_links_path, method: :post, class: "flex gap-2" do |f| %>
          <%= f.text_field "promo_link[label]", placeholder: "Nombre de la campaña",
                class: "border-2 border-graphite bg-transparent text-white text-sm px-3 py-2 focus:outline-none focus:border-saffron w-44" %>
          <%= f.submit "+ Nuevo enlace",
                class: "border-2 border-saffron text-saffron font-black uppercase text-xs px-4 py-2 hover:-translate-y-px hover:-translate-x-px hover:shadow-[4px_4px_0_0_#ffffff] transition-all cursor-pointer bg-transparent" %>
        <% end %>
      </div>

      <% if @promo_links.any? %>
        <div class="border-2 border-graphite divide-y divide-graphite">
          <% @promo_links.each do |link| %>
            <div class="p-4 flex items-center gap-4">
              <div class="flex-1 min-w-0">
                <div class="font-black text-white text-sm uppercase tracking-widest mb-1"><%= link.label %></div>
                <div class="flex items-center gap-3">
                  <span class="text-saffron text-xs font-mono truncate"><%= link.full_url %></span>
                  <button
                    onclick="navigator.clipboard.writeText('<%= j(link.full_url) %>').then(() => this.textContent = '¡Copiado!')"
                    class="text-graphite text-xs uppercase tracking-widest hover:text-white shrink-0">
                    Copiar
                  </button>
                </div>
              </div>
              <div class="text-right shrink-0">
                <div class="text-white font-bold"><%= link.promo_conversions.count %> referido<%= link.promo_conversions.count == 1 ? "" : "s" %></div>
                <div class="text-saffron text-sm">US$<%= "%.2f" % (link.total_earnings_cents / 100.0) %></div>
              </div>
              <% if link.active %>
                <%= button_to "Desactivar", promo_link_path(link), method: :patch,
                      data: { turbo_confirm: "¿Desactivar este enlace? Los usuarios con el link no podrán usarlo más." },
                      class: "text-graphite text-xs uppercase hover:text-white shrink-0 bg-transparent border-0 cursor-pointer" %>
              <% else %>
                <span class="text-graphite text-xs uppercase">Inactivo</span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-graphite text-sm">Aún no tienes enlaces. Crea uno arriba para empezar.</p>
      <% end %>
    <% end %>

  </div>
</div>
