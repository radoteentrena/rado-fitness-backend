<%# locals: (message:) %>
<%= turbo_frame_tag "ai_coach_result", data: { controller: "scroll-into-view" } do %>
  <div class="mt-8 bg-whiteish dark:bg-shadow rounded-2xl border border-red-500/40 p-8 text-center">
    <span class="material-symbols-outlined text-red-500 text-4xl">error</span>
    <p class="mt-3 text-base font-semibold text-blackish dark:text-whiteish"><%= message %></p>
    <%= link_to admin_new_ai_coach_path, data: { turbo_frame: "admin_main_content" },
      class: "mt-4 inline-flex items-center gap-2 px-4 py-2.5 bg-primary hover:bg-primary/90 text-blackish font-semibold rounded-xl transition" do %>
      <span class="material-symbols-outlined text-base">refresh</span>
      Volver a intentar
    <% end %>
  </div>
<% end %>
