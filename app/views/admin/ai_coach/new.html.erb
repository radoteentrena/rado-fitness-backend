<% content_for(:title) { "AI Coach" } %>

<%= turbo_frame_tag "admin_main_content" do %>
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-blackish dark:text-whiteish flex items-center gap-3">
        <span class="material-symbols-outlined text-primary text-4xl">psychology</span>
        AI Coach
      </h1>
      <p class="mt-2 text-graphite dark:text-muted">Generate tailored programs and routines from your fitness knowledge base.</p>
    </div>

    <!-- Wizard Form -->
    <div id="ai-coach-wizard" data-controller="ai-coach">
      <%= form_tag admin_generate_ai_coach_path, method: :post, data: { turbo_frame: "ai_coach_result", action: "submit->ai-coach#handleSubmit" } do %>
        <!-- Step 1: Client Selection -->
        <div class="bg-whiteish dark:bg-shadow rounded-2xl border border-shadow dark:border-graphite p-6 mb-6">
          <h2 class="text-lg font-semibold text-blackish dark:text-whiteish mb-4 flex items-center gap-2">
            <span class="bg-primary text-blackish w-7 h-7 rounded-full flex items-center justify-center text-sm font-bold">1</span>
            Select Client
            <span class="text-sm font-normal text-graphite dark:text-muted">(optional — leave empty for template)</span>
          </h2>

          <select name="user_id" id="user_id"
            class="w-full rounded-xl border border-shadow dark:border-graphite bg-background-light dark:bg-blackish text-blackish dark:text-whiteish px-4 py-3 focus:ring-2 focus:ring-primary focus:border-primary transition">
            <option value="">No client — Generate a Template</option>
            <% @users.each do |user| %>
              <option value="<%= user.id %>">
                <%= user.name %> (<%= user.category %>) — S:<%= user.calculate_workout_compliance_score %>% M:<%= user.calculate_diet_adherence_score %>%
              </option>
            <% end %>
          </select>
        </div>

        <!-- Step 2: Routine Classification -->
        <div class="bg-whiteish dark:bg-shadow rounded-2xl border border-shadow dark:border-graphite p-6 mb-6">
          <h2 class="text-lg font-semibold text-blackish dark:text-whiteish mb-1 flex items-center gap-2">
            <span class="bg-primary text-blackish w-7 h-7 rounded-full flex items-center justify-center text-sm font-bold">2</span>
            Clasificación de la Rutina
          </h2>
          <p class="text-xs text-graphite dark:text-muted mb-4 ml-9">Estos valores se incluyen automáticamente en el nombre de cada rutina generada para que queden filtrables en la biblioteca.</p>

          <div class="grid grid-cols-3 gap-4">
            <div>
              <label for="gender" class="block text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider mb-1.5">Género</label>
              <select name="gender" id="gender"
                class="w-full rounded-xl border border-shadow dark:border-graphite bg-background-light dark:bg-blackish text-blackish dark:text-whiteish px-3 py-2.5 text-sm focus:ring-2 focus:ring-primary focus:border-primary transition">
                <option value="">— Sin especificar</option>
                <% Routine::GENDERS.each do |g| %>
                  <option value="<%= g %>"><%= g %></option>
                <% end %>
              </select>
            </div>

            <div>
              <label for="focus" class="block text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider mb-1.5">Objetivo</label>
              <select name="focus" id="focus"
                class="w-full rounded-xl border border-shadow dark:border-graphite bg-background-light dark:bg-blackish text-blackish dark:text-whiteish px-3 py-2.5 text-sm focus:ring-2 focus:ring-primary focus:border-primary transition">
                <option value="">— Sin especificar</option>
                <% Routine::FOCUSES.each do |f| %>
                  <option value="<%= f %>"><%= f %></option>
                <% end %>
              </select>
            </div>

            <div>
              <label for="level" class="block text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider mb-1.5">Nivel</label>
              <select name="level" id="level"
                class="w-full rounded-xl border border-shadow dark:border-graphite bg-background-light dark:bg-blackish text-blackish dark:text-whiteish px-3 py-2.5 text-sm focus:ring-2 focus:ring-primary focus:border-primary transition">
                <option value="">— Sin especificar</option>
                <% Routine::LEVELS.each do |l| %>
                  <option value="<%= l %>"><%= l %></option>
                <% end %>
              </select>
            </div>
          </div>
        </div>

        <!-- Step 3: Objectives -->
        <div class="bg-whiteish dark:bg-shadow rounded-2xl border border-shadow dark:border-graphite p-6 mb-6">
          <h2 class="text-lg font-semibold text-blackish dark:text-whiteish mb-4 flex items-center gap-2">
            <span class="bg-primary text-blackish w-7 h-7 rounded-full flex items-center justify-center text-sm font-bold">3</span>
            Prompt de Objetivos
          </h2>

          <!-- Prompt Guide -->
          <div class="mb-4 rounded-xl border border-primary/30 bg-primary/5 dark:bg-primary/10 p-4">
            <p class="text-xs font-semibold text-primary uppercase tracking-wider mb-2">Guía de prompt</p>
            <ul class="text-xs text-graphite dark:text-muted space-y-1.5 list-none">
              <li><span class="font-semibold text-blackish dark:text-whiteish">Días/semana:</span> indicar cuántos días entrena (ej: 4 días/semana)</li>
              <li><span class="font-semibold text-blackish dark:text-whiteish">Split:</span> tipo de división (ej: Upper/Lower, Push/Pull/Legs, Full Body)</li>
              <li><span class="font-semibold text-blackish dark:text-whiteish">Duración:</span> semanas del bloque o programa (ej: 8 semanas)</li>
              <li><span class="font-semibold text-blackish dark:text-whiteish">Énfasis muscular:</span> grupos prioritarios (ej: pecho y hombros)</li>
              <li><span class="font-semibold text-blackish dark:text-whiteish">Restricciones:</span> lesiones, equipamiento, tiempo por sesión</li>
              <li><span class="font-semibold text-blackish dark:text-whiteish">Observaciones extra:</span> cualquier detalle específico del cliente</li>
            </ul>
            <p class="mt-3 text-xs text-graphite dark:text-muted border-t border-primary/20 pt-2">
              <span class="font-semibold text-blackish dark:text-whiteish">Ejemplo:</span>
              4 días/semana, Upper/Lower, 8 semanas de acumulación. Énfasis en pecho y dorsales. Sin lesiones. 60 min por sesión.
            </p>
          </div>

          <textarea name="objectives" id="objectives" rows="5" required
            placeholder="4 días/semana, Upper/Lower, 8 semanas de acumulación. Énfasis en pecho y dorsales. Sin lesiones. 60 min por sesión."
            class="w-full rounded-xl border border-shadow dark:border-graphite bg-background-light dark:bg-blackish text-blackish dark:text-whiteish px-4 py-3 focus:ring-2 focus:ring-primary focus:border-primary transition resize-y"></textarea>

          <!-- Generation Mode -->
          <div class="mt-4">
            <label class="text-sm font-medium text-graphite dark:text-muted mb-3 block">Generar:</label>
            <div class="flex flex-col sm:flex-row gap-6">
              <label class="flex items-start gap-3 cursor-pointer group">
                <input type="radio" name="mode" value="program" checked
                  class="mt-1 w-4 h-4 text-primary focus:ring-primary border-shadow dark:border-graphite">
                <div>
                  <span class="block text-sm font-semibold text-blackish dark:text-whiteish group-hover:text-primary transition-colors">Programa completo</span>
                  <span class="block text-xs text-graphite dark:text-muted mt-0.5">Macrociclo completo con fases, rutinas y workouts</span>
                </div>
              </label>

              <label class="flex items-start gap-3 cursor-pointer group">
                <input type="radio" name="mode" value="routine"
                  class="mt-1 w-4 h-4 text-primary focus:ring-primary border-shadow dark:border-graphite">
                <div>
                  <span class="block text-sm font-semibold text-blackish dark:text-whiteish group-hover:text-primary transition-colors">Rutina individual</span>
                  <span class="block text-xs text-graphite dark:text-muted mt-0.5">Bloque standalone sin fases (Rutina → Workouts)</span>
                </div>
              </label>
            </div>
          </div>
        </div>

        <!-- Submit -->
        <div class="flex justify-end">
          <button type="submit" id="generate-button" data-ai-coach-target="generateButton"
            class="generate-button inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary/90 text-blackish font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all duration-200 transform hover:scale-[1.02] cursor-pointer">
            <span class="generate-icon material-symbols-outlined">auto_awesome</span>
            <span class="generate-text">Generate</span>
          </button>
        </div>
      <% end %>
    </div>

    <!-- Result Area (updated via Turbo Frame) -->
    <%= turbo_frame_tag "ai_coach_result" do %>
    <% end %>
  </div>
<% end %>
