<% if existing_action?(collection_presenter.resource_name, :edit) %>
  <td class="px-6 py-4">
    <%= link_to(
    t("administrate.actions.edit"),
    [:edit, namespace, resource],
    class: "font-medium text-blue-600 dark:text-blue-500 hover:underline",
  ) if accessible_action?(resource, :edit) %>
  </td>
<% end %>

<% if existing_action?(collection_presenter.resource_name, :destroy) %>
  <td class="px-6 py-4">
    <%= button_to(
    t("administrate.actions.destroy"),
    [namespace, resource],
    class: "font-medium text-red-600 dark:text-red-500 hover:underline bg-transparent border-0 p-0 cursor-pointer",
    method: :delete,
    data: { turbo_confirm: t("administrate.actions.confirm") }
  ) if accessible_action?(resource, :destroy) %>
  </td>
<% end %>
