<ul class="space-y-2 font-medium" data-controller="active-link">
  <li>
    <%= link_to admin_dashboard_path, data: { active_link_target: "link", turbo_frame: "admin_main_content", turbo_action: "advance" }, class: "flex items-center p-3 rounded-xl group transition-colors #{request.path == admin_dashboard_path ? 'bg-saffron text-blackish shadow-sm dark:bg-saffron dark:text-blackish' : 'text-graphite hover:bg-background-light dark:text-muted dark:hover:bg-shadow/50 dark:hover:text-whiteish'}" do %>
      <span class="material-symbols-outlined w-5 h-5 transition duration-75 text-inherit">dashboard</span>
      <span class="ms-3 font-semibold text-sm">Dashboard</span>
    <% end %>
  </li>

  <!-- AI Coach -->
  <li>
    <%= link_to admin_new_ai_coach_path, data: { active_link_target: "link", turbo_frame: "admin_main_content", turbo_action: "advance" }, class: "flex items-center p-3 rounded-xl group transition-colors #{request.path.include?('ai_coach') ? 'bg-saffron text-blackish shadow-sm dark:bg-saffron dark:text-blackish' : 'text-graphite hover:bg-background-light dark:text-muted dark:hover:bg-shadow/50 dark:hover:text-whiteish'}" do %>
      <span class="material-symbols-outlined w-5 h-5 transition duration-75 text-inherit">psychology</span>
      <span class="ms-3 font-semibold text-sm">AI Coach</span>
    <% end %>
  </li>

  <!-- Conversations (custom layout, no Turbo) -->
  <li>
    <%= link_to admin_conversations_path, data: { active_link_target: "link" }, class: "flex items-center p-3 rounded-xl group transition-colors #{request.path.include?('conversations') ? 'bg-saffron text-blackish shadow-sm dark:bg-saffron dark:text-blackish' : 'text-graphite hover:bg-background-light dark:text-muted dark:hover:bg-shadow/50 dark:hover:text-whiteish'}" do %>
      <span class="material-symbols-outlined w-5 h-5 transition duration-75 text-inherit">forum</span>
      <span class="ms-3 font-semibold text-sm flex-1">Conversations</span>
      <%= turbo_frame_tag "unread_messages_badge" do %>
        <%= render "admin/shared/unread_messages_badge" %>
      <% end %>
    <% end %>
  </li>

  <% excluded_nav_resources = ["dashboard", "phase_routines", "user_dietary_plans", "phases", "conversations"] %>
  <% Administrate::Namespace.new(namespace).resources_with_index_route.reject { |r| excluded_nav_resources.include?(r.to_s) }.each do |resource| %>
    <li>
      <%= link_to(
        resource_index_route(resource),
        data: { active_link_target: "link", turbo_frame: "admin_main_content", turbo_action: "advance" },
        class: "flex items-center p-3 rounded-xl group transition-colors #{nav_link_state(resource) == :active ? 'bg-saffron text-blackish shadow-sm dark:bg-saffron dark:text-blackish' : 'text-graphite hover:bg-background-light dark:text-muted dark:hover:bg-shadow/50 dark:hover:text-whiteish'}"
      ) do %>
        <% icon_name = case resource.to_s
           when "users", "admin/users" then "group"
           when "subscriptions", "admin/subscriptions" then "credit_card"
           when "programs", "admin/programs" then "app_registration"
           when "routines", "admin/routines" then "format_list_numbered"
           when "workouts", "admin/workouts" then "event_note"
           when "exercises", "admin/exercises" then "fitness_center"
           when "workout_exercises", "admin/workout_exercises" then "fitness_center"
           when "training_sessions", "admin/training_sessions" then "directions_run"
           when "dietary_plans", "admin/dietary_plans" then "restaurant_menu"
           when "progress_photos", "admin/progress_photos" then "photo_camera"
           when "daily_metrics", "admin/daily_metrics" then "monitoring"
           when "coach_alerts", "admin/coach_alerts" then "notifications_active"
           when "books", "admin/books" then "library_books"
           when "messages", "admin/messages" then "chat"
           when "onboarding_profiles", "admin/onboarding_profiles" then "contact_page"
           else "label"
           end
        %>
        <span class="material-symbols-outlined w-5 h-5 transition duration-75 text-inherit"><%= icon_name %></span>
        <span class="ms-3 font-semibold text-sm"><%= display_resource_name(resource) %></span>
      <% end %>
    </li>
  <% end %>
</ul>
