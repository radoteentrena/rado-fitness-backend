<%# Page Title %>
<header class="px-4 pt-6 pb-4 mb-4 border-b border-shadow dark:border-graphite">
  <h1 class="text-2xl font-bold text-blackish dark:text-whiteish">Coach Alerts</h1>
  <p class="text-sm text-graphite dark:text-muted mt-1">Monitor and act on client alerts flagged for your attention</p>
</header>

<%# Header Section %>
<div class="flex flex-col md:flex-row items-center justify-between space-y-3 md:space-y-0 md:space-x-4 p-4">
  <div class="w-full md:w-1/2">
    <form class="flex items-center" action="<%= admin_coach_alerts_path %>" method="get">
      <% params.slice(:status, :category).each do |key, val| %>
        <input type="hidden" name="<%= key %>" value="<%= val %>">
      <% end %>
      <label for="search" class="sr-only">Search</label>
      <div class="relative w-full">
        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
          <svg aria-hidden="true" class="w-5 h-5 text-graphite dark:text-muted" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
          </svg>
        </div>
        <input type="text" name="search" id="search" value="<%= params[:search] %>" class="bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full pl-10 p-2 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish dark:focus:ring-primary dark:focus:border-primary" placeholder="Search alerts...">
      </div>
    </form>
  </div>
  <div class="w-full md:w-auto flex flex-col md:flex-row space-y-2 md:space-y-0 items-stretch md:items-center justify-end md:space-x-3 flex-shrink-0">
    <%= link_to new_admin_coach_alert_path, data: { turbo_frame: "modal_frame" }, class: "flex items-center justify-center text-blackish bg-primary hover:bg-primary/90 focus:ring-4 focus:ring-primary/20 font-medium rounded-lg text-sm px-4 py-2 dark:bg-primary dark:hover:bg-primary/90 focus:outline-none dark:focus:ring-primary/20" do %>
      <svg class="h-3.5 w-3.5 mr-2" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path clip-rule="evenodd" fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" />
      </svg>
      New Alert
    <% end %>
  </div>
</div>

<%# Filter Section %>
<div class="px-4 pb-4">
  <div class="bg-whiteish dark:bg-shadow p-4 rounded-lg border border-shadow dark:border-graphite shadow-sm">
    <%= form_with url: admin_coach_alerts_path, method: :get, class: "flex flex-wrap items-end gap-4" do |f| %>
      <%= f.hidden_field :search, value: params[:search] if params[:search].present? %>

      <div class="flex flex-col space-y-1">
        <%= f.label :status, "Status", class: "text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider" %>
        <%= f.select :status, CoachAlert.statuses.keys.map { |k| [k.titleize, k] }, { include_blank: "All Statuses", selected: params[:status] }, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-40 p-2.5 dark:bg-graphite dark:border-graphite dark:text-whiteish" %>
      </div>

      <div class="flex flex-col space-y-1">
        <%= f.label :category, "Category", class: "text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider" %>
        <%= f.select :category, CoachAlert.categories.keys.map { |k| [k.titleize.gsub("_", " "), k] }, { include_blank: "All Categories", selected: params[:category] }, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-44 p-2.5 dark:bg-graphite dark:border-graphite dark:text-whiteish" %>
      </div>

      <div class="flex gap-2">
        <%= f.submit "Filter", class: "cursor-pointer text-whiteish bg-primary hover:bg-primary/90 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-primary dark:hover:bg-primary/90 focus:outline-none transition-colors" %>
        <%= link_to "Clear", admin_coach_alerts_path, class: "flex items-center justify-center text-graphite bg-whiteish border border-shadow hover:bg-background-light font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-shadow dark:text-whiteish dark:border-graphite dark:hover:bg-graphite transition-colors" %>
      </div>
    <% end %>
  </div>
</div>

<%# Alerts Table %>
<div class="px-4 pb-4">
  <div class="bg-whiteish dark:bg-shadow rounded-xl border border-shadow dark:border-graphite shadow-sm overflow-hidden">
    <% if resources.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left text-graphite dark:text-slate-200">
          <thead class="text-xs text-graphite uppercase bg-background-light dark:bg-graphite dark:text-whiteish">
            <tr>
              <th scope="col" class="px-4 py-3">Type</th>
              <th scope="col" class="px-4 py-3">Client</th>
              <th scope="col" class="px-4 py-3">Message</th>
              <th scope="col" class="px-4 py-3">Status</th>
              <th scope="col" class="px-4 py-3">Time</th>
              <th scope="col" class="px-4 py-3 text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% resources.each do |alert| %>
              <tr class="border-b border-shadow dark:border-graphite hover:bg-background-light dark:hover:bg-shadow/50 transition-colors">
                <td class="px-4 py-3">
                  <span class="inline-flex items-center px-2 py-0.5 text-xs font-bold text-blackish bg-primary rounded">
                    <%= alert.initials %>
                  </span>
                  <span class="ml-2 text-xs text-graphite dark:text-muted hidden sm:inline"><%= alert.category.humanize %></span>
                </td>
                <td class="px-4 py-3 font-medium text-blackish dark:text-whiteish whitespace-nowrap">
                  <%= link_to alert.user.name, admin_user_path(alert.user), class: "hover:text-primary transition-colors" %>
                </td>
                <td class="px-4 py-3 max-w-xs truncate text-graphite dark:text-slate-200">
                  <%= alert.message %>
                </td>
                <td class="px-4 py-3">
                  <span class="inline-block px-2 py-0.5 text-xs font-bold rounded <%= alert_status_classes(alert.status) %>">
                    <%= alert.status.titleize %>
                  </span>
                </td>
                <td class="px-4 py-3 text-graphite dark:text-muted whitespace-nowrap">
                  <%= time_ago_in_words(alert.created_at) %> ago
                </td>
                <td class="px-4 py-3 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to "View", admin_coach_alert_path(alert), class: "font-medium text-primary hover:underline text-xs" %>
                    <%= link_to "Edit", edit_admin_coach_alert_path(alert), data: { turbo_frame: "modal_frame" }, class: "font-medium text-graphite dark:text-muted hover:text-blackish dark:hover:text-whiteish text-xs" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <div class="w-16 h-16 rounded-full bg-background-light dark:bg-graphite flex items-center justify-center mb-4 border border-shadow dark:border-graphite">
          <svg class="w-8 h-8 text-graphite dark:text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
        </div>
        <p class="text-blackish dark:text-whiteish font-semibold">No alerts found</p>
        <p class="text-sm text-graphite dark:text-muted mt-1">All clear — nothing matches the current filters.</p>
      </div>
    <% end %>
  </div>

  <%# Pagination %>
  <% if resources.respond_to?(:total_count) && resources.total_count > resources.limit_value %>
    <div class="mt-4">
      <%= paginate resources, total_count: resources.total_count %>
    </div>
  <% end %>
</div>

<%= turbo_frame_tag "modal_frame" %>
