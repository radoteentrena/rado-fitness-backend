<%
  alert = @coach_alert
  status_classes = {
    "pending"   => "bg-primary/10 text-primary border border-primary/20",
    "resolved"  => "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300 border border-green-200 dark:border-green-700",
    "dismissed" => "bg-graphite/20 text-graphite dark:bg-graphite/40 dark:text-muted border border-graphite/30"
  }
  category_icon = {
    "missed_workout"  => "fitness_center",
    "low_compliance"  => "trending_down",
    "weight_spike"    => "monitor_weight",
    "check_in"        => "chat_bubble",
    "program_complete"=> "emoji_events",
    "payment_failed"  => "credit_card_off"
  }
%>

<div class="space-y-6">
  <%# Header %>
  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-4">
      <%= link_to admin_coach_alerts_path, class: "p-2 text-graphite bg-whiteish rounded-lg border border-shadow hover:bg-background-light hover:text-blackish dark:bg-shadow dark:border-graphite dark:text-muted dark:hover:bg-shadow/50 dark:hover:text-whiteish" do %>
        <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5H1m0 0 4 4M1 5l4-4"/>
        </svg>
        <span class="sr-only">Back</span>
      <% end %>
      <div>
        <h1 class="text-2xl font-bold tracking-tight text-blackish dark:text-whiteish">
          <%= alert.category.humanize %>
        </h1>
        <p class="text-sm text-graphite dark:text-muted mt-0.5">Alert #<%= alert.id %> · <%= alert.created_at.strftime("%B %d, %Y at %H:%M") %></p>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <% if alert.pending? %>
        <%= button_to resolve_admin_coach_alert_path(alert), method: :patch,
            class: "flex items-center gap-1.5 px-4 py-2 bg-green-600 hover:bg-green-700 text-whiteish font-bold text-sm rounded-lg transition-colors cursor-pointer" do %>
          <span class="material-symbols-outlined text-base">check_circle</span>
          Resolve
        <% end %>
        <%= button_to dismiss_admin_coach_alert_path(alert), method: :patch,
            data: { turbo_confirm: "Dismiss this alert?" },
            class: "flex items-center gap-1.5 px-4 py-2 bg-whiteish dark:bg-shadow border border-shadow dark:border-graphite text-graphite dark:text-muted hover:text-blackish dark:hover:text-whiteish font-bold text-sm rounded-lg transition-colors cursor-pointer" do %>
          <span class="material-symbols-outlined text-base">close</span>
          Dismiss
        <% end %>
      <% end %>
      <%= link_to edit_admin_coach_alert_path(alert), data: { turbo_frame: "modal_frame" },
          class: "flex items-center gap-1.5 px-4 py-2 text-blackish bg-primary hover:bg-primary/90 font-bold text-sm rounded-lg transition-colors" do %>
        <span class="material-symbols-outlined text-base">edit</span>
        Edit
      <% end %>
    </div>
  </div>

  <%# Main Grid %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <%# Left Column: Alert Details %>
    <div class="lg:col-span-2 space-y-6">

      <%# Alert Card %>
      <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center">
            <span class="material-symbols-outlined text-2xl"><%= category_icon[alert.category] || "notifications" %></span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3 mb-2">
              <h3 class="font-bold text-blackish dark:text-whiteish"><%= alert.category.humanize %></h3>
              <span class="inline-block px-2 py-0.5 text-xs font-bold rounded <%= status_classes[alert.status] || '' %>">
                <%= alert.status.titleize %>
              </span>
            </div>
            <p class="text-graphite dark:text-slate-200 leading-relaxed"><%= alert.message %></p>
          </div>
        </div>
      </div>

      <%# Message Client %>
      <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite overflow-hidden">
        <%# Sent from this alert %>
        <% if @alert_messages.any? %>
          <div class="flex flex-col gap-3 p-4 max-h-64 overflow-y-auto">
            <% @alert_messages.each do |msg| %>
              <div class="flex justify-end">
                <div class="max-w-[80%] px-3 py-2 rounded-xl rounded-br-sm text-sm text-blackish bg-primary">
                  <p class="leading-snug"><%= msg.content %></p>
                  <p class="text-[10px] mt-1 text-blackish/60"><%= msg.created_at.strftime("%b %d · %H:%M") %></p>
                </div>
              </div>
            <% end %>
          </div>
          <div class="border-t border-shadow dark:border-graphite"></div>
        <% end %>

        <%# Compose %>
        <div class="p-4">
          <% unless @alert_messages.any? %>
            <h3 class="text-sm font-bold uppercase tracking-wider text-graphite dark:text-muted mb-3">Message Client</h3>
          <% end %>
          <%= form_with url: send_message_admin_coach_alert_path(alert), method: :post do |f| %>
            <%= f.text_area :content,
                rows: 3,
                placeholder: "Write a message to #{alert.user.name}...",
                class: "block w-full p-3 text-sm text-blackish bg-background-light rounded-lg border border-shadow focus:ring-primary focus:border-primary dark:bg-graphite dark:border-graphite dark:text-whiteish dark:placeholder-muted resize-none" %>
            <div class="flex items-center justify-between mt-3">
              <p class="text-xs text-graphite dark:text-muted">Sends via in-app chat.</p>
              <%= f.submit "Send",
                  class: "px-4 py-2 bg-primary hover:bg-primary/90 text-blackish font-bold text-sm rounded-lg transition-colors cursor-pointer" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# Right Column: Client + Meta %>
    <div class="space-y-6">

      <%# Client Card %>
      <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
        <h3 class="text-sm font-bold uppercase tracking-wider text-graphite dark:text-muted mb-4">Client</h3>
        <%= link_to admin_user_path(alert.user), class: "flex items-center gap-3 group" do %>
          <div class="w-12 h-12 rounded-full bg-primary/20 text-primary flex items-center justify-center text-lg font-bold flex-shrink-0">
            <%= alert.user.first_name[0] %><%= alert.user.last_name[0] rescue alert.user.name[0] %>
          </div>
          <div class="min-w-0">
            <p class="font-bold text-blackish dark:text-whiteish group-hover:text-primary transition-colors truncate"><%= alert.user.name %></p>
            <p class="text-xs text-graphite dark:text-muted truncate"><%= alert.user.email %></p>
          </div>
          <span class="material-symbols-outlined text-graphite dark:text-muted ml-auto">chevron_right</span>
        <% end %>
      </div>

      <%# Metadata Card %>
      <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
        <h3 class="text-sm font-bold uppercase tracking-wider text-graphite dark:text-muted mb-4">Details</h3>
        <dl class="space-y-4">
          <div>
            <dt class="text-xs font-medium text-graphite dark:text-muted">Category</dt>
            <dd class="mt-1 text-sm font-semibold text-blackish dark:text-whiteish"><%= alert.category.humanize %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-graphite dark:text-muted">Status</dt>
            <dd class="mt-1">
              <span class="inline-block px-2 py-0.5 text-xs font-bold rounded <%= status_classes[alert.status] || '' %>">
                <%= alert.status.titleize %>
              </span>
            </dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-graphite dark:text-muted">Created</dt>
            <dd class="mt-1 text-sm font-semibold text-blackish dark:text-whiteish"><%= alert.created_at.strftime("%b %d, %Y · %H:%M") %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-graphite dark:text-muted">Last Updated</dt>
            <dd class="mt-1 text-sm font-semibold text-blackish dark:text-whiteish"><%= alert.updated_at.strftime("%b %d, %Y · %H:%M") %></dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</div>

<%= turbo_frame_tag "modal_frame" %>
