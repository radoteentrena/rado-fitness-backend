<%= turbo_frame_tag "modal_frame" do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-blackish/50 backdrop-blur-sm p-4">
    <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-xl w-full max-w-md overflow-hidden border border-shadow dark:border-graphite">

      <div class="flex items-center justify-between p-4 border-b border-shadow dark:border-graphite bg-background-light dark:bg-graphite">
        <h3 class="text-base font-semibold text-blackish dark:text-whiteish">Nueva conversación</h3>
        <%= link_to admin_conversations_path, data: { turbo_frame: "_top" }, class: "text-graphite hover:text-blackish dark:text-muted dark:hover:text-whiteish transition-colors" do %>
          <span class="material-symbols-outlined">close</span>
        <% end %>
      </div>

      <div class="p-6">
        <% if @users.empty? %>
          <p class="text-sm text-graphite dark:text-muted text-center py-4">
            Todos los usuarios ya tienen una conversación activa.
          </p>
        <% else %>
          <%= form_with url: admin_conversations_path, method: :post, data: { turbo_frame: "_top" } do |f| %>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-blackish dark:text-whiteish mb-2">
                  Seleccionar usuario
                </label>
                <%= f.select :user_id,
                  @users.map { |u| [u.email, u.id] },
                  { prompt: "— Elige un usuario —" },
                  class: "w-full px-3 py-2 text-sm bg-whiteish dark:bg-graphite border border-shadow dark:border-graphite rounded-lg text-blackish dark:text-whiteish focus:outline-none focus:ring-2 focus:ring-primary/40" %>
              </div>

              <div class="flex justify-end gap-3 pt-2">
                <%= link_to "Cancelar", admin_conversations_path,
                  data: { turbo_frame: "_top" },
                  class: "px-4 py-2 text-sm font-medium text-graphite dark:text-muted hover:text-blackish dark:hover:text-whiteish transition-colors" %>
                <%= f.submit "Crear conversación",
                  class: "px-4 py-2 text-sm font-semibold text-blackish bg-primary hover:bg-primary/90 rounded-lg transition-colors cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary/40" %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

    </div>
  </div>
<% end %>
