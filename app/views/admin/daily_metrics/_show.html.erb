<%= turbo_frame_tag "overlay_frame" do %>
  <div class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-blackish/50 backdrop-blur-sm" data-controller="overlay" data-overlay-target="overlay" data-overlay-auto-open-value="true" data-action="click->overlay#closeBackground keyup@window->overlay#closeWithKeyboard">
    <div class="relative w-full max-w-2xl max-h-[90vh] overflow-y-auto bg-whiteish dark:bg-shadow rounded-xl shadow-2xl border border-shadow dark:border-graphite">

      <!-- Header -->
      <div class="flex items-center justify-between p-6 border-b border-shadow dark:border-graphite sticky top-0 bg-whiteish dark:bg-shadow z-10">
        <div>
          <h3 class="text-xl font-bold text-blackish dark:text-whiteish">Daily Metric Details</h3>
          <p class="text-sm text-graphite dark:text-muted"><%= daily_metric.date_logged.strftime("%A, %B %d, %Y") %></p>
        </div>
        <button type="button" class="text-graphite dark:text-muted hover:text-blackish dark:hover:text-whiteish transition-colors" data-action="click->overlay#close">
          <span class="material-symbols-outlined text-2xl">close</span>
        </button>
      </div>

      <!-- Content -->
      <div class="p-6 space-y-6">

        <!-- Key Metrics Grid -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="bg-background-light dark:bg-graphite p-4 rounded-lg text-center">
            <p class="text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider mb-1">Calories</p>
            <p class="text-xl font-bold text-blackish dark:text-whiteish"><%= daily_metric.calories_consumed || "-" %></p>
          </div>
          <div class="bg-background-light dark:bg-graphite p-4 rounded-lg text-center">
            <p class="text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider mb-1">Protein</p>
            <p class="text-xl font-bold text-blackish dark:text-whiteish"><%= daily_metric.protein_consumed || "-" %>g</p>
          </div>
          <div class="bg-background-light dark:bg-graphite p-4 rounded-lg text-center">
            <p class="text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider mb-1">Steps</p>
            <p class="text-xl font-bold text-blackish dark:text-whiteish"><%= daily_metric.steps || "-" %></p>
          </div>
          <div class="bg-background-light dark:bg-graphite p-4 rounded-lg text-center">
            <p class="text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider mb-1">Weight</p>
            <p class="text-xl font-bold text-blackish dark:text-whiteish"><%= daily_metric.weight.truncate(2) || "-" %>kg</p>
          </div>
        </div>

        <!-- Compliance & Status -->
        <div class="flex gap-4">
           <% if daily_metric.compliant %>
              <div class="flex-1 p-3 bg-success/10 border border-success/20 rounded-lg flex items-center justify-center space-x-2 text-success">
                 <span class="material-symbols-outlined text-lg">check_circle</span>
                 <span class="font-semibold text-sm">Compliant</span>
              </div>
           <% else %>
               <div class="flex-1 p-3 bg-danger/10 border border-danger/20 rounded-lg flex items-center justify-center space-x-2 text-danger">
                 <span class="material-symbols-outlined text-lg">cancel</span>
                 <span class="font-semibold text-sm">Non-Compliant</span>
              </div>
           <% end %>

            <% if daily_metric.on_target %>
              <div class="flex-1 p-3 bg-primary/10 border border-primary/20 rounded-lg flex items-center justify-center space-x-2 text-primary">
                 <span class="material-symbols-outlined text-lg">ads_click</span>
                 <span class="font-semibold text-sm">On Target</span>
              </div>
           <% else %>
               <div class="flex-1 p-3 bg-warning/10 border border-warning/20 rounded-lg flex items-center justify-center space-x-2 text-warning">
                 <span class="material-symbols-outlined text-lg">warning</span>
                 <span class="font-semibold text-sm">Off Target</span>
              </div>
           <% end %>
        </div>

        <!-- Raw Message -->
        <div class="space-y-2">
            <h4 class="font-semibold text-blackish dark:text-whiteish flex items-center space-x-2">
                <span class="material-symbols-outlined text-lg text-primary">chat</span>
                <span>Raw Message Content</span>
            </h4>
            <div class="bg-background-light dark:bg-graphite p-4 rounded-lg font-mono text-sm text-graphite dark:text-muted whitespace-pre-wrap leading-relaxed border border-shadow dark:border-graphite/50">
                <%= daily_metric.raw_message_content %>
            </div>
        </div>

        <!-- AI Parsed Data (Expandable/Optional) -->
        <% if daily_metric.ai_parsed_json.present? %>
            <div class="space-y-2">
                <h4 class="font-semibold text-blackish dark:text-whiteish flex items-center space-x-2">
                    <span class="material-symbols-outlined text-lg text-primary">psychology</span>
                    <span>AI Parsed Data</span>
                </h4>
                <div class="bg-background-light dark:bg-graphite p-4 rounded-lg font-mono text-xs text-graphite dark:text-muted overflow-x-auto border border-shadow dark:border-graphite/50">
                    <pre><%= JSON.pretty_generate(daily_metric.ai_parsed_json) rescue daily_metric.ai_parsed_json %></pre>
                </div>
            </div>
        <% end %>

      </div>

      <!-- Footer -->
       <div class="bg-background-light dark:bg-graphite p-4 border-t border-shadow dark:border-graphite flex justify-end sticky bottom-0 rounded-b-xl">
           <button type="button" class="px-4 py-2 bg-whiteish dark:bg-shadow border border-shadow dark:border-graphite rounded-lg text-blackish dark:text-whiteish hover:bg-shadow/5 transition-colors text-sm font-medium" data-action="click->overlay#close">
             Close
           </button>
       </div>

    </div>
  </div>
<% end %>
