<div class="px-4 pt-6">
  <!-- Header -->
  <div class="grid grid-cols-1 gap-4 mb-4">
      <div class="flex justify-between items-end">
        <div>
           <p class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= Date.today.strftime("%A, %B %d, %Y") %></p>
           <h1 class="text-2xl font-semibold text-gray-900 dark:text-white">Admin Dashboard</h1>
        </div>
      </div>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 gap-4 mb-4 md:grid-cols-2 lg:grid-cols-4">
    <!-- Total Users -->
    <div class="border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 p-4 bg-white dark:bg-gray-800">
       <div class="flex items-center">
          <div class="inline-flex flex-shrink-0 justify-center items-center w-12 h-12 text-white bg-primary-600 rounded-lg shadow-lg shadow-primary-500/50">
             <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"></path></svg>
          </div>
          <div class="ml-4">
             <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white"><%= @total_users %></h3>
             <p class="font-light text-gray-500 dark:text-gray-400">Total Users</p>
          </div>
       </div>
    </div>

    <!-- Active Clients -->
    <div class="border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 p-4 bg-white dark:bg-gray-800">
        <div class="flex items-center">
            <div class="inline-flex flex-shrink-0 justify-center items-center w-12 h-12 text-white bg-green-500 rounded-lg shadow-lg shadow-green-500/50">
               <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path></svg>
            </div>
            <div class="ml-4">
               <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white"><%= @active_clients_count %></h3>
               <p class="font-light text-gray-500 dark:text-gray-400">Active Clients</p>
            </div>
         </div>
    </div>

    <!-- Low Compliance -->
    <div class="border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 p-4 bg-white dark:bg-gray-800">
         <div class="flex items-center">
             <div class="inline-flex flex-shrink-0 justify-center items-center w-12 h-12 text-white bg-red-500 rounded-lg shadow-lg shadow-red-500/50">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
             </div>
             <div class="ml-4">
                <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white"><%= @low_compliance_users_count %></h3>
                <p class="font-light text-gray-500 dark:text-gray-400">Low Compliance</p>
             </div>
          </div>
     </div>

     <!-- Pending Alerts -->
     <div class="border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 p-4 bg-white dark:bg-gray-800">
          <div class="flex items-center">
              <div class="inline-flex flex-shrink-0 justify-center items-center w-12 h-12 text-white bg-yellow-500 rounded-lg shadow-lg shadow-yellow-500/50">
                 <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
              </div>
              <div class="ml-4">
                 <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white"><%= @pending_alerts.count %></h3>
                 <p class="font-light text-gray-500 dark:text-gray-400">Pending Alerts</p>
              </div>
           </div>
      </div>
  </div>

  <!-- Main Content Grid -->
  <div class="grid grid-cols-1 w-full gap-4 mb-4 xl:grid-cols-3">
    <!-- Left Column -->
    <div class="xl:col-span-2 space-y-4">
        <!-- Priority Inbox -->
        <div class="bg-white border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 p-4 dark:bg-gray-800">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-xl font-bold text-gray-900 dark:text-white">Priority Inbox</h3>
                <span class="bg-yellow-100 text-yellow-800 text-xs font-medium mr-2 px-2.5 py-0.5 rounded dark:bg-yellow-900 dark:text-yellow-300"><%= @pending_alerts.count %> Pending</span>
            </div>
            <% if @pending_alerts.any? %>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
                        <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
                            <tr>
                                <th scope="col" class="px-4 py-3">Type</th>
                                <th scope="col" class="px-4 py-3">User</th>
                                <th scope="col" class="px-4 py-3">Message</th>
                                <th scope="col" class="px-4 py-3">Time</th>
                                <th scope="col" class="px-4 py-3">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% @pending_alerts.each do |alert| %>
                            <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600">
                                <td class="px-4 py-3">
                                    <% color_class = alert.weight_spike? ? 'text-red-600 dark:text-red-500' : 'text-yellow-600 dark:text-yellow-500' %>
                                    <span class="font-medium <%= color_class %>"><%= alert.category.humanize %></span>
                                </td>
                                <td class="px-4 py-3 font-medium text-gray-900 dark:text-white whitespace-nowrap"><%= alert.user.email %></td>
                                <td class="px-4 py-3 truncate max-w-xs"><%= alert.message %></td>
                                <td class="px-4 py-3"><%= time_ago_in_words(alert.created_at) %> ago</td>
                                <td class="px-4 py-3">
                                    <%= link_to "View", "/avo/resources/coach_alerts/#{alert.id}", class: "font-medium text-primary-600 hover:underline dark:text-primary-500" %>
                                </td>
                            </tr>
                            <% end %>
                        </tbody>
                    </table>
                </div>
            <% else %>
                <div class="flex flex-col items-center justify-center py-8 text-gray-500 dark:text-gray-400">
                    <svg class="w-12 h-12 mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <p>All caught up! No pending alerts.</p>
                </div>
            <% end %>
        </div>

        <!-- User Growth Chart -->
        <div class="bg-white border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 p-4 dark:bg-gray-800">
          <div class="flex items-center justify-between mb-4">
            <div class="flex-shrink-0">
              <span class="text-xl font-bold leading-none text-gray-900 sm:text-2xl dark:text-white">User Growth</span>
              <h3 class="text-base font-light text-gray-500 dark:text-gray-400">Users over last 7 days</h3>
            </div>
          </div>
          <div id="main-chart" data-controller="admin--charts" data-admin--charts-target="chart"></div>
        </div>
    </div>

    <!-- Right Column -->
    <div class="space-y-4">
        <!-- Quick Actions -->
        <div class="bg-white border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 p-4 dark:bg-gray-800">
             <h3 class="mb-4 text-xl font-bold text-gray-900 dark:text-white">Quick Actions</h3>
             <div class="grid grid-cols-1 gap-2">
                 <%= link_to "/avo/resources/users/new", class: "flex items-center p-3 text-base font-bold text-gray-900 rounded-lg bg-gray-50 hover:bg-gray-100 group hover:shadow dark:bg-gray-600 dark:hover:bg-gray-500 dark:text-white" do %>
                    <svg class="flex-shrink-0 w-5 h-5 text-gray-500 transition duration-75 group-hover:text-gray-900 dark:text-gray-400 dark:group-hover:text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M8 9a3 3 0 100-6 3 3 0 000 6zM8 11a6 6 0 016 6H2a6 6 0 016-6zM16 7a1 1 0 10-2 0v1h-1a1 1 0 100 2h1v1a1 1 0 102 0v-1h1a1 1 0 100-2h-1V7z"></path></svg>
                    <span class="flex-1 ml-3 whitespace-nowrap">Add New Client</span>
                 <% end %>
                 <%= link_to "/avo/resources/user_dietary_plans", class: "flex items-center p-3 text-base font-bold text-gray-900 rounded-lg bg-gray-50 hover:bg-gray-100 group hover:shadow dark:bg-gray-600 dark:hover:bg-gray-500 dark:text-white" do %>
                    <svg class="flex-shrink-0 w-5 h-5 text-gray-500 transition duration-75 group-hover:text-gray-900 dark:text-gray-400 dark:group-hover:text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 2a4 4 0 00-4 4v1H5a1 1 0 00-.994.89l-1 9A1 1 0 003.118 18h13.764a1 1 0 00.999-1.109l-1-9A1 1 0 0015 7h-1V6a4 4 0 00-4-4zm2 5V6a2 2 0 10-4 0v1h4zm-6 3a1 1 0 112 0 1 1 0 01-2 0zm7-1a1 1 0 100 2 1 1 0 000-2z" clip-rule="evenodd"></path></svg>
                    <span class="flex-1 ml-3 whitespace-nowrap">Nutrition Plans</span>
                 <% end %>
             </div>
        </div>

        <!-- Recent Users -->
        <div class="bg-white border border-gray-200 rounded-lg shadow-sm dark:border-gray-700 p-4 dark:bg-gray-800">
            <h3 class="mb-4 text-xl font-bold text-gray-900 dark:text-white">Recent Users</h3>
            <ul role="list" class="divide-y divide-gray-200 dark:divide-gray-700">
                <% @recent_users.each do |user| %>
                <li class="py-3 sm:py-4">
                    <div class="flex items-center space-x-4">
                        <div class="flex-shrink-0">
                            <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center text-primary-600 font-bold">
                                <%= user.email[0].upcase rescue "?" %>
                            </div>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-gray-900 truncate dark:text-white">
                                <%= user.email %>
                            </p>
                            <p class="text-sm text-gray-500 truncate dark:text-gray-400">
                                <%= time_ago_in_words(user.created_at) %> ago
                            </p>
                        </div>
                    </div>
                </li>
                <% end %>
            </ul>
            <div class="pt-4 mt-4 border-t border-gray-200 dark:border-gray-700">
                <%= link_to "View all", admin_users_path, class: "inline-flex items-center text-sm font-medium text-primary-600 hover:underline dark:text-primary-500" %>
            </div>
        </div>
    </div>
  </div>
</div>
