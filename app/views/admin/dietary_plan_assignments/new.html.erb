<%= turbo_frame_tag "modal_frame" do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-blackish/60 backdrop-blur-sm" data-controller="overlay">
    <div class="relative w-full max-w-lg mx-4 max-h-[80vh] flex flex-col bg-whiteish dark:bg-shadow rounded-xl border border-shadow dark:border-graphite shadow-xl">

      <div class="flex items-center justify-between px-6 py-4 border-b border-shadow dark:border-graphite">
        <h3 class="text-lg font-bold text-blackish dark:text-whiteish">Asignar Plan Alimenticio</h3>
        <%= link_to admin_user_path(@user), class: "p-1 text-graphite hover:text-blackish dark:text-muted dark:hover:text-whiteish transition-colors", data: { turbo_frame: "modal_frame" } do %>
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
        <% end %>
      </div>

      <div class="overflow-y-auto flex-1 px-6 py-4">
        <% if @dietary_plans.any? %>
          <ul class="space-y-2">
            <% @dietary_plans.each do |plan| %>
              <li>
                <%= button_to admin_user_dietary_plan_assignment_path(@user),
                    method: :post,
                    params: { dietary_plan_id: plan.id },
                    data: { turbo_frame: "_top" },
                    class: "w-full text-left p-4 bg-background-light dark:bg-graphite rounded-lg border border-shadow dark:border-graphite hover:border-primary dark:hover:border-primary transition-colors group" do %>
                  <div class="flex items-center justify-between">
                    <div>
                      <p class="font-medium text-blackish dark:text-whiteish group-hover:text-primary transition-colors"><%= plan.name %></p>
                      <div class="flex items-center gap-3 mt-1">
                        <% if plan.calories_target.present? %>
                          <span class="text-xs text-graphite dark:text-muted"><%= plan.calories_target %> kcal</span>
                        <% end %>
                        <% if plan.protein_target.present? %>
                          <span class="text-xs text-graphite dark:text-muted"><%= plan.protein_target %>g prot</span>
                        <% end %>
                      </div>
                    </div>
                    <svg class="w-4 h-4 text-graphite dark:text-muted group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  </div>
                <% end %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="flex flex-col items-center justify-center py-10 text-center">
            <span class="material-symbols-outlined text-3xl text-graphite dark:text-muted mb-2">restaurant_menu</span>
            <p class="text-graphite dark:text-muted text-sm">No hay planes alimenticios creados.</p>
          </div>
        <% end %>
      </div>

    </div>
  </div>
<% end %>
