<div id="dietary_plans_collection" class="relative overflow-x-auto bg-whiteish dark:bg-shadow shadow-xs rounded-xl border border-shadow dark:border-graphite mx-4">
    <table class="w-full text-sm text-left rtl:text-right text-graphite dark:text-muted">
        <thead class="text-sm text-blackish dark:text-whiteish bg-background-light dark:bg-graphite border-b border-shadow dark:border-graphite">
            <tr>
                <th scope="col" class="px-6 py-3 font-medium cursor-pointer hover:bg-background-light dark:hover:bg-shadow">
                    <%= render "admin/application/sortable_header", collection_presenter: collection_presenter, attr_name: :name, page: page, collection_field_name: local_assigns[:collection_field_name] %>
                </th>
                <th scope="col" class="px-6 py-3 font-medium cursor-pointer hover:bg-background-light dark:hover:bg-shadow">
                    <%= render "admin/application/sortable_header", collection_presenter: collection_presenter, attr_name: :calories_target, label: "Calories Target", page: page, collection_field_name: local_assigns[:collection_field_name] %>
                </th>
                <th scope="col" class="px-6 py-3 font-medium cursor-pointer hover:bg-background-light dark:hover:bg-shadow">
                    <%= render "admin/application/sortable_header", collection_presenter: collection_presenter, attr_name: :protein_target, label: "Protein Target", page: page, collection_field_name: local_assigns[:collection_field_name] %>
                </th>
                <th scope="col" class="px-6 py-3 font-medium cursor-pointer hover:bg-background-light dark:hover:bg-shadow">
                    <%= render "admin/application/sortable_header", collection_presenter: collection_presenter, attr_name: :description, page: page, collection_field_name: local_assigns[:collection_field_name] %>
                </th>
                <th scope="col" class="px-6 py-3 font-medium">
                    <span class="sr-only">Edit</span>
                </th>
            </tr>
        </thead>
        <tbody>
            <% resources.each do |resource| %>
            <tr class="bg-whiteish dark:bg-shadow border-b border-shadow dark:border-whiteish/50 hover:bg-background-light dark:hover:bg-shadow/50">
                <th scope="row" class="px-6 py-4 font-medium text-blackish dark:text-whiteish whitespace-nowrap">
                   <%= link_to resource.name, admin_dietary_plan_path(resource), class: "hover:text-primary dark:hover:text-primary" %>
                </th>
                <td class="px-6 py-4">
                    <%= resource.calories_target %>
                </td>
                <td class="px-6 py-4">
                    <%= resource.protein_target %> g
                </td>
                <td class="px-6 py-4 truncate max-w-xs">
                    <%= resource.description %>
                </td>
                <td class="px-6 py-4 text-right">
                    <%= link_to "Edit", edit_admin_dietary_plan_path(resource), data: { turbo_frame: "modal_frame" }, class: "font-medium text-primary dark:text-primary hover:underline" %>
                </td>
            </tr>
            <% end %>
        </tbody>
    </table>
</div>
