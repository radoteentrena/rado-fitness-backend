<%# app/views/admin/dietary_plans/show.html.erb %>
<% plan = page.resource %>

<div class="space-y-6">
  <%# Header with Back and Edit %>
  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-4">
      <%= link_to admin_dietary_plans_path, class: "p-2 text-graphite bg-whiteish rounded-lg border border-shadow hover:bg-background-light hover:text-blackish dark:bg-shadow dark:border-graphite dark:text-muted dark:hover:bg-shadow/50 dark:hover:text-whiteish" do %>
         <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5H1m0 0 4 4M1 5l4-4"/>
         </svg>
         <span class="sr-only">Back</span>
      <% end %>
      <h1 class="text-2xl font-bold tracking-tight text-blackish dark:text-whiteish">
        <%= plan.name %>
      </h1>
    </div>

    <div class="flex space-x-3">
        <%= link_to "Edit Plan", edit_admin_dietary_plan_path(plan), data: { turbo_frame: "modal_frame" }, class: "text-blackish bg-primary hover:bg-primary/90 focus:ring-4 focus:ring-primary/20 font-medium rounded-lg text-sm px-4 py-2 dark:bg-primary dark:hover:bg-primary/90 focus:outline-none dark:focus:ring-primary/20" %>
    </div>
  </div>

  <%# Main Content Grid %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <%# Left Column: Key Stats %>
    <div class="lg:col-span-1 space-y-6">
      <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
         <h5 class="mb-4 text-xl font-medium text-blackish dark:text-whiteish border-b border-shadow dark:border-graphite pb-2">Nutritional Targets</h5>

         <div class="grid grid-cols-2 gap-4">
             <div class="text-center p-4 bg-background-light dark:bg-graphite rounded-xl col-span-2">
                <dt class="text-sm font-medium text-graphite dark:text-muted mb-1">Calories</dt>
                <dd class="text-3xl font-bold text-blackish dark:text-whiteish"><%= plan.calories_target %></dd>
             </div>
             <div class="text-center p-4 bg-background-light dark:bg-graphite rounded-xl">
                <dt class="text-sm font-medium text-graphite dark:text-muted mb-1">Protein</dt>
                <dd class="text-3xl font-bold text-blackish dark:text-whiteish"><%= plan.protein_target %>g</dd>
             </div>
             <div class="text-center p-4 bg-background-light dark:bg-graphite rounded-xl">
                <dt class="text-sm font-medium text-graphite dark:text-muted mb-1">Fats</dt>
                <dd class="text-3xl font-bold text-blackish dark:text-whiteish"><%= plan.fats_target %>g</dd>
             </div>
             <div class="text-center p-4 bg-background-light dark:bg-graphite rounded-xl col-span-2">
                <dt class="text-sm font-medium text-graphite dark:text-muted mb-1">Carbs</dt>
                <dd class="text-3xl font-bold text-blackish dark:text-whiteish"><%= plan.carbs_target %>g</dd>
             </div>
         </div>
      </div>
    </div>

    <%# Right Column: Details & Notes %>
    <div class="lg:col-span-2 space-y-6">
        <%# Description %>
        <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
            <h3 class="text-lg font-bold text-blackish dark:text-whiteish mb-2">Description</h3>
            <p class="text-graphite dark:text-muted text-base leading-relaxed">
                <%= plan.description.presence || "No description provided." %>
            </p>
        </div>

        <%# Notes %>
         <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
            <h3 class="text-lg font-bold text-blackish dark:text-whiteish mb-4 flex items-center">
                <span class="material-symbols-outlined mr-2">description</span>
                Detailed Notes
            </h3>
            <div class="bg-background-light dark:bg-graphite p-4 rounded-lg text-sm text-graphite dark:text-muted whitespace-pre-wrap">
                <%= plan.notes.presence || "No additional notes." %>
            </div>
        </div>

    </div>
  </div>
</div>

<%= turbo_frame_tag "modal_frame" %>
