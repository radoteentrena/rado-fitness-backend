<div class="relative overflow-x-auto bg-whiteish dark:bg-shadow shadow-xs rounded-xl border border-graphite dark:border-graphite mx-4">
  <table class="w-full text-sm text-left rtl:text-right text-graphite dark:text-muted">
    <thead class="text-sm text-blackish dark:text-whiteish bg-background-light dark:bg-graphite border-b border-shadow dark:border-graphite">
      <tr>
        <th scope="col" class="px-6 py-3 font-medium cursor-pointer hover:bg-background-light dark:hover:bg-shadow">
          <%= render "admin/application/sortable_header", collection_presenter: collection_presenter, attr_name: :id, label: "ID", page: page, collection_field_name: local_assigns[:collection_field_name] %>
        </th>
        <th scope="col" class="px-6 py-3 font-medium cursor-pointer hover:bg-background-light dark:hover:bg-shadow">
          <%= render "admin/application/sortable_header", collection_presenter: collection_presenter, attr_name: :name, page: page, collection_field_name: local_assigns[:collection_field_name] %>
        </th>
        <th scope="col" class="px-6 py-3 font-medium cursor-pointer hover:bg-background-light dark:hover:bg-shadow">
          <%= render "admin/application/sortable_header", collection_presenter: collection_presenter, attr_name: :muscle_group, label: "Muscle Group", page: page, collection_field_name: local_assigns[:collection_field_name] %>
        </th>
        <th scope="col" class="px-6 py-3 font-medium cursor-pointer hover:bg-background-light dark:hover:bg-shadow">
          <%= render "admin/application/sortable_header", collection_presenter: collection_presenter, attr_name: :video_link, label: "Video", page: page, collection_field_name: local_assigns[:collection_field_name] %>
        </th>
        <th scope="col" class="px-6 py-3 font-medium">
          <span class="sr-only">Edit</span>
        </th>
      </tr>
    </thead>
    <tbody>
      <% resources.each do |resource| %>
        <tr class="bg-whiteish dark:bg-shadow border-b border-shadow dark:border-whiteish/50 hover:bg-background-light dark:hover:bg-shadow/50">
          <th scope="row" class="px-6 py-4 font-medium text-blackish dark:text-whiteish whitespace-nowrap">
            <%= resource.id %>
          </th>
          <td class="px-6 py-4 font-medium text-blackish dark:text-whiteish">
            <%= link_to resource.name, admin_exercise_path(resource), class: "hover:text-primary transition-colors" %>
          </td>
          <td class="px-6 py-4">
            <%= resource.muscle_group %>
          </td>
          <td class="px-6 py-4">
            <% if resource.video_link.present? %>
                <a href="<%= resource.video_link %>" target="_blank" class="text-primary hover:text-primary/80">
                    <span class="material-symbols-outlined">play_circle</span>
                </a>
            <% else %>
                <span class="text-muted">–</span>
            <% end %>
          </td>

          <td class="px-6 py-4 text-right">
            <div class="flex items-center justify-end gap-3">
              <%= link_to "Edit", edit_admin_exercise_path(resource), data: { turbo_frame: "modal_frame" }, class: "font-medium text-primary dark:text-primary hover:underline" %>
              <%= button_to admin_exercise_path(resource), method: :delete,
                    data: { turbo_confirm: "¿Eliminar el ejercicio \"#{resource.name}\"? Esta acción no se puede deshacer." },
                    class: "inline-flex items-center p-1.5 text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 transition-colors cursor-pointer",
                    form: { class: "inline-flex" },
                    title: "Eliminar" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
