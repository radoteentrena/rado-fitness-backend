<div class="fixed inset-0 z-50 flex items-center justify-center bg-blackish/50 backdrop-blur-sm p-4">
  <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-xl w-full max-w-lg overflow-hidden border border-shadow dark:border-graphite">
    <%# Header %>
    <div class="flex items-center justify-between p-4 border-b border-shadow dark:border-graphite bg-background-light dark:bg-graphite">
      <h3 class="text-lg font-semibold text-blackish dark:text-whiteish">
        Add Routine to Phase
      </h3>
      <% builder_program_id = params[:program_id] || Phase.find_by(id: params[:phase_id] || resource.phase_id)&.program_id %>
      <%= link_to (builder_program_id ? admin_program_builder_path(builder_program_id) : admin_programs_path), class: "text-graphite hover:text-blackish dark:text-muted dark:hover:text-whiteish transition-colors" do %>
        <span class="material-symbols-outlined">close</span>
      <% end %>
    </div>

    <%# Form %>
    <%= form_for([namespace, resource], html: { class: "p-6 space-y-6", data: { turbo_frame: "_top" } }) do |f| %>
      <% if resource.errors.any? %>
        <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900/50 dark:text-red-300" role="alert">
          <ul class="list-disc pl-5 space-y-1">
            <% resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 gap-6">
        <%# Phase ID (Hidden if passed via params, otherwise select) %>
        <div class="col-span-1">
          <% if params[:phase_id] || resource.phase_id %>
            <%= f.hidden_field :phase_id, value: params[:phase_id] || resource.phase_id %>
            <%= hidden_field_tag :program_id, Phase.find_by(id: params[:phase_id] || resource.phase_id)&.program_id %>
            <%= f.label :phase_id, "Assigning to Phase", class: "block mb-2 text-sm font-medium text-graphite dark:text-muted" %>
            <div class="bg-whiteish border border-shadow text-graphite text-sm rounded-lg block w-full p-2.5 dark:bg-blackish dark:border-graphite dark:text-muted cursor-not-allowed">
              <%= Phase.find_by(id: params[:phase_id] || resource.phase_id)&.name || "Selected Phase" %>
            </div>
          <% else %>
            <%= f.label :phase_id, class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
            <%= f.select :phase_id, Phase.all.map { |p| [p.name, p.id] }, { include_blank: "Select Phase" }, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
          <% end %>
        </div>

        <%# Routine ID (Select existing Routine) %>
        <div class="col-span-1">
          <%= f.label :routine_id, "Select Routine", class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
          <%= f.select :routine_id, Routine.all.order(:name).map { |r| ["#{r.name}#{' (Template)' if r.is_template?}", r.id] }, { include_blank: "Select Routine to Add" }, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish", required: true %>
          <p class="mt-2 text-sm text-graphite dark:text-muted">Select an existing routine to add it to this phase.</p>
        </div>
      </div>

      <%# Footer %>
      <div class="flex items-center justify-end space-x-3 pt-4 border-t border-shadow dark:border-graphite">
        <%= link_to "Cancel", (builder_program_id ? admin_program_builder_path(builder_program_id) : admin_programs_path), class: "text-blackish bg-whiteish border border-shadow focus:ring-4 focus:outline-none focus:ring-primary/20 font-medium rounded-lg text-sm px-5 py-2.5 hover:bg-background-light hover:text-primary focus:z-10 dark:bg-shadow dark:text-muted dark:border-graphite dark:hover:text-whiteish dark:hover:bg-graphite", data: { turbo_frame: "_top" } %>
        <%= f.submit "Add Routine", class: "text-blackish bg-primary hover:bg-primary/90 focus:ring-4 focus:outline-none focus:ring-primary/20 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-primary dark:hover:bg-primary/90 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
