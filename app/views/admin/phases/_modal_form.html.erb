<div class="fixed inset-0 z-50 flex items-center justify-center bg-blackish/50 backdrop-blur-sm p-4">
  <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-xl w-full max-w-2xl overflow-hidden border border-shadow dark:border-graphite">
    <%# Header %>
    <div class="flex items-center justify-between p-4 border-b border-shadow dark:border-graphite bg-background-light dark:bg-graphite">
      <h3 class="text-lg font-semibold text-blackish dark:text-whiteish">
        <%= resource.persisted? ? "Edit Phase" : "New Phase" %>
      </h3>
      <%= link_to admin_phases_path, class: "text-graphite hover:text-blackish dark:text-muted dark:hover:text-whiteish transition-colors" do %>
        <span class="material-symbols-outlined">close</span>
      <% end %>
    </div>

    <%# Form %>
    <%= form_for([namespace, resource], html: { class: "p-6 space-y-6", data: { turbo_frame: "_top" } }) do |f| %>
      <% if resource.errors.any? %>
        <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900/50 dark:text-red-300" role="alert">
          <ul class="list-disc pl-5 space-y-1">
            <% resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <%# Name %>
        <div class="col-span-2 md:col-span-1">
          <%= f.label :name, class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
          <%= f.text_field :name, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>

        <%# Duration %>
        <div class="col-span-2 md:col-span-1">
          <%= f.label :duration_weeks, "Duration (Weeks)", class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
          <%= f.number_field :duration_weeks, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>

        <%# Program ID (Hidden if passed via params, otherwise select) %>
        <div class="col-span-2 md:col-span-1">
          <% if params[:program_id] || resource.program_id %>
            <%= f.hidden_field :program_id, value: params[:program_id] || resource.program_id %>
            <%= f.label :program_id, "Program", class: "block mb-2 text-sm font-medium text-graphite dark:text-muted" %>
            <div class="bg-whiteish border border-shadow text-graphite text-sm rounded-lg block w-full p-2.5 dark:bg-blackish dark:border-graphite dark:text-muted cursor-not-allowed">
              <%= Program.find_by(id: params[:program_id] || resource.program_id)&.name || "Selected Program" %>
            </div>
          <% else %>
            <%= f.label :program_id, class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
            <%= f.select :program_id, Program.all.map { |u| [u.name, u.id] }, { include_blank: "Select Program" }, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
          <% end %>
        </div>

        <%# Order Index %>
        <div class="col-span-2 md:col-span-1">
          <%= f.label :order_index, "Order Index", class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
          <%= f.number_field :order_index, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>

        <%# Description %>
        <div class="col-span-2">
          <%= f.label :description, class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
          <%= f.text_area :description, rows: 4, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>

        <%# Routines %>
        <div class="col-span-2" data-controller="phase-routine-filter">
          <%= f.label :routine_ids, "Included Routines", class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>

          <%# Filters — mirror the routines page (Género / Objetivo / Nivel) %>
          <div class="flex flex-wrap gap-2 mb-2">
            <select data-phase-routine-filter-target="filter" data-action="change->phase-routine-filter#filter"
                    class="bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary p-2 dark:bg-graphite dark:border-graphite dark:text-whiteish">
              <option value="">Género</option>
              <% Routine::GENDERS.each do |g| %><option value="<%= g %>"><%= g %></option><% end %>
            </select>
            <select data-phase-routine-filter-target="filter" data-action="change->phase-routine-filter#filter"
                    class="bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary p-2 dark:bg-graphite dark:border-graphite dark:text-whiteish">
              <option value="">Objetivo</option>
              <% Routine::FOCUSES.each do |v| %><option value="<%= v %>"><%= v %></option><% end %>
            </select>
            <select data-phase-routine-filter-target="filter" data-action="change->phase-routine-filter#filter"
                    class="bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary p-2 dark:bg-graphite dark:border-graphite dark:text-whiteish">
              <option value="">Nivel</option>
              <% Routine::LEVELS.each do |v| %><option value="<%= v %>"><%= v %></option><% end %>
            </select>
          </div>

          <div class="bg-background-light dark:bg-shadow border border-shadow dark:border-graphite rounded-lg max-h-48 overflow-y-auto p-3 space-y-2">
            <%= f.collection_check_boxes :routine_ids, Routine.where(is_template: true).order(name: :asc, id: :desc), :id, :name do |b| %>
              <div class="flex items-center" data-phase-routine-filter-target="row" data-name="<%= b.object.name.to_s.downcase %>">
                <%= b.check_box class: "w-4 h-4 text-primary bg-whiteish border-shadow rounded focus:ring-primary dark:focus:ring-primary dark:ring-offset-shadow dark:bg-blackish dark:border-graphite" %>
                <%= b.label(class: "ml-2 text-sm font-medium text-blackish dark:text-whiteish cursor-pointer flex items-center") do %>
                  <%= b.object.name.presence || "Routine ##{b.object.id}" %>
                  <span class="text-xs text-graphite dark:text-muted ml-1">(<%= b.object.duration_weeks || 0 %> Weeks)</span>
                <% end %>
              </div>
            <% end %>
            <p data-phase-routine-filter-target="empty" class="hidden text-sm text-graphite dark:text-muted py-2 text-center">No hay rutinas que coincidan con los filtros.</p>
          </div>
          <p class="mt-1 text-xs text-graphite dark:text-muted">Select existing routines to automatically populate this phase.</p>
        </div>
      </div>

      <%# Footer %>
      <div class="flex items-center justify-end space-x-3 pt-4 border-t border-shadow dark:border-graphite">
        <%= link_to "Cancel", admin_phases_path, class: "text-blackish bg-whiteish border border-shadow focus:ring-4 focus:outline-none focus:ring-primary/20 font-medium rounded-lg text-sm px-5 py-2.5 hover:bg-background-light hover:text-primary focus:z-10 dark:bg-shadow dark:text-muted dark:border-graphite dark:hover:text-whiteish dark:hover:bg-graphite", data: { turbo_frame: "_top" } %>
        <%= f.submit class: "text-blackish bg-primary hover:bg-primary/90 focus:ring-4 focus:outline-none focus:ring-primary/20 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-primary dark:hover:bg-primary/90 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
