<%# app/views/admin/phases/update.turbo_stream.erb %>

<%# 1. Close the modal %>
<%= turbo_stream.update "modal_frame", "" %>

<%# 2. Replace the existing phase block with the updated one %>
<%= turbo_stream.replace dom_id(requested_resource) do %>
  <%= render partial: "admin/phases/phase_block", object: requested_resource, as: :phase %>
<% end %>

<%# 3. Flash message %>
<%= turbo_stream.prepend "flash_messages" do %>
  <div class="p-4 mb-4 text-sm text-green-800 rounded-lg bg-green-50 dark:bg-shadow dark:text-green-400 border border-green-300 dark:border-green-800" role="alert">
    <span class="font-medium">Success!</span> Phase was successfully updated.
  </div>
<% end %>
