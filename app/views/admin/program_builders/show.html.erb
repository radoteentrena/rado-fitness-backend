<%# app/views/admin/program_builders/show.html.erb %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-4">
      <%= link_to admin_programs_path, class: "p-2 text-graphite bg-whiteish rounded-lg border border-shadow hover:bg-background-light hover:text-blackish dark:bg-shadow dark:border-graphite dark:text-muted dark:hover:bg-shadow/50 dark:hover:text-whiteish" do %>
         <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5H1m0 0 4 4M1 5l4-4"/>
         </svg>
         <span class="sr-only">Back</span>
      <% end %>
      <div>
        <h1 class="text-2xl font-bold tracking-tight text-blackish dark:text-whiteish flex items-center gap-2">
          Builder: <%= @program.name %>
          <% unless @program.user %>
            <span class="bg-primary/20 text-primary text-xs font-medium px-2.5 py-0.5 rounded border border-primary/20">Template</span>
          <% end %>
        </h1>
        <p class="text-sm text-graphite dark:text-muted mt-1">
          Duration: <%= @program.duration_weeks %> Weeks | Assigned To: <%= @program.user&.name || "Unassigned" %>
        </p>
      </div>
    </div>

  </div>

  <div id="program-builder-content">
    <%= render partial: "admin/program_builders/content",
               locals: { program: @program, phases: @phases } %>
  </div>

</div>

<%= turbo_frame_tag "modal_frame" %>
