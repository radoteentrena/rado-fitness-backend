<%# app/views/admin/program_builders/show.html.erb %>

<div data-controller="program-chat" class="space-y-6">
  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-4">
      <%= link_to admin_programs_path, class: "p-2 text-graphite bg-whiteish rounded-lg border border-shadow hover:bg-background-light hover:text-blackish dark:bg-shadow dark:border-graphite dark:text-muted dark:hover:bg-shadow/50 dark:hover:text-whiteish" do %>
         <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5H1m0 0 4 4M1 5l4-4"/>
         </svg>
         <span class="sr-only">Back</span>
      <% end %>
      <div>
        <h1 class="text-2xl font-bold tracking-tight text-blackish dark:text-whiteish flex items-center gap-2">
          Builder: <%= @program.name %>
          <% unless @program.user %>
            <span class="bg-primary/20 text-primary text-xs font-medium px-2.5 py-0.5 rounded border border-primary/20">Template</span>
          <% end %>
        </h1>
        <p class="text-sm text-graphite dark:text-muted mt-1">
          Duration: <%= @program.duration_weeks %> Weeks | Assigned To: <%= @program.user&.name || "Unassigned" %>
        </p>
      </div>
    </div>

    <button data-action="program-chat#open"
            class="flex items-center gap-2 text-sm font-medium px-4 py-2 border-2 border-primary text-primary hover:bg-primary hover:text-blackish transition-all">
      <span class="material-symbols-outlined text-base">smart_toy</span>
      Chat con AI Coach
    </button>
  </div>

  <div id="program-builder-content">
    <%= render partial: "admin/program_builders/content",
               locals: { program: @program, phases: @phases } %>
  </div>

  <div data-program-chat-target="panel"
       class="fixed right-0 top-0 h-full w-96 z-50 bg-blackish border-l-2 border-primary/50 transform transition-transform duration-300 translate-x-full flex flex-col">

    <div class="flex items-center justify-between px-4 py-3 border-b border-primary/30 shrink-0">
      <h2 class="text-sm font-bold text-whiteish uppercase tracking-wider">AI Coach Chat</h2>
      <button data-action="program-chat#close"
              class="text-muted hover:text-whiteish transition-colors p-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <turbo-frame id="program-chat-panel"
                 data-program-chat-target="frame"
                 data-chat-url="<%= admin_program_chat_path(@program) %>"
                 class="flex flex-col flex-1 min-h-0">
      <div class="flex items-center justify-center h-full text-muted text-sm">
        Cargando chat...
      </div>
    </turbo-frame>
  </div>
</div>

<%= turbo_frame_tag "modal_frame" %>
