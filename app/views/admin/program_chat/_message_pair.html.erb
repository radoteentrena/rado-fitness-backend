<div class="flex justify-end">
  <div class="max-w-[85%] bg-primary/20 border border-primary/30 text-whiteish text-sm rounded-lg px-3 py-2">
    <%= user_message %>
  </div>
</div>

<div class="flex justify-start">
  <div class="max-w-[85%] bg-graphite border border-primary/20 text-whiteish text-sm rounded-lg px-3 py-2">
    <p class="text-xs text-muted mb-2 font-medium uppercase tracking-wider">AI Coach</p>
    <p class="mb-2"><%= summary %></p>
    <% if modifications.any? %>
      <ul class="space-y-1 border-t border-primary/20 pt-2">
        <% modifications.each do |mod| %>
          <li class="text-xs text-muted">
            <% if mod["workout_exercise_id"].present? %>
              <span class="text-primary font-medium">#<%= mod["workout_exercise_id"] %></span>
              <%= mod.except("workout_exercise_id").map { |k, v| "#{k}: #{v}" }.join(" · ") %>
            <% else %>
              <span class="text-saffron font-medium">+ <%= mod["name"] %></span>
              (workout #<%= mod["workout_id"] %>) · <%= mod["sets"] %>x<%= mod["reps"] %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
</div>
