<%= turbo_frame_tag "program-chat-panel" do %>
  <div class="flex flex-col h-full">
    <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-3 min-h-0">
      <p class="text-xs text-muted text-center py-4">
        Chat activo para <span class="text-primary font-medium"><%= @program.name %></span>.
        Pedile al AI Coach que modifique ejercicios, series, repeticiones o cargas.
      </p>
    </div>

    <div id="chat-error" class="px-4"></div>

    <div id="chat-apply-button" class="px-4 pb-2"></div>

    <%= form_with url: message_admin_program_chat_path(@program), method: :post,
                  class: "border-t border-primary/30 shrink-0" do |f| %>
      <div class="p-4 space-y-2">
        <%= f.hidden_field :conversation_id, value: @conversation.id %>
        <%= f.text_area :message, rows: 3,
                        class: "w-full bg-blackish border border-primary/30 text-whiteish text-sm rounded p-3 resize-none focus:outline-none focus:ring-1 focus:ring-primary placeholder:text-muted",
                        placeholder: "Ej: Aumenta el volumen de press de banca a 5x5...",
                        required: true %>
        <%= f.submit "Enviar",
                     class: "w-full button text-sm py-2",
                     data: { turbo_submits_with: "Enviando..." } %>
      </div>
    <% end %>
  </div>
<% end %>
