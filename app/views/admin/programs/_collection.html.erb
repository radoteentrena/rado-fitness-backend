<div class="relative overflow-x-auto bg-whiteish dark:bg-shadow shadow-xs rounded-xl border border-shadow dark:border-graphite mx-4">
  <table class="w-full text-sm text-left text-graphite dark:text-muted">
    <thead class="text-xs text-blackish uppercase border-b border-graphite bg-background-light dark:bg-graphite dark:text-whiteish">
      <tr>
        <th scope="col" class="px-6 py-3 w-full">Programa</th>
        <th scope="col" class="px-6 py-3 whitespace-nowrap">Rutinas</th>
        <th scope="col" class="px-6 py-3 whitespace-nowrap">Fases</th>
        <th scope="col" class="px-6 py-3 whitespace-nowrap">Duración</th>
        <th scope="col" class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody>
      <% resources.each do |resource| %>
        <% routines = resource.phases.flat_map { |p| p.phase_routines.map(&:routine) }.compact.uniq(&:id) %>
        <tr class="bg-whiteish dark:bg-shadow border-b border-shadow dark:border-graphite hover:bg-background-light dark:hover:bg-shadow/50">

          <%# Program name %>
          <td class="px-6 py-4">
            <%= link_to resource.name, admin_program_path(resource),
                class: "font-medium text-blackish dark:text-whiteish hover:text-primary dark:hover:text-primary transition-colors" %>
          </td>

          <%# Attached routines %>
          <td class="px-6 py-4">
            <% if routines.any? %>
              <div class="flex flex-col gap-1">
                <% routines.each do |routine| %>
                  <%= link_to routine.name, admin_routine_path(routine), data: { turbo: false },
                      class: "text-xs text-graphite dark:text-muted hover:text-primary dark:hover:text-primary transition-colors truncate max-w-[220px] block" %>
                <% end %>
              </div>
            <% else %>
              <span class="text-graphite dark:text-muted">—</span>
            <% end %>
          </td>

          <%# Phases count %>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="flex items-center gap-1.5 text-graphite dark:text-muted">
              <span class="material-symbols-outlined text-base">schema</span>
              <%= resource.phases.size %>
            </div>
          </td>

          <%# Duration %>
          <td class="px-6 py-4 whitespace-nowrap">
            <% if resource.duration_weeks.present? %>
              <div class="flex items-center gap-1.5 text-graphite dark:text-muted">
                <span class="material-symbols-outlined text-base">calendar_month</span>
                <%= resource.duration_weeks %> sem.
              </div>
            <% else %>
              <span class="text-graphite dark:text-muted">—</span>
            <% end %>
          </td>

          <%# Actions %>
          <td class="px-6 py-4">
            <div class="flex items-center justify-end gap-1">
              <%= link_to admin_program_path(resource),
                  title: "Ver programa",
                  class: "p-1.5 rounded text-graphite hover:text-primary dark:text-muted dark:hover:text-primary hover:bg-background-light dark:hover:bg-blackish transition-colors" do %>
                <span class="material-symbols-outlined text-[18px]">visibility</span>
              <% end %>

              <%= link_to edit_admin_program_path(resource), data: { turbo_frame: "modal_frame" },
                  title: "Editar programa",
                  class: "p-1.5 rounded text-graphite hover:text-primary dark:text-muted dark:hover:text-primary hover:bg-background-light dark:hover:bg-blackish transition-colors" do %>
                <span class="material-symbols-outlined text-[18px]">edit</span>
              <% end %>

              <%= button_to admin_program_path(resource), method: :delete,
                  title: "Eliminar programa",
                  data: { turbo_confirm: "¿Eliminar el programa \"#{resource.name}\"? Esta acción no se puede deshacer." },
                  class: "p-1.5 rounded text-graphite hover:text-red-500 dark:text-muted dark:hover:text-red-400 hover:bg-background-light dark:hover:bg-blackish transition-colors cursor-pointer bg-transparent border-0" do %>
                <span class="material-symbols-outlined text-[18px]">delete</span>
              <% end %>
            </div>
          </td>

        </tr>
      <% end %>
    </tbody>
  </table>
</div>
