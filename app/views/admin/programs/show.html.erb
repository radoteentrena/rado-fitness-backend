<%# app/views/admin/programs/show.html.erb %>
<% program = page.resource %>

<div class="space-y-6">
  <%# Header with Back and Edit %>
  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-4">
      <%= link_to admin_programs_path, class: "p-2 text-graphite bg-whiteish rounded-lg border border-shadow hover:bg-background-light hover:text-blackish dark:bg-shadow dark:border-graphite dark:text-muted dark:hover:bg-shadow/50 dark:hover:text-whiteish" do %>
         <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5H1m0 0 4 4M1 5l4-4"/>
         </svg>
         <span class="sr-only">Back</span>
      <% end %>
      <h1 class="text-2xl font-bold tracking-tight text-blackish dark:text-whiteish">
        <%= program.name %>
      </h1>
      <% unless program.user %>
        <span class="bg-primary/20 text-primary text-xs font-medium px-2.5 py-0.5 rounded border border-primary/20">Template</span>
      <% end %>
    </div>

    <div class="flex space-x-3">
        <%= link_to "Open Builder", admin_program_builder_path(program), class: "text-blackish bg-background-light border border-shadow hover:bg-whiteish focus:ring-4 focus:ring-primary/20 font-medium rounded-lg text-sm px-4 py-2 dark:bg-shadow dark:text-whiteish dark:border-graphite dark:hover:bg-shadow/50 focus:outline-none dark:focus:ring-primary/20 transition-colors flex items-center" %>
        <%= link_to "Edit Program", edit_admin_program_path(program), data: { turbo_frame: "modal_frame" }, class: "text-blackish bg-primary hover:bg-primary/90 focus:ring-4 focus:ring-primary/20 font-medium rounded-lg text-sm px-4 py-2 dark:bg-primary dark:hover:bg-primary/90 focus:outline-none dark:focus:ring-primary/20 flex items-center" %>
    </div>
  </div>

  <%# Main Content Grid %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <%# Left Column: Key Stats %>
    <div class="lg:col-span-1 space-y-6">
      <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
         <h5 class="mb-4 text-xl font-medium text-blackish dark:text-whiteish border-b border-shadow dark:border-graphite pb-2">Details</h5>

         <div class="space-y-4">
             <div class="flex justify-between items-center py-2 border-b border-shadow dark:border-graphite last:border-0">
                <span class="text-sm font-medium text-graphite dark:text-muted">Duration</span>
                <span class="text-sm font-bold text-blackish dark:text-whiteish"><%= program.duration_weeks %> Weeks</span>
             </div>
             <div class="flex justify-between items-center py-2 border-b border-shadow dark:border-graphite last:border-0">
                <span class="text-sm font-medium text-graphite dark:text-muted">Assigned To</span>
                <% if program.user %>
                    <%= link_to program.user.name, admin_user_path(program.user), class: "text-sm font-bold text-primary hover:underline" %>
                <% else %>
                    <span class="text-sm font-bold text-graphite dark:text-muted">Unassigned</span>
                <% end %>
             </div>

             <% if program.google_sheet_link.present? %>
                 <div class="pt-4 space-y-3">
                    <a href="<%= program.google_sheet_link %>" target="_blank" class="flex items-center justify-center w-full text-whiteish bg-green-600 hover:bg-green-700 focus:ring-4 focus:ring-green-300 font-medium rounded-lg text-sm px-4 py-2 dark:bg-green-600 dark:hover:bg-green-700 dark:focus:ring-green-800 transition-colors">
                        <span class="material-symbols-outlined mr-2">table_view</span>
                        Open Google Sheet
                    </a>

                    <%= button_to sync_sheet_admin_program_path(program), method: :post, class: "flex items-center justify-center w-full text-blackish bg-whiteish border border-shadow hover:bg-background-light focus:ring-4 focus:ring-primary/20 font-medium rounded-lg text-sm px-4 py-2 dark:bg-shadow dark:text-whiteish dark:border-graphite dark:hover:bg-shadow/50 transition-colors" do %>
                        <span class="material-symbols-outlined mr-2">sync</span>
                        Sync from Sheet
                    <% end %>

                    <% if program.last_synced_at %>
                        <p class="text-xs text-center text-graphite dark:text-muted">
                            Last synced: <%= time_ago_in_words(program.last_synced_at) %> ago
                        </p>
                    <% end %>
                 </div>
             <% else %>
                 <div class="pt-4">
                    <p class="text-xs text-graphite dark:text-muted italic">
                      No Google Sheet link attached. You can add a link by editing the program.
                    </p>
                 </div>
             <% end %>
         </div>
      </div>
    </div>

    <%# Right Column: Description & Routines %>
    <div class="lg:col-span-2 space-y-6">
        <%# Description %>
        <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
            <h3 class="text-lg font-bold text-blackish dark:text-whiteish mb-2">Overview</h3>
            <p class="text-graphite dark:text-muted text-base leading-relaxed">
                <%= program.description.presence || "No description provided." %>
            </p>
        </div>

        <%# Routines Placeholder (Future Proofing) %>
         <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold text-blackish dark:text-whiteish">Routines</h3>
                <span class="bg-background-light text-graphite text-xs font-medium px-2.5 py-0.5 rounded dark:bg-graphite dark:text-muted border border-shadow dark:border-graphite">
                    <%= program.routines.count %>
                </span>
            </div>

            <% if program.routines.any? %>
                <ul class="divide-y divide-shadow dark:divide-graphite">
                    <% program.routines.each do |routine| %>
                        <li class="py-3 sm:py-4">
                            <div class="flex items-center space-x-4">
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-medium text-blackish truncate dark:text-whiteish">
                                        <%= link_to (routine.name.presence || "Routine ##{routine.id}"), admin_routine_path(routine), data: { turbo: false }, class: "hover:text-primary transition-colors" %>
                                    </p>
                                    <p class="text-sm text-graphite truncate dark:text-muted">
                                        <%= routine.description rescue "" %>
                                    </p>
                                </div>
                                <div class="inline-flex items-center text-base font-semibold text-blackish dark:text-whiteish">
                                    <%= link_to admin_routine_path(routine), data: { turbo: false }, class: "text-graphite hover:text-primary dark:text-muted dark:hover:text-primary transition-colors" do %>
                                        <span class="material-symbols-outlined">chevron_right</span>
                                    <% end %>
                                </div>
                            </div>
                        </li>
                    <% end %>
                </ul>
            <% else %>
                <p class="text-sm text-graphite dark:text-muted italic">No routines added to this program yet.</p>
            <% end %>
        </div>

    </div>
  </div>
  </div>

</div>

<%= turbo_frame_tag "modal_frame" %>
