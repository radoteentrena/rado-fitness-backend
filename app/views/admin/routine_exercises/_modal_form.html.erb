<div class="fixed inset-0 z-50 flex items-center justify-center bg-blackish/50 backdrop-blur-sm p-4">
  <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto border border-shadow dark:border-graphite">
    <%# Header %>
    <div class="flex items-center justify-between p-4 border-b border-shadow dark:border-graphite bg-background-light dark:bg-graphite sticky top-0 z-10">
      <h3 class="text-lg font-semibold text-blackish dark:text-whiteish">
        <%= resource.persisted? ? "Edit Routine Exercise" : "Add Exercise to Routine" %>
      </h3>
      <%= link_to admin_routine_exercises_path, class: "text-graphite hover:text-blackish dark:text-muted dark:hover:text-whiteish transition-colors" do %>
        <span class="material-symbols-outlined">close</span>
      <% end %>
    </div>

    <%# Form %>
    <%= form_for([namespace, resource], html: { class: "p-6 space-y-6" }) do |f| %>
      <% if resource.errors.any? %>
        <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900/50 dark:text-red-300" role="alert">
          <ul class="list-disc pl-5 space-y-1">
            <% resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <%# Routine & Exercise Selection %>
        <div class="col-span-2 md:col-span-1">
          <%= f.label :routine_id, class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
          <%= f.select :routine_id, Routine.all.map { |r| [r.name, r.id] }, { include_blank: "Select Routine" }, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>

        <div class="col-span-2 md:col-span-1">
          <%= f.label :exercise_id, class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
          <%= f.select :exercise_id, Exercise.all.map { |e| [e.name, e.id] }, { include_blank: "Select Exercise" }, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>

        <%# Day Configuration %>
         <div class="col-span-2 md:col-span-1">
          <%= f.label :day_number, "Day Number", class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
          <%= f.number_field :day_number, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>

        <div class="col-span-2 md:col-span-1">
           <%= f.label :day_name, "Day Name (e.g. Chest Day)", class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
           <%= f.text_field :day_name, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>

         <div class="col-span-2 md:col-span-1">
          <%= f.label :order_index, "Order in Workout", class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
          <%= f.number_field :order_index, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>

        <div class="col-span-2 md:col-span-1 flex items-center pt-8">
             <div class="flex items-center">
                <%= f.check_box :warmup, class: "w-4 h-4 text-primary bg-background-light border-shadow rounded focus:ring-primary dark:focus:ring-primary dark:ring-offset-gray-800 focus:ring-2 dark:bg-shadow dark:border-graphite" %>
                <%= f.label :warmup, "Is Warmup?", class: "ml-2 text-sm font-medium text-blackish dark:text-whiteish" %>
            </div>
        </div>


        <%# Protocol Details %>
        <div class="col-span-2 border-t border-shadow dark:border-graphite pt-4">
             <h4 class="text-sm font-bold text-blackish dark:text-whiteish mb-4">Training Protocol</h4>
             <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div>
                   <%= f.label :sets, class: "block mb-2 text-xs font-medium text-graphite dark:text-muted" %>
                   <%= f.number_field :sets, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:text-whiteish" %>
                </div>
                 <div>
                   <%= f.label :reps, class: "block mb-2 text-xs font-medium text-graphite dark:text-muted" %>
                   <%= f.text_field :reps, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:text-whiteish" %>
                </div>
                 <div>
                   <%= f.label :rir, "RIR", class: "block mb-2 text-xs font-medium text-graphite dark:text-muted" %>
                   <%= f.text_field :rir, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:text-whiteish" %>
                </div>
                 <div>
                   <%= f.label :rest_seconds, "Rest (sec)", class: "block mb-2 text-xs font-medium text-graphite dark:text-muted" %>
                   <%= f.number_field :rest_seconds, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:text-whiteish" %>
                </div>
             </div>

              <div class="mt-4">
                 <%= f.label :load, "Load / Weight instructions", class: "block mb-2 text-xs font-medium text-graphite dark:text-muted" %>
                 <%= f.text_field :load, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:text-whiteish" %>
              </div>
        </div>

        <%# Instructions %>
        <div class="col-span-2">
          <%= f.label :instructions, "Note / Instructions", class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
          <%= f.text_area :instructions, rows: 3, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>
      </div>

      <%# Footer %>
      <div class="flex items-center justify-end space-x-3 pt-4 border-t border-shadow dark:border-graphite sticky bottom-0 bg-whiteish dark:bg-shadow pb-2">
        <%= link_to "Cancel", admin_routine_exercises_path, class: "text-blackish bg-whiteish border border-shadow focus:ring-4 focus:outline-none focus:ring-primary/20 font-medium rounded-lg text-sm px-5 py-2.5 hover:bg-background-light hover:text-primary focus:z-10 dark:bg-shadow dark:text-muted dark:border-graphite dark:hover:text-whiteish dark:hover:bg-graphite", data: { turbo_frame: "_top" } %>
        <%= f.submit class: "text-blackish bg-primary hover:bg-primary/90 focus:ring-4 focus:outline-none focus:ring-primary/20 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-primary dark:hover:bg-primary/90 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
