<div class="relative overflow-x-auto shadow-md border border-graphite sm:rounded-lg mx-4">
  <table class="w-full text-sm text-left text-graphite dark:text-muted" aria-labelledby="<%= local_assigns[:table_title] || 'page-title' %>">
    <thead class="text-xs text-blackish uppercase border-b border-graphite bg-background-light dark:bg-graphite dark:text-whiteish">
      <tr>
        <th scope="col" class="px-6 py-3 w-full">Rutina</th>
        <th scope="col" class="px-6 py-3 whitespace-nowrap">Workouts</th>
        <th scope="col" class="px-6 py-3 whitespace-nowrap">Duración</th>
        <th scope="col" class="px-6 py-3 text-right"></th>
      </tr>
    </thead>

    <tbody>
      <% resources.each do |resource| %>
        <%
          gender = Routine::GENDERS.find { |g| resource.name.include?(g) }
          focus  = Routine::FOCUSES.find { |f| resource.name.include?(f) }
          level  = Routine::LEVELS.find  { |l| resource.name.include?(l) }
          workouts_count = resource.workouts.size
        %>
        <tr class="bg-whiteish border-b border-shadow dark:bg-shadow dark:border-graphite hover:bg-background-light dark:hover:bg-shadow/50">
          <%# Name + classification tags %>
          <td class="px-6 py-4">
            <% if accessible_action?(resource, :show) %>
              <a href="<%= admin_routine_path(resource) %>" data-turbo="false"
                 class="font-medium text-blackish dark:text-whiteish hover:text-primary dark:hover:text-primary transition-colors">
                <%= resource.name %>
              </a>
            <% else %>
              <span class="font-medium text-blackish dark:text-whiteish"><%= resource.name %></span>
            <% end %>

            <% if gender || focus || level %>
              <div class="flex flex-wrap gap-1 mt-1.5">
                <% if gender %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400"><%= gender %></span>
                <% end %>
                <% if focus %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-primary/15 text-primary"><%= focus %></span>
                <% end %>
                <% if level %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-graphite/15 text-graphite dark:bg-graphite/30 dark:text-muted"><%= level %></span>
                <% end %>
              </div>
            <% end %>
          </td>

          <%# Workouts count %>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="flex items-center gap-1.5 text-graphite dark:text-muted">
              <span class="material-symbols-outlined text-base">fitness_center</span>
              <%= workouts_count %>
            </div>
          </td>

          <%# Duration %>
          <td class="px-6 py-4 whitespace-nowrap">
            <% if resource.duration_weeks.present? %>
              <div class="flex items-center gap-1.5 text-graphite dark:text-muted">
                <span class="material-symbols-outlined text-base">calendar_month</span>
                <%= resource.duration_weeks %> sem.
              </div>
            <% else %>
              <span class="text-graphite dark:text-muted">—</span>
            <% end %>
          </td>

          <%# Actions %>
          <td class="px-6 py-4">
            <div class="flex items-center justify-end gap-1">
              <% if accessible_action?(resource, :show) %>
                <%= link_to admin_routine_path(resource), data: { turbo: false },
                    title: "Ver rutina",
                    class: "p-1.5 rounded text-graphite hover:text-primary dark:text-muted dark:hover:text-primary hover:bg-background-light dark:hover:bg-blackish transition-colors" do %>
                  <span class="material-symbols-outlined text-[18px]">visibility</span>
                <% end %>
              <% end %>

              <% if accessible_action?(resource, :edit) %>
                <%= link_to edit_admin_routine_path(resource), data: { turbo_frame: "modal_frame" },
                    title: "Editar rutina",
                    class: "p-1.5 rounded text-graphite hover:text-primary dark:text-muted dark:hover:text-primary hover:bg-background-light dark:hover:bg-blackish transition-colors" do %>
                  <span class="material-symbols-outlined text-[18px]">edit</span>
                <% end %>
              <% end %>

              <% if accessible_action?(resource, :destroy) %>
                <%= button_to admin_routine_path(resource), method: :delete,
                    title: "Eliminar rutina",
                    data: { turbo_confirm: "¿Seguro que querés eliminar esta rutina?" },
                    class: "p-1.5 rounded text-graphite hover:text-red-500 dark:text-muted dark:hover:text-red-400 hover:bg-background-light dark:hover:bg-blackish transition-colors cursor-pointer bg-transparent border-0" do %>
                  <span class="material-symbols-outlined text-[18px]">delete</span>
                <% end %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
