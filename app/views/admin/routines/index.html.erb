<%# app/views/admin/routines/index.html.erb %>

<%# Header Section %>
<div class="flex flex-col md:flex-row items-center justify-between space-y-3 md:space-y-0 md:space-x-4 p-4">
  <div class="w-full md:w-1/2">
    <form class="flex items-center" action="<%= admin_routines_path %>" method="get">
      <% params.slice(:gender, :focus, :level).each do |key, val| %>
        <input type="hidden" name="<%= key %>" value="<%= val %>">
      <% end %>
      <label for="search" class="sr-only">Search</label>
      <div class="relative w-full">
        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
          <svg aria-hidden="true" class="w-5 h-5 text-graphite dark:text-muted" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
          </svg>
        </div>
        <input type="text" name="search" id="search" autocomplete="off" value="<%= params[:search] %>" class="bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full pl-10 p-2 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish dark:focus:ring-primary dark:focus:border-primary" placeholder="Buscar rutina...">
      </div>
    </form>
  </div>
  <div class="w-full md:w-auto flex flex-col md:flex-row space-y-2 md:space-y-0 items-stretch md:items-center justify-end md:space-x-3 flex-shrink-0">
    <%= link_to new_admin_routine_path, data: { turbo_frame: "modal_frame" }, class: "flex items-center justify-center text-blackish bg-primary hover:bg-primary/90 focus:ring-4 focus:ring-primary/20 font-medium rounded-lg text-sm px-4 py-2 dark:bg-primary dark:hover:bg-primary/90 focus:outline-none dark:focus:ring-primary/20" do %>
      <svg class="h-3.5 w-3.5 mr-2" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path clip-rule="evenodd" fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" />
      </svg>
      Add Routine
    <% end %>
  </div>
</div>

<%# Filters %>
<div class="px-4 pb-4">
  <div class="bg-whiteish dark:bg-shadow p-4 rounded-lg border border-shadow dark:border-graphite shadow-sm">
    <%= form_with url: admin_routines_path, method: :get, class: "flex flex-wrap items-end gap-4" do |f| %>
      <%= f.hidden_field :search, value: params[:search] if params[:search].present? %>

      <div class="flex flex-col space-y-1">
        <%= f.label :gender, "Género", class: "text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider" %>
        <%= f.select :gender, options_for_select(Routine::GENDERS.map { |g| [g, g] }, params[:gender]),
            { include_blank: "Todos" },
            class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-40 p-2.5 dark:bg-graphite dark:border-graphite dark:text-whiteish" %>
      </div>

      <div class="flex flex-col space-y-1">
        <%= f.label :focus, "Objetivo", class: "text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider" %>
        <%= f.select :focus, options_for_select(Routine::FOCUSES.map { |v| [v, v] }, params[:focus]),
            { include_blank: "Todos" },
            class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-40 p-2.5 dark:bg-graphite dark:border-graphite dark:text-whiteish" %>
      </div>

      <div class="flex flex-col space-y-1">
        <%= f.label :level, "Nivel", class: "text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider" %>
        <%= f.select :level, options_for_select(Routine::LEVELS.map { |v| [v, v] }, params[:level]),
            { include_blank: "Todos" },
            class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-44 p-2.5 dark:bg-graphite dark:border-graphite dark:text-whiteish" %>
      </div>

      <div class="flex gap-2">
        <%= f.submit "Filtrar", class: "cursor-pointer text-whiteish bg-primary hover:bg-primary/90 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-primary dark:hover:bg-primary/90 focus:outline-none transition-colors" %>
        <%= link_to "Limpiar", admin_routines_path, class: "flex items-center justify-center text-graphite bg-whiteish border border-shadow hover:bg-background-light font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-shadow dark:text-whiteish dark:border-graphite dark:hover:bg-graphite transition-colors" %>
      </div>

      <% if params[:gender].present? || params[:focus].present? || params[:level].present? %>
        <span class="text-xs text-primary font-semibold self-end pb-2.5"><%= resources.total_count %> rutina<%= resources.total_count == 1 ? "" : "s" %></span>
      <% end %>
    <% end %>
  </div>
</div>

<%# Table Section %>
<%= render(
  "collection",
  collection_presenter: page,
  collection_field_name: resource_name,
  page: page,
  resources: resources,
  table_title: "page-title"
) %>

<%# Pagination %>
  <div class="p-4">
    <%= paginate resources, total_count: resources.total_count %>
  </div>

<%= turbo_frame_tag "modal_frame" %>
