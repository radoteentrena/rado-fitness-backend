<div class="max-w-7xl mx-auto">
  <!-- Routine Header -->
  <div class="mb-8 p-6 bg-whiteish dark:bg-shadow border border-shadow dark:border-graphite rounded-xl shadow-md">
    <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold text-blackish dark:text-whiteish mb-2"><%= @routine.name %></h1>
        <p class="text-lg text-graphite dark:text-muted mb-4 max-w-2xl"><%= @routine.description %></p>

        <div class="flex flex-wrap items-center gap-4 text-sm">
           <span class="px-3 py-1 rounded-full bg-primary/10 text-primary font-medium flex items-center gap-1">
             <span class="material-symbols-outlined text-sm">calendar_today</span>
             Duration: <%= @routine.duration_weeks || 4 %> Weeks
           </span>
           <% if @routine.is_template? %>
             <span class="px-3 py-1 rounded-full bg-secondary/10 text-secondary font-medium flex items-center gap-1">
               <span class="material-symbols-outlined text-sm">content_copy</span>
               Template
             </span>
           <% end %>
           <span class="px-3 py-1 rounded-full bg-background-light dark:bg-graphite text-graphite dark:text-muted font-medium flex items-center gap-1">
             <span class="material-symbols-outlined text-sm">fitness_center</span>
             <%= @routine.routine_exercises.count %> Exercises
           </span>
        </div>
      </div>
      <div class="flex items-center gap-2">
         <%= link_to "Edit Routine", edit_admin_routine_path(@routine), class: "px-4 py-2 bg-primary text-blackish font-bold rounded-lg hover:bg-primary/90 transition-colors" if accessible_action?(@routine, :edit) %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
     <!-- Main Content: Exercises -->
     <div class="lg:col-span-2 space-y-6">
        <% @routine.routine_exercises.order(:order_index).each do |re| %>
           <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite overflow-hidden group hover:border-primary/50 transition-colors">
              <div class="p-4 border-b border-shadow dark:border-graphite flex justify-between items-start bg-background-light dark:bg-shadow/50">
                 <div>
                    <h3 class="text-lg font-bold text-blackish dark:text-whiteish flex items-center gap-2">
                       <div class="w-8 h-8 rounded-full bg-primary text-blackish font-bold flex items-center justify-center text-sm">
                         <%= re.order_index || "-" %>
                       </div>
                       <%= re.exercise.name %>
                       <% if re.warmup? %>
                         <span class="text-xs px-2 py-0.5 rounded bg-orange-100 text-orange-800 dark:bg-orange-900 dark:text-orange-200 uppercase tracking-wide font-bold">Warmup</span>
                       <% end %>
                    </h3>
                    <p class="text-xs text-muted mt-1 ml-10"><%= re.exercise.muscle_group %></p>
                 </div>
                 <div class="text-right">
                    <% if re.time_estimate.present? %>
                       <div class="text-xs font-semibold text-graphite dark:text-muted flex items-center justify-end gap-1 bg-whiteish dark:bg-graphite px-2 py-1 rounded border border-shadow dark:border-graphite shadow-sm">
                          <span class="material-symbols-outlined text-sm">schedule</span>
                          <%= re.time_estimate %>
                       </div>
                    <% end %>
                 </div>
              </div>

              <div class="p-4">
                 <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
                    <div class="p-3 rounded-lg bg-background-light dark:bg-graphite/50 border border-transparent group-hover:bg-whiteish dark:group-hover:bg-graphite transition-colors">
                       <span class="block text-xs uppercase text-muted mb-1 font-bold tracking-wider">Sets x Reps</span>
                       <span class="font-bold text-blackish dark:text-whiteish text-lg">
                         <%= re.sets %> x <%= re.reps %>
                       </span>
                       <% if re.warmup_sets.present? %>
                         <div class="text-xs text-muted mt-1">(+<%= re.warmup_sets %> warmup)</div>
                       <% end %>
                    </div>
                    <div class="p-3 rounded-lg bg-background-light dark:bg-graphite/50 border border-transparent group-hover:bg-whiteish dark:group-hover:bg-graphite transition-colors">
                       <span class="block text-xs uppercase text-muted mb-1 font-bold tracking-wider">RPE Target</span>
                       <span class="font-bold text-blackish dark:text-whiteish text-lg flex items-center gap-1">
                         <%= re.early_rpe || "?" %> <span class="text-muted text-xs">to</span> <%= re.last_rpe || "?" %>
                       </span>
                    </div>
                    <div class="p-3 rounded-lg bg-background-light dark:bg-graphite/50 border border-transparent group-hover:bg-whiteish dark:group-hover:bg-graphite transition-colors">
                       <span class="block text-xs uppercase text-muted mb-1 font-bold tracking-wider">Rest</span>
                       <span class="font-bold text-blackish dark:text-whiteish text-lg">
                         <%= re.rest_seconds %>s
                       </span>
                    </div>
                     <div class="p-3 rounded-lg bg-background-light dark:bg-graphite/50 border border-transparent group-hover:bg-whiteish dark:group-hover:bg-graphite transition-colors">
                       <span class="block text-xs uppercase text-muted mb-1 font-bold tracking-wider">Load</span>
                       <span class="font-bold text-blackish dark:text-whiteish text-lg truncate" title="<%= re.load %>">
                         <%= re.load.presence || "Bodyweight" %>
                       </span>
                    </div>
                 </div>

                 <% if re.instructions.present? %>
                   <div class="mt-4 text-sm text-graphite dark:text-muted border-t border-shadow dark:border-graphite pt-3 flex gap-2">
                      <span class="material-symbols-outlined text-primary text-base mt-0.5">tips_and_updates</span>
                      <div>
                        <strong class="block mb-1 text-xs uppercase tracking-wider text-primary">Coach Instructions</strong>
                        <%= re.instructions %>
                      </div>
                   </div>
                 <% end %>

                 <% if re.substitutions.present? %>
                    <div class="mt-3 text-xs text-muted border-t border-shadow dark:border-graphite pt-2">
                       <span class="font-bold">Substitutions:</span>
                       <% if re.substitutions.is_a?(Array) %>
                          <%= re.substitutions.join(", ") %>
                       <% else %>
                          <%= re.substitutions %>
                       <% end %>
                    </div>
                 <% end %>
              </div>
           </div>
        <% end %>
     </div>

     <!-- Sidebar: Info Cards -->
     <div class="space-y-6">
        <!-- Overview Card -->
        <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm p-6 border border-shadow dark:border-graphite">
           <h3 class="font-bold text-blackish dark:text-whiteish mb-4 flex items-center gap-2">
             <span class="material-symbols-outlined text-primary">info</span>
             Program Guide
           </h3>
           <div class="text-sm text-graphite dark:text-muted space-y-3">
              <p>RPE (Rate of Perceived Exertion) scales from 1-10.</p>
              <ul class="list-disc pl-4 space-y-1 marker:text-primary">
                 <li><strong>RPE 7:</strong> 3 reps in reserve.</li>
                 <li><strong>RPE 8:</strong> 2 reps in reserve.</li>
                 <li><strong>RPE 9:</strong> 1 rep in reserve.</li>
                 <li><strong>RPE 10:</strong> Max effort.</li>
              </ul>
           </div>
        </div>

        <!-- Progress Card -->
         <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm p-6 border border-shadow dark:border-graphite">
           <h3 class="font-bold text-blackish dark:text-whiteish mb-4 flex items-center gap-2">
             <span class="material-symbols-outlined text-secondary">trending_up</span>
             Phase Focus
           </h3>

           <div class="space-y-4">
              <div class="flex items-center justify-between text-sm">
                 <span class="text-muted">Total Volume</span>
                 <span class="font-bold text-blackish dark:text-whiteish">High</span>
              </div>
               <div class="flex items-center justify-between text-sm">
                 <span class="text-muted">Intensity</span>
                 <span class="font-bold text-blackish dark:text-whiteish">Moderate</span>
              </div>

              <div class="pt-4 border-t border-shadow dark:border-graphite">
                  <h4 class="text-xs font-bold uppercase tracking-wider text-muted mb-2">Suggested Rest Days</h4>
                  <div class="flex gap-2">
                     <span class="px-2 py-1 bg-background-light dark:bg-graphite rounded text-xs font-bold">Wed</span>
                     <span class="px-2 py-1 bg-background-light dark:bg-graphite rounded text-xs font-bold">Sun</span>
                  </div>
              </div>
           </div>
        </div>

     </div>
  </div>
</div>
