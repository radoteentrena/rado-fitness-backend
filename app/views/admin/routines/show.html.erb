<%# app/views/admin/routines/show.html.erb %>
<% routine = page.resource %>

<div class="space-y-6">
  <%# Header with Back and Edit %>
  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-4">
      <%= link_to admin_routines_path, class: "p-2 text-graphite bg-whiteish rounded-lg border border-shadow hover:bg-background-light hover:text-blackish dark:bg-shadow dark:border-graphite dark:text-muted dark:hover:bg-shadow/50 dark:hover:text-whiteish" do %>
         <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5H1m0 0 4 4M1 5l4-4"/>
         </svg>
         <span class="sr-only">Back</span>
      <% end %>
      <h1 class="text-2xl font-bold tracking-tight text-blackish dark:text-whiteish">
        <%= routine.name %>
      </h1>
      <% if routine.is_template %>
        <span class="bg-primary/20 text-primary text-xs font-medium px-2.5 py-0.5 rounded border border-primary/20">Template</span>
      <% end %>
    </div>

    <div class="flex space-x-3">
        <%= link_to "Edit Routine", edit_admin_routine_path(routine), data: { turbo_frame: "modal_frame" }, class: "text-blackish bg-primary hover:bg-primary/90 focus:ring-4 focus:ring-primary/20 font-medium rounded-lg text-sm px-4 py-2 dark:bg-primary dark:hover:bg-primary/90 focus:outline-none dark:focus:ring-primary/20" %>
    </div>
  </div>

  <%# Main Content Grid %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <%# Left Column: Key Stats %>
    <div class="lg:col-span-1 space-y-6">
      <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
         <h5 class="mb-4 text-xl font-medium text-blackish dark:text-whiteish border-b border-shadow dark:border-graphite pb-2">Details</h5>

         <div class="space-y-4">
             <div class="flex justify-between items-center py-2 border-b border-shadow dark:border-graphite last:border-0">
                <span class="text-sm font-medium text-graphite dark:text-muted">Duration</span>
                <span class="text-sm font-bold text-blackish dark:text-whiteish"><%= routine.duration_weeks %> Weeks</span>
             </div>

             <div class="flex justify-between items-center py-2 border-b border-shadow dark:border-graphite last:border-0">
                <span class="text-sm font-medium text-graphite dark:text-muted">Program</span>
                 <% if routine.program %>
                    <%= link_to routine.program.name, admin_program_path(routine.program), class: "text-sm font-bold text-primary hover:underline" %>
                <% else %>
                    <span class="text-sm font-bold text-graphite dark:text-muted">–</span>
                <% end %>
             </div>

             <div class="flex justify-between items-center py-2 border-b border-shadow dark:border-graphite last:border-0">
                <span class="text-sm font-medium text-graphite dark:text-muted">Assigned To</span>
                <% if routine.user %>
                    <%= link_to routine.user.name, admin_user_path(routine.user), class: "text-sm font-bold text-primary hover:underline" %>
                <% else %>
                    <span class="text-sm font-bold text-graphite dark:text-muted">Unassigned</span>
                <% end %>
             </div>
         </div>
      </div>
    </div>

    <%# Right Column: Description & Exercises %>
    <div class="lg:col-span-2 space-y-6">
        <%# Description %>
        <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
            <h3 class="text-lg font-bold text-blackish dark:text-whiteish mb-2">Description</h3>
            <p class="text-graphite dark:text-muted text-base leading-relaxed">
                <%= routine.description.presence || "No description provided." %>
            </p>
        </div>

        <%# Exercises List %>
         <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold text-blackish dark:text-whiteish">Exercises</h3>
                <span class="bg-background-light text-graphite text-xs font-medium px-2.5 py-0.5 rounded dark:bg-graphite dark:text-muted border border-shadow dark:border-graphite">
                    <%= routine.routine_exercises.count %>
                </span>
            </div>

            <% if routine.routine_exercises.any? %>
                <ul class="divide-y divide-shadow dark:divide-graphite">
                    <% routine.routine_exercises.includes(:exercise).each do |routine_exercise| %>
                        <li class="py-3 sm:py-4">
                            <div class="flex items-center space-x-4">
                                <%# Display order/day if available? For now just list them %>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-medium text-blackish truncate dark:text-whiteish">
                                        <%= link_to routine_exercise.exercise.name, admin_exercise_path(routine_exercise.exercise), class: "hover:text-primary transition-colors" %>
                                    </p>
                                    <p class="text-xs text-graphite truncate dark:text-muted">
                                        <%= routine_exercise.exercise.muscle_group %>
                                    </p>
                                </div>
                                <div class="inline-flex items-center text-sm font-semibold text-graphite dark:text-muted">
                                    <%# Maybe show sets/reps if available in future %>
                                    <%# routine_exercise.sets %> x <%# routine_exercise.reps %>
                                </div>
                            </div>
                        </li>
                    <% end %>
                </ul>
            <% else %>
                <div class="text-center py-4">
                    <p class="text-sm text-graphite dark:text-muted italic mb-2">No exercises added to this routine yet.</p>
                    <%# Future: Add quick link to add exercises %>
                </div>
            <% end %>
        </div>

    </div>
  </div>
</div>

<%= turbo_frame_tag "modal_frame" %>
