<% if @program %><div data-controller="program-chat"><% else %><div><% end %>
<div class="max-w-7xl mx-auto">
  <!-- Routine Header -->
  <div class="mb-8 p-6 bg-whiteish dark:bg-shadow border border-shadow dark:border-graphite rounded-xl shadow-md">
    <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-blackish dark:text-whiteish mb-2"><%= @routine.name %></h1>
        <p class="text-lg text-graphite dark:text-muted mb-4 max-w-2xl"><%= @routine.description %></p>

        <div class="flex flex-wrap items-center gap-4 text-sm">
           <span class="px-3 py-1 rounded-full bg-primary/10 text-primary font-medium flex items-center gap-1">
             <span class="material-symbols-outlined text-sm">calendar_today</span>
             Duration: <%= @routine.duration_weeks || 4 %> Weeks
           </span>
           <% if @routine.is_template? %>
             <span class="px-3 py-1 rounded-full bg-graphite/10 text-graphite dark:bg-muted/10 dark:text-muted font-medium flex items-center gap-1">
               <span class="material-symbols-outlined text-sm">content_copy</span>
               Template
             </span>
           <% end %>
           <span class="px-3 py-1 rounded-full bg-background-light dark:bg-graphite text-graphite dark:text-muted font-medium flex items-center gap-1">
             <span class="material-symbols-outlined text-sm">view_agenda</span>
             <%= @routine.workouts.count %> Days
           </span>
        </div>
      </div>
      <div class="flex items-center gap-2">
         <%= link_to new_admin_routine_workout_path(@routine),
               class: "p-2 bg-saffron text-blackish rounded-lg hover:bg-blackish transition-colors hover:text-saffron",
               title: "Add Workout Day" do %>
           <span class="material-symbols-outlined text-xl">add</span>
         <% end %>
         <% if accessible_action?(@routine, :edit) %>
           <%= link_to edit_admin_routine_path(@routine),
                 class: "p-2 bg-primary text-blackish rounded-lg hover:bg-blackish transition-colors hover:text-saffron",
                 title: "Edit Routine" do %>
             <span class="material-symbols-outlined text-xl">edit</span>
           <% end %>
         <% end %>
         <% if @program %>
           <button data-action="program-chat#open"
                   class="p-2 border-2 hover:cursor-pointer rounded-lg border-primary text-primary hover:bg-primary hover:text-blackish transition-all"
                   title="Chat con AI Coach">
             <span class="material-symbols-outlined text-xl">smart_toy</span>
           </button>
         <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
     <!-- Main Content: Exercises -->
     <div class="lg:col-span-2 space-y-6">
         <%= turbo_frame_tag "workout_content" do %>
           <% if @selected_workout %>
            <% workout = @selected_workout %>
            <div class="mb-8 p-6 bg-background-light dark:bg-blackish border border-shadow dark:border-graphite rounded-xl">
               <div class="flex items-center justify-between mb-6 border-b border-shadow dark:border-graphite pb-4">
                 <div>
                   <h2 class="text-2xl font-black uppercase tracking-tight text-blackish dark:text-whiteish"><%= workout.name %></h2>
                   <% if workout.description.present? %>
                     <p class="text-graphite dark:text-muted mt-1 max-w-xl"><%= workout.description %></p>
                   <% end %>
                 </div>
                 <div class="flex items-center gap-2">
                   <%= link_to "Edit Day", edit_admin_workout_path(workout), data: { turbo: false }, class: "px-3 py-1.5 text-sm bg-graphite text-whiteish font-medium rounded hover:bg-shadow transition-colors" %>
                   <%= button_to "Delete", admin_workout_path(workout), method: :delete, class: "px-3 py-1.5 text-sm border border-red-500/30 text-red-500 hover:bg-red-500 hover:text-white font-bold rounded transition-colors", form: { data: { turbo_confirm: "Are you sure?", turbo: false } } %>
                 </div>
               </div>

               <div class="space-y-6">
                  <% workout.workout_exercises.order(:order_index).each do |we| %>
                     <%= render partial: "admin/workout_exercises/workout_exercise", locals: { workout_exercise: we, allow_actions: !@routine.is_template? } %>
                  <% end %>

                  <div class="mt-4 flex justify-center border-2 border-dashed border-shadow dark:border-graphite rounded-lg p-4 hover:border-primary transition-colors">
                    <%= link_to new_admin_workout_workout_exercise_path(workout), data: { turbo_frame: "_top" }, class: "text-graphite dark:text-muted hover:text-primary font-medium flex items-center gap-2" do %>
                      <span class="material-symbols-outlined">add_circle</span>
                      Add Exercise
                    <% end %>
                  </div>
               </div>
            </div>
           <% else %>
             <div class="text-center py-12 p-6 border-2 border-dashed border-shadow dark:border-graphite rounded-xl mb-8">
               <span class="material-symbols-outlined text-4xl text-graphite mb-2">fitness_center</span>
               <h3 class="text-lg font-medium text-blackish dark:text-whiteish mb-1">No workout days yet</h3>
               <p class="text-sm text-graphite dark:text-muted">Add a workout day to get started.</p>
             </div>
           <% end %>
         <% end %>
     </div>

     <!-- Sidebar: Info Cards -->
     <div class="space-y-6">
        <%
          all_workout_exercises = @routine.workouts.includes(workout_exercises: :exercise).flat_map(&:workout_exercises)
          total_exercises = all_workout_exercises.count
          muscle_group_counts = all_workout_exercises
            .map { |we| we.exercise&.muscle_group.presence || "Sin grupo" }
            .tally
            .sort_by { |_, count| -count }
        %>

        <!-- Muscle Group Breakdown Card -->
        <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm p-6 border border-shadow dark:border-graphite">
           <h3 class="font-bold text-blackish dark:text-whiteish mb-1 flex items-center gap-2">
             <span class="material-symbols-outlined text-primary">fitness_center</span>
             Grupos Musculares
           </h3>
           <p class="text-xs text-muted mb-4"><%= total_exercises %> ejercicios · <%= @routine.workouts.count %> días</p>

           <% if muscle_group_counts.any? %>
             <ul class="space-y-3">
               <% muscle_group_counts.each do |group, count| %>
                 <% percentage = total_exercises > 0 ? (count.to_f / total_exercises * 100).round : 0 %>
                 <li>
                   <div class="flex items-center justify-between text-sm mb-1">
                     <span class="font-medium text-blackish dark:text-whiteish"><%= group %></span>
                     <span class="text-xs text-muted"><%= count %> (<%= percentage %>%)</span>
                   </div>
                   <div class="w-full bg-background-light dark:bg-graphite rounded-full h-1.5">
                     <div class="bg-primary h-1.5 rounded-full" style="width: <%= percentage %>%"></div>
                   </div>
                 </li>
               <% end %>
             </ul>
           <% else %>
             <p class="text-sm text-muted italic">Sin ejercicios aún.</p>
           <% end %>
        </div>
     </div>
  </div>
</div>

<% if @program %>
  <div data-program-chat-target="panel"
       class="fixed right-0 top-0 h-full w-96 z-50 bg-blackish border-l-2 border-primary/50 transform transition-transform duration-300 translate-x-full flex flex-col">

    <div class="flex items-center justify-between px-4 py-3 border-b border-primary/30 shrink-0">
      <h2 class="text-sm font-bold text-whiteish uppercase tracking-wider">AI Coach Chat</h2>
      <button data-action="program-chat#close"
              class="text-muted hover:text-whiteish transition-colors p-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <turbo-frame id="program-chat-panel"
                 data-program-chat-target="frame"
                 data-chat-url="<%= admin_program_chat_path(@program, routine_id: @routine.id, workout_id: @selected_workout&.id) %>"
                 class="flex flex-col flex-1 min-h-0">
      <div class="flex items-center justify-center h-full text-muted text-sm">
        Cargando chat...
      </div>
    </turbo-frame>
  </div>
<% end %>

</div>

<%= turbo_frame_tag "modal_frame" %>
