<div class="max-w-7xl mx-auto">
  <!-- Routine Header -->
  <div class="mb-8 p-6 bg-whiteish dark:bg-shadow border border-shadow dark:border-graphite rounded-xl shadow-md">
    <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold text-blackish dark:text-whiteish mb-2"><%= @routine.name %></h1>
        <p class="text-lg text-graphite dark:text-muted mb-4 max-w-2xl"><%= @routine.description %></p>

        <div class="flex flex-wrap items-center gap-4 text-sm">
           <span class="px-3 py-1 rounded-full bg-primary/10 text-primary font-medium flex items-center gap-1">
             <span class="material-symbols-outlined text-sm">calendar_today</span>
             Duration: <%= @routine.duration_weeks || 4 %> Weeks
           </span>
           <% if @routine.is_template? %>
             <span class="px-3 py-1 rounded-full bg-secondary/10 text-secondary font-medium flex items-center gap-1">
               <span class="material-symbols-outlined text-sm">content_copy</span>
               Template
             </span>
           <% end %>
           <span class="px-3 py-1 rounded-full bg-background-light dark:bg-graphite text-graphite dark:text-muted font-medium flex items-center gap-1">
             <span class="material-symbols-outlined text-sm">fitness_center</span>
             <%= @routine.routine_exercises.count %> Exercises
           </span>
        </div>
      </div>
      <div class="flex items-center gap-2">
         <%= link_to "Edit Routine", edit_admin_routine_path(@routine), class: "px-4 py-2 bg-primary text-blackish font-bold rounded-lg hover:bg-primary/90 transition-colors" if accessible_action?(@routine, :edit) %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
     <!-- Main Content: Exercises -->
     <div class="lg:col-span-2 space-y-6">
         <% grouped_exercises = @routine.routine_exercises.order(:day_number, :order_index).group_by { |re| re.day_name.presence || "Day #{re.day_number || '?'}" } %>
         <% grouped_exercises.sort_by { |day_string, _| day_string.scan(/\d+/).first.to_i }.each do |day, exercises| %>
            <div class="mb-8">
               <h2 class="text-xl font-bold text-blackish dark:text-whiteish mb-4 border-b border-shadow dark:border-graphite pb-2"><%= day %></h2>
               <div class="space-y-6">
                  <% exercises.each do |re| %>
                     <%= render partial: "admin/routine_exercises/routine_exercise", locals: { routine_exercise: re } %>
                  <% end %>
               </div>
            </div>
         <% end %>
     </div>

     <!-- Sidebar: Info Cards -->
     <div class="space-y-6">
        <!-- Overview Card -->
        <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm p-6 border border-shadow dark:border-graphite">
           <h3 class="font-bold text-blackish dark:text-whiteish mb-4 flex items-center gap-2">
             <span class="material-symbols-outlined text-primary">info</span>
             Program Guide
           </h3>
           <div class="text-sm text-graphite dark:text-muted space-y-3">
              <p>RPE (Rate of Perceived Exertion) scales from 1-10.</p>
              <ul class="list-disc pl-4 space-y-1 marker:text-primary">
                 <li><strong>RPE 7:</strong> 3 reps in reserve.</li>
                 <li><strong>RPE 8:</strong> 2 reps in reserve.</li>
                 <li><strong>RPE 9:</strong> 1 rep in reserve.</li>
                 <li><strong>RPE 10:</strong> Max effort.</li>
              </ul>
           </div>
        </div>

        <!-- Progress Card -->
         <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm p-6 border border-shadow dark:border-graphite">
           <h3 class="font-bold text-blackish dark:text-whiteish mb-4 flex items-center gap-2">
             <span class="material-symbols-outlined text-secondary">trending_up</span>
             Phase Focus
           </h3>

           <div class="space-y-4">
              <div class="flex items-center justify-between text-sm">
                 <span class="text-muted">Total Volume</span>
                 <span class="font-bold text-blackish dark:text-whiteish">High</span>
              </div>
               <div class="flex items-center justify-between text-sm">
                 <span class="text-muted">Intensity</span>
                 <span class="font-bold text-blackish dark:text-whiteish">Moderate</span>
              </div>

              <div class="pt-4 border-t border-shadow dark:border-graphite">
                  <h4 class="text-xs font-bold uppercase tracking-wider text-muted mb-2">Suggested Rest Days</h4>
                  <div class="flex gap-2">
                     <span class="px-2 py-1 bg-background-light dark:bg-graphite rounded text-xs font-bold">Wed</span>
                     <span class="px-2 py-1 bg-background-light dark:bg-graphite rounded text-xs font-bold">Sun</span>
                  </div>
              </div>
           </div>
        </div>

     </div>
  </div>
</div>
