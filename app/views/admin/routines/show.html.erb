<div class="max-w-7xl mx-auto">
  <!-- Routine Header -->
  <div class="mb-8 p-6 bg-whiteish dark:bg-shadow border border-shadow dark:border-graphite rounded-xl shadow-md">
    <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-blackish dark:text-whiteish mb-2"><%= @routine.name %></h1>
        <p class="text-lg text-graphite dark:text-muted mb-4 max-w-2xl"><%= @routine.description %></p>

        <div class="flex flex-wrap items-center gap-4 text-sm">
           <span class="px-3 py-1 rounded-full bg-primary/10 text-primary font-medium flex items-center gap-1">
             <span class="material-symbols-outlined text-sm">calendar_today</span>
             Duration: <%= @routine.duration_weeks || 4 %> Weeks
           </span>
           <% if @routine.is_template? %>
             <span class="px-3 py-1 rounded-full bg-graphite/10 text-graphite dark:bg-muted/10 dark:text-muted font-medium flex items-center gap-1">
               <span class="material-symbols-outlined text-sm">content_copy</span>
               Template
             </span>
           <% end %>
           <span class="px-3 py-1 rounded-full bg-background-light dark:bg-graphite text-graphite dark:text-muted font-medium flex items-center gap-1">
             <span class="material-symbols-outlined text-sm">view_agenda</span>
             <%= @routine.workouts.count %> Days
           </span>
        </div>
      </div>
      <div class="flex items-center gap-2">
         <%= link_to "Add Workout Day", new_admin_routine_workout_path(@routine), class: "px-4 py-2 bg-saffron text-blackish font-bold rounded-lg hover:bg-saffron-dark transition-colors" %>
         <%= link_to "Edit Routine", edit_admin_routine_path(@routine), class: "px-4 py-2 bg-primary text-blackish font-bold rounded-lg hover:bg-primary/90 transition-colors" if accessible_action?(@routine, :edit) %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
     <!-- Main Content: Exercises -->
     <div class="lg:col-span-2 space-y-6">
         <%= turbo_frame_tag "workout_content" do %>
           <% if @selected_workout %>
            <% workout = @selected_workout %>
            <div class="mb-8 p-6 bg-background-light dark:bg-blackish border border-shadow dark:border-graphite rounded-xl">
               <div class="flex items-center justify-between mb-6 border-b border-shadow dark:border-graphite pb-4">
                 <div>
                   <h2 class="text-2xl font-black uppercase tracking-tight text-blackish dark:text-whiteish"><%= workout.name %></h2>
                   <% if workout.description.present? %>
                     <p class="text-graphite dark:text-muted mt-1 max-w-xl"><%= workout.description %></p>
                   <% end %>
                 </div>
                 <div class="flex items-center gap-2">
                   <%= link_to "Edit Day", edit_admin_workout_path(workout), data: { turbo: false }, class: "px-3 py-1.5 text-sm bg-graphite text-whiteish font-medium rounded hover:bg-shadow transition-colors" %>
                   <%= button_to "Delete", admin_workout_path(workout), method: :delete, class: "px-3 py-1.5 text-sm border border-red-500/30 text-red-500 hover:bg-red-500 hover:text-white font-bold rounded transition-colors", form: { data: { turbo_confirm: "Are you sure?", turbo: false } } %>
                 </div>
               </div>

               <div class="space-y-6">
                  <% workout.workout_exercises.order(:order_index).each do |we| %>
                     <%= render partial: "admin/workout_exercises/workout_exercise", locals: { workout_exercise: we } %>
                  <% end %>

                  <div class="mt-4 flex justify-center border-2 border-dashed border-shadow dark:border-graphite rounded-lg p-4 hover:border-primary transition-colors">
                    <%= link_to new_admin_workout_workout_exercise_path(workout), data: { turbo_frame: "_top" }, class: "text-graphite dark:text-muted hover:text-primary font-medium flex items-center gap-2" do %>
                      <span class="material-symbols-outlined">add_circle</span>
                      Add Exercise
                    <% end %>
                  </div>
               </div>
            </div>
           <% else %>
             <div class="text-center py-12 p-6 border-2 border-dashed border-shadow dark:border-graphite rounded-xl mb-8">
               <span class="material-symbols-outlined text-4xl text-graphite mb-2">fitness_center</span>
               <h3 class="text-lg font-medium text-blackish dark:text-whiteish mb-1">No workout days yet</h3>
               <p class="text-sm text-graphite dark:text-muted">Add a workout day to get started.</p>
             </div>
           <% end %>
         <% end %>
     </div>

     <!-- Sidebar: Info Cards -->
     <div class="space-y-6">
        <!-- Overview Card -->
        <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm p-6 border border-shadow dark:border-graphite">
           <h3 class="font-bold text-blackish dark:text-whiteish mb-4 flex items-center gap-2">
             <span class="material-symbols-outlined text-primary">info</span>
             Program Guide
           </h3>
           <div class="text-sm text-graphite dark:text-muted space-y-3">
              <p>RPE (Rate of Perceived Exertion) scales from 1-10.</p>
              <ul class="list-disc pl-4 space-y-1 marker:text-primary">
                 <li><strong>RPE 7:</strong> 3 reps in reserve.</li>
                 <li><strong>RPE 8:</strong> 2 reps in reserve.</li>
                 <li><strong>RPE 9:</strong> 1 rep in reserve.</li>
                 <li><strong>RPE 10:</strong> Max effort.</li>
              </ul>
           </div>
        </div>

        <!-- Progress Card -->
         <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm p-6 border border-shadow dark:border-graphite">
           <h3 class="font-bold text-blackish dark:text-whiteish mb-4 flex items-center gap-2">
             <span class="material-symbols-outlined text-primary">trending_up</span>
             Phase Focus
           </h3>

           <div class="space-y-4">
              <div class="flex items-center justify-between text-sm">
                 <span class="text-muted">Total Volume</span>
                 <span class="font-bold text-blackish dark:text-whiteish">High</span>
              </div>
               <div class="flex items-center justify-between text-sm">
                 <span class="text-muted">Intensity</span>
                 <span class="font-bold text-blackish dark:text-whiteish">Moderate</span>
              </div>

              <div class="pt-4 border-t border-shadow dark:border-graphite">
                  <h4 class="text-xs font-bold uppercase tracking-wider text-muted mb-2">Suggested Rest Days</h4>
                  <div class="flex gap-2">
                     <span class="px-2 py-1 bg-background-light dark:bg-graphite rounded text-xs font-bold">Wed</span>
                     <span class="px-2 py-1 bg-background-light dark:bg-graphite rounded text-xs font-bold">Sun</span>
                  </div>
              </div>
           </div>
        </div>
     </div>
  </div>
</div>
