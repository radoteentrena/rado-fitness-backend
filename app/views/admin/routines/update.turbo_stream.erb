<%# app/views/admin/routines/update.turbo_stream.erb %>

<%= turbo_stream.update "modal_frame", "" %>

<%= turbo_stream.replace dom_id(requested_resource) do %>
  <%= render partial: "admin/routines/routine_card", object: requested_resource, as: :routine %>
<% end %>

<%= turbo_stream.prepend "flash_messages" do %>
  <div class="p-4 mb-4 text-sm text-green-800 rounded-lg bg-green-50 dark:bg-shadow dark:text-green-400 border border-green-300 dark:border-green-800" role="alert">
    <span class="font-medium">Success!</span> Routine was successfully updated.
  </div>
<% end %>
