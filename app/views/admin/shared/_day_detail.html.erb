<%= turbo_frame_tag "modal_frame" do %>
  <div class="fixed scroll-auto inset-0 z-50 hidden items-center justify-center p-4 bg-blackish/50 backdrop-blur-sm" data-controller="overlay" data-overlay-target="overlay" data-overlay-auto-open-value="true" data-action="click->overlay#closeBackground keyup@window->overlay#closeWithKeyboard">
    <div class="relative w-full max-w-2xl max-h-[90vh] overflow-y-auto scrollbar-hide bg-whiteish dark:bg-shadow rounded-xl shadow-2xl border border-shadow dark:border-graphite">

      <% date = daily_metric&.date_logged || training_session&.completed_at&.to_date %>

      <!-- Header -->
      <div class="flex items-center justify-between p-6 border-b border-shadow dark:border-graphite sticky top-0 bg-whiteish dark:bg-shadow z-10">
        <div>
          <h3 class="text-xl font-bold text-blackish dark:text-whiteish"><%= date&.strftime("%A, %B %d, %Y") %></h3>
          <div class="flex items-center gap-3 mt-0.5">
            <% if daily_metric %>
              <span class="text-xs text-graphite dark:text-muted flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px]">monitor_weight</span> Métricas
              </span>
            <% end %>
            <% if training_session %>
              <span class="text-xs text-graphite dark:text-muted flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px]">fitness_center</span>
                <%= training_session.workout.name %>
              </span>
            <% end %>
          </div>
        </div>
        <button type="button" class="text-graphite dark:text-muted hover:text-blackish dark:hover:text-whiteish transition-colors" data-action="click->overlay#close">
          <span class="material-symbols-outlined text-2xl">close</span>
        </button>
      </div>

      <!-- Content -->
      <div class="p-6 space-y-6">

        <% if daily_metric %>
          <!-- Key Metrics Grid -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-background-light dark:bg-graphite p-4 rounded-lg text-center">
              <p class="text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider mb-1">Calories</p>
              <p class="text-xl font-bold text-blackish dark:text-whiteish"><%= daily_metric.calories_consumed || "-" %></p>
            </div>
            <div class="bg-background-light dark:bg-graphite p-4 rounded-lg text-center">
              <p class="text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider mb-1">Protein</p>
              <p class="text-xl font-bold text-blackish dark:text-whiteish"><%= daily_metric.protein_consumed || "-" %>g</p>
            </div>
            <div class="bg-background-light dark:bg-graphite p-4 rounded-lg text-center">
              <p class="text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider mb-1">Steps</p>
              <p class="text-xl font-bold text-blackish dark:text-whiteish"><%= daily_metric.steps || "-" %></p>
            </div>
            <div class="bg-background-light dark:bg-graphite p-4 rounded-lg text-center">
              <p class="text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider mb-1">Weight</p>
              <p class="text-xl font-bold text-blackish dark:text-whiteish"><%= daily_metric.weight ? number_with_precision(daily_metric.weight, precision: 1) : "-" %>kg</p>
            </div>
          </div>

          <!-- Compliance badges -->
          <div class="flex gap-4">
            <% if daily_metric.compliant %>
              <div class="flex-1 p-3 bg-success/10 border border-success/20 rounded-lg flex items-center justify-center space-x-2 text-success">
                <span class="material-symbols-outlined text-lg">check_circle</span>
                <span class="font-semibold text-sm">Compliant</span>
              </div>
            <% else %>
              <div class="flex-1 p-3 bg-danger/10 border border-danger/20 rounded-lg flex items-center justify-center space-x-2 text-danger">
                <span class="material-symbols-outlined text-lg">cancel</span>
                <span class="font-semibold text-sm">Non-Compliant</span>
              </div>
            <% end %>
            <% if daily_metric.on_target %>
              <div class="flex-1 p-3 bg-primary/10 border border-primary/20 rounded-lg flex items-center justify-center space-x-2 text-primary">
                <span class="material-symbols-outlined text-lg">ads_click</span>
                <span class="font-semibold text-sm">On Target</span>
              </div>
            <% else %>
              <div class="flex-1 p-3 bg-warning/10 border border-warning/20 rounded-lg flex items-center justify-center space-x-2 text-warning">
                <span class="material-symbols-outlined text-lg">warning</span>
                <span class="font-semibold text-sm">Off Target</span>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if training_session %>
          <%
            duration_min = if training_session.started_at && training_session.completed_at
              ((training_session.completed_at - training_session.started_at) / 60).round
            end
            logs_by_we_id = training_session.exercise_logs.index_by(&:workout_exercise_id)
            workout_exercises = training_session.workout.workout_exercises
              .includes(:exercise).order(order_index: :asc)
          %>

          <!-- Training section divider -->
          <div class="flex items-center gap-3 -mx-6 px-6 py-3 border-y border-shadow dark:border-graphite bg-background-light dark:bg-graphite/40">
            <span class="material-symbols-outlined text-primary text-base">fitness_center</span>
            <span class="text-xs font-bold uppercase tracking-widest text-blackish dark:text-whiteish flex-1">
              <%= training_session.workout.name %>
            </span>
            <span class="text-xs text-graphite dark:text-muted"><%= training_session.phase.name %></span>
            <% if duration_min %>
              <span class="text-xs font-bold text-primary tabular-nums"><%= duration_min %>m</span>
            <% end %>
          </div>

          <% if training_session.skipped? %>
            <div class="flex items-center gap-3 p-4 border border-dashed border-graphite/50 dark:border-graphite rounded-lg">
              <span class="material-symbols-outlined text-graphite dark:text-muted text-base">block</span>
              <span class="text-sm text-graphite dark:text-muted">
                Saltada<% if training_session.skip_reason.present? %> — <em><%= training_session.skip_reason %></em><% end %>
              </span>
            </div>

          <% elsif workout_exercises.any? %>
            <div class="space-y-4">
              <% workout_exercises.each do |we| %>
                <% log = logs_by_we_id[we.id] %>
                <% has_log = log && log.actual_sets.present? %>
                <div>
                  <!-- Exercise name + prescribed -->
                  <div class="flex items-baseline justify-between gap-4 mb-2">
                    <span class="text-sm font-bold text-blackish dark:text-whiteish leading-tight"><%= we.exercise.name %></span>
                    <span class="text-[11px] text-graphite dark:text-muted shrink-0">
                      <%= we.sets %>×<%= we.reps %><% if we.load.present? %> &middot; <%= we.load %><% end %>
                    </span>
                  </div>

                  <!-- Set pills -->
                  <% if has_log %>
                    <div class="flex flex-wrap gap-1.5">
                      <% Array(log.actual_sets).each_with_index do |set, i| %>
                        <%
                          rpe = set["rpe"].to_i
                          rpe_color = if rpe >= 9 then "text-alert border-alert/40"
                                      elsif rpe >= 7 then "text-warning border-warning/40"
                                      else "text-graphite dark:text-muted border-shadow dark:border-graphite"
                                      end
                        %>
                        <div class="inline-flex items-center border <%= rpe_color %> bg-background-light dark:bg-graphite px-2.5 py-1.5 gap-2 text-[11px] font-medium">
                          <span class="text-graphite dark:text-muted font-normal tabular-nums"><%= i + 1 %></span>
                          <span class="text-blackish dark:text-whiteish tabular-nums font-bold"><%= set["reps"] %>r</span>
                          <% if set["weight"].present? && set["weight"].to_f > 0 %>
                            <span class="text-graphite dark:text-muted">·</span>
                            <span class="text-blackish dark:text-whiteish tabular-nums"><%= set["weight"] %>kg</span>
                          <% end %>
                          <% if set["rpe"].present? %>
                            <span class="font-bold tabular-nums <%= rpe >= 9 ? "text-alert" : rpe >= 7 ? "text-warning" : "text-graphite dark:text-muted" %>">
                              <%= set["rpe"] %>
                            </span>
                          <% end %>
                        </div>
                      <% end %>
                    </div>
                  <% else %>
                    <div class="flex items-center gap-2 py-1">
                      <div class="h-px flex-1 border-t border-dashed border-shadow dark:border-graphite/50"></div>
                      <span class="text-[11px] text-graphite dark:text-muted uppercase tracking-wider">Sin registro</span>
                      <div class="h-px flex-1 border-t border-dashed border-shadow dark:border-graphite/50"></div>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>

            <% if training_session.notes.present? %>
              <div class="flex items-start gap-2 pt-2 border-t border-shadow dark:border-graphite/50">
                <span class="material-symbols-outlined text-[15px] text-graphite dark:text-muted mt-0.5">notes</span>
                <span class="text-xs text-graphite dark:text-muted italic"><%= training_session.notes %></span>
              </div>
            <% end %>
          <% end %>
        <% end %>

      </div>

      <!-- Footer -->
      <div class="bg-background-light dark:bg-graphite p-4 border-t border-shadow dark:border-graphite flex justify-end sticky bottom-0 rounded-b-xl">
        <button type="button" class="px-4 py-2 bg-whiteish dark:bg-shadow border border-shadow dark:border-graphite rounded-lg text-blackish dark:text-whiteish hover:bg-shadow/5 transition-colors text-sm font-medium" data-action="click->overlay#close">
          Close
        </button>
      </div>

    </div>
  </div>
<% end %>
