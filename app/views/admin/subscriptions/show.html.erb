<%
  sub = @resource
  status_classes = {
    "active"   => "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400",
    "pending"  => "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400",
    "past_due" => "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400",
    "canceled" => "bg-background-light text-graphite dark:bg-graphite dark:text-muted"
  }
%>

<%# Header %>
<div class="px-4 pt-6 pb-4 mb-4 border-b border-shadow dark:border-graphite flex items-center justify-between gap-4">
  <div class="flex items-center gap-3">
    <%= link_to admin_subscriptions_path, class: "p-2 text-graphite bg-whiteish rounded-lg border border-shadow hover:bg-background-light hover:text-blackish dark:bg-shadow dark:border-graphite dark:text-muted dark:hover:bg-shadow/50 dark:hover:text-whiteish" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 14 10">
        <path d="M13 5H1m0 0 4 4M1 5l4-4"/>
      </svg>
    <% end %>
    <div>
      <h1 class="text-2xl font-bold text-blackish dark:text-whiteish">
        <%= sub.user.name %> — <%= sub.plan_tier.humanize %>
      </h1>
      <p class="text-sm text-graphite dark:text-muted mt-0.5">
        Subscription #<%= sub.id %> · Created <%= sub.created_at.strftime("%B %d, %Y") %>
      </p>
    </div>
  </div>

  <% unless sub.cancel_at_period_end? || sub.canceled? %>
    <%= button_to admin_subscription_cancellations_path(subscription_id: sub.id),
          method: :post,
          data: { turbo_confirm: "¿Cancelar al vencimiento del período actual?" },
          class: "flex items-center gap-1.5 px-4 py-2 bg-whiteish dark:bg-shadow border border-shadow dark:border-graphite text-graphite dark:text-muted hover:text-blackish dark:hover:text-whiteish font-bold text-sm rounded-lg transition-colors cursor-pointer" do %>
      <span class="material-symbols-outlined text-base">cancel</span>
      Cancel at period end
    <% end %>
  <% end %>
</div>

<%# Main Grid %>
<div class="px-4 pb-4 grid grid-cols-1 lg:grid-cols-3 gap-6">

  <%# Left: Subscription Details %>
  <div class="lg:col-span-2 space-y-6">
    <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
      <h3 class="text-sm font-bold uppercase tracking-wider text-graphite dark:text-muted mb-5">Subscription Details</h3>
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <dt class="text-xs font-medium text-graphite dark:text-muted">Status</dt>
          <dd class="mt-1 flex items-center gap-2">
            <span class="inline-block px-2 py-0.5 text-xs font-bold rounded <%= status_classes[sub.status] || 'bg-graphite text-whiteish' %>">
              <%= sub.status.humanize %>
            </span>
            <% if sub.cancel_at_period_end? %>
              <span class="text-xs text-graphite dark:text-muted">(cancels at period end)</span>
            <% end %>
          </dd>
        </div>

        <div>
          <dt class="text-xs font-medium text-graphite dark:text-muted">Plan</dt>
          <dd class="mt-1 text-sm font-semibold text-blackish dark:text-whiteish"><%= sub.plan_tier.humanize %></dd>
        </div>

        <div>
          <dt class="text-xs font-medium text-graphite dark:text-muted">Amount</dt>
          <dd class="mt-1 text-sm font-semibold text-blackish dark:text-whiteish">
            <%= sub.currency %> <%= number_to_currency(sub.amount_in_dollars, unit: "") %>
          </dd>
        </div>

        <div>
          <dt class="text-xs font-medium text-graphite dark:text-muted">Processor</dt>
          <dd class="mt-1 text-sm font-semibold text-blackish dark:text-whiteish">MercadoPago</dd>
        </div>

        <% if sub.frequency? %>
          <div>
            <dt class="text-xs font-medium text-graphite dark:text-muted">Frequency</dt>
            <dd class="mt-1 text-sm font-semibold text-blackish dark:text-whiteish"><%= sub.frequency.humanize %></dd>
          </div>
        <% end %>

        <% if sub.billing_type? %>
          <div>
            <dt class="text-xs font-medium text-graphite dark:text-muted">Billing Type</dt>
            <dd class="mt-1 text-sm font-semibold text-blackish dark:text-whiteish"><%= sub.billing_type.humanize %></dd>
          </div>
        <% end %>

        <% if sub.current_period_end? %>
          <div>
            <dt class="text-xs font-medium text-graphite dark:text-muted">Next Charge</dt>
            <dd class="mt-1 text-sm font-semibold text-blackish dark:text-whiteish">
              <%= sub.current_period_end.strftime("%d %b %Y") %>
            </dd>
          </div>
        <% end %>

        <% if sub.canceled_at? %>
          <div>
            <dt class="text-xs font-medium text-graphite dark:text-muted">Canceled At</dt>
            <dd class="mt-1 text-sm font-semibold text-blackish dark:text-whiteish">
              <%= sub.canceled_at.strftime("%d %b %Y") %>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>

    <% if sub.external_id? %>
      <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
        <h3 class="text-sm font-bold uppercase tracking-wider text-graphite dark:text-muted mb-3">External Reference</h3>
        <p class="text-sm font-mono text-blackish dark:text-whiteish break-all"><%= sub.external_id %></p>
      </div>
    <% end %>
  </div>

  <%# Right: Client + Timestamps %>
  <div class="space-y-6">
    <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
      <h3 class="text-sm font-bold uppercase tracking-wider text-graphite dark:text-muted mb-4">Client</h3>
      <%= link_to admin_user_path(sub.user), class: "flex items-center gap-3 group" do %>
        <div class="w-12 h-12 rounded-full bg-primary/20 text-primary flex items-center justify-center text-lg font-bold shrink-0">
          <%= sub.user.first_name&.first %><%= sub.user.last_name&.first %>
        </div>
        <div class="min-w-0">
          <p class="font-bold text-blackish dark:text-whiteish group-hover:text-primary transition-colors truncate"><%= sub.user.name %></p>
          <p class="text-xs text-graphite dark:text-muted truncate"><%= sub.user.email %></p>
        </div>
        <span class="material-symbols-outlined text-graphite dark:text-muted ml-auto">chevron_right</span>
      <% end %>
    </div>

    <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
      <h3 class="text-sm font-bold uppercase tracking-wider text-graphite dark:text-muted mb-4">Timestamps</h3>
      <dl class="space-y-4">
        <div>
          <dt class="text-xs font-medium text-graphite dark:text-muted">Created</dt>
          <dd class="mt-1 text-sm font-semibold text-blackish dark:text-whiteish"><%= sub.created_at.strftime("%d %b %Y · %H:%M") %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-graphite dark:text-muted">Last Updated</dt>
          <dd class="mt-1 text-sm font-semibold text-blackish dark:text-whiteish"><%= sub.updated_at.strftime("%d %b %Y · %H:%M") %></dd>
        </div>
      </dl>
    </div>
  </div>

</div>
