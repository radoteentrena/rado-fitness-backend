<div class="fixed inset-0 z-50 flex items-center justify-center bg-blackish/50 backdrop-blur-sm p-4">
  <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto border border-shadow dark:border-graphite">
    <%# Header %>
    <div class="flex items-center justify-between p-4 border-b border-shadow dark:border-graphite bg-background-light dark:bg-graphite sticky top-0 z-10">
      <h3 class="text-lg font-semibold text-blackish dark:text-whiteish">
        <%= resource.persisted? ? "Edit User Plan" : "Assign Dietary Plan" %>
      </h3>
      <%= link_to admin_user_dietary_plans_path, class: "text-graphite hover:text-blackish dark:text-muted dark:hover:text-whiteish transition-colors" do %>
        <span class="material-symbols-outlined">close</span>
      <% end %>
    </div>

    <%# Form %>
    <%= form_for([namespace, resource], html: { class: "p-6 space-y-6" }) do |f| %>
      <% if resource.errors.any? %>
        <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-red-900/50 dark:text-red-300" role="alert">
          <ul class="list-disc pl-5 space-y-1">
            <% resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <%# User & Template Selection %>
        <div class="col-span-2 md:col-span-1">
          <%= f.label :user_id, class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
          <%= f.select :user_id, User.all.map { |u| [u.email, u.id] }, { include_blank: "Select User" }, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>

        <div class="col-span-2 md:col-span-1">
           <%= f.label :dietary_plan_id, "Template (Optional)", class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
           <%= f.select :dietary_plan_id, DietaryPlan.all.map { |dp| [dp.title, dp.id] }, { include_blank: "Select base template" }, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>

        <%# Active Toggle %>
        <div class="col-span-2 flex items-center">
            <%= f.check_box :active, class: "w-4 h-4 text-primary bg-background-light border-shadow rounded focus:ring-primary dark:focus:ring-primary dark:ring-offset-gray-800 focus:ring-2 dark:bg-shadow dark:border-graphite" %>
            <%= f.label :active, "Set as Active Plan", class: "ml-2 text-sm font-medium text-blackish dark:text-whiteish" %>
        </div>

        <%# Targets %>
         <div class="col-span-2 md:col-span-1">
          <%= f.label :calories_target, class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
          <%= f.number_field :calories_target, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>

         <div class="col-span-2 md:col-span-1">
          <%= f.label :protein_target, "Protein Target (g)", class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
          <%= f.number_field :protein_target, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>

        <%# Dates %>
        <div class="col-span-2 md:col-span-1">
          <%= f.label :start_date, class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
          <%= f.date_field :start_date, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>

        <div class="col-span-2 md:col-span-1">
          <%= f.label :end_date, class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
          <%= f.date_field :end_date, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>

        <%# Notes %>
        <div class="col-span-2">
          <%= f.label :notes, class: "block mb-2 text-sm font-medium text-blackish dark:text-whiteish" %>
          <%= f.text_area :notes, rows: 3, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish" %>
        </div>
      </div>

      <%# Footer %>
      <div class="flex items-center justify-end space-x-3 pt-4 border-t border-shadow dark:border-graphite sticky bottom-0 bg-whiteish dark:bg-shadow pb-2">
        <%= link_to "Cancel", admin_user_dietary_plans_path, class: "text-blackish bg-whiteish border border-shadow focus:ring-4 focus:outline-none focus:ring-primary/20 font-medium rounded-lg text-sm px-5 py-2.5 hover:bg-background-light hover:text-primary focus:z-10 dark:bg-shadow dark:text-muted dark:border-graphite dark:hover:text-whiteish dark:hover:bg-graphite", data: { turbo_frame: "_top" } %>
        <%= f.submit class: "text-blackish bg-primary hover:bg-primary/90 focus:ring-4 focus:outline-none focus:ring-primary/20 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-primary dark:hover:bg-primary/90 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
