<%# app/views/admin/user_dietary_plans/_plan_card.html.erb %>

<%= turbo_frame_tag dom_id(user_dietary_plan) do %>
  <div class="group relative flex items-center justify-between p-3 bg-whiteish dark:bg-shadow border border-shadow dark:border-graphite rounded-lg shadow-xs hover:border-primary/50 dark:hover:border-primary/50 transition-colors">
    <div class="flex items-center space-x-3 w-full min-w-0">
      <div class="flex-shrink-0 w-8 h-8 rounded bg-background-light dark:bg-blackish flex items-center justify-center text-graphite dark:text-muted">
        <span class="material-symbols-outlined text-sm">restaurant</span>
      </div>
      <div class="flex-1 min-w-0 pr-4">
        <p class="text-sm font-medium text-blackish dark:text-whiteish truncate">
          <%= link_to user_dietary_plan.dietary_plan&.name || "Dietary Plan", edit_admin_user_dietary_plan_path(user_dietary_plan), data: { turbo_frame: "modal_frame" }, class: "hover:text-primary transition-colors focus:outline-none focus:underline" %>
        </p>
        <p class="text-xs text-graphite dark:text-muted truncate mt-0.5 flex space-x-2">
           <span class="flex items-center"><span class="material-symbols-outlined text-[10px] mr-0.5">local_fire_department</span> <%= user_dietary_plan.calories_target || 'N/A' %> kcal</span>
           <span class="flex items-center"><span class="material-symbols-outlined text-[10px] mr-0.5">fitness_center</span> <%= user_dietary_plan.protein_target || 'N/A' %>g P</span>
           <span class="flex items-center"><span class="material-symbols-outlined text-[10px] mr-0.5">water_drop</span> <%= user_dietary_plan.fats_target || 'N/A' %>g F</span>
           <span class="flex items-center"><span class="material-symbols-outlined text-[10px] mr-0.5">grain</span> <%= user_dietary_plan.carbs_target || 'N/A' %>g C</span>
        </p>
      </div>
    </div>

    <%# Action Menu (Hidden by default, visible on hover) %>
    <div class="absolute right-2 opacity-0 group-hover:opacity-100 transition-opacity flex space-x-1 bg-whiteish dark:bg-shadow pl-2">
      <%= link_to edit_admin_user_dietary_plan_path(user_dietary_plan), data: { turbo_frame: "modal_frame" }, class: "text-graphite hover:text-primary dark:text-muted dark:hover:text-primary p-1 rounded hover:bg-background-light dark:hover:bg-blackish", title: "Edit Dietary Plan" do %>
        <span class="material-symbols-outlined text-sm">edit</span>
      <% end %>
      <%= button_to admin_user_dietary_plan_path(user_dietary_plan), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this dietary plan?" }, class: "text-graphite hover:text-red-600 dark:text-muted dark:hover:text-red-400 p-1 rounded hover:bg-background-light dark:hover:bg-blackish cursor-pointer", title: "Delete Dietary Plan" do %>
        <span class="material-symbols-outlined text-sm">delete</span>
      <% end %>
    </div>
  </div>
<% end %>
