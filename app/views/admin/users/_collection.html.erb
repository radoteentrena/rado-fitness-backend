<%
  page = local_assigns[:page] if local_assigns.key?(:page)
  collection_presenter = local_assigns.fetch(:collection_presenter, page)
  resources = local_assigns[:resources] if local_assigns.key?(:resources)
%>
<%= turbo_frame_tag "users_collection" do %>
<div class="relative overflow-x-auto bg-whiteish dark:bg-shadow shadow-xs rounded-xl border border-shadow dark:border-graphite mx-4">
    <table class="w-full text-sm text-left rtl:text-right text-graphite dark:text-muted">
        <thead class="text-sm text-blackish dark:text-whiteish bg-background-light dark:bg-graphite border-b border-shadow dark:border-graphite">
            <tr>
                <th scope="col" class="px-6 py-3 font-medium cursor-pointer hover:bg-background-light dark:hover:bg-shadow">
                    <%= render "admin/application/sortable_header", collection_presenter: collection_presenter, attr_name: :first_name, label: "Name", page: page, collection_field_name: local_assigns[:collection_field_name] %>
                </th>
                <th scope="col" class="px-6 py-3 font-medium cursor-pointer hover:bg-background-light dark:hover:bg-shadow">
                    <%= render "admin/application/sortable_header", collection_presenter: collection_presenter, attr_name: :phone, page: page, collection_field_name: local_assigns[:collection_field_name] %>
                </th>
                <th scope="col" class="px-6 py-3 font-medium text-center cursor-pointer hover:bg-background-light dark:hover:bg-shadow">
                    <%= render "admin/application/sortable_header", collection_presenter: collection_presenter, attr_name: :workout_compliance_score, label: "S% (Session)", page: page, collection_field_name: local_assigns[:collection_field_name] %>
                </th>
                <th scope="col" class="px-6 py-3 font-medium text-center cursor-pointer hover:bg-background-light dark:hover:bg-shadow">
                    <%= render "admin/application/sortable_header", collection_presenter: collection_presenter, attr_name: :diet_adherence_score, label: "M% (Diet)", page: page, collection_field_name: local_assigns[:collection_field_name] %>
                </th>
                <th scope="col" class="px-6 py-3 font-medium cursor-pointer hover:bg-background-light dark:hover:bg-shadow">
                    <%= render "admin/application/sortable_header", collection_presenter: collection_presenter, attr_name: :category, page: page, collection_field_name: local_assigns[:collection_field_name] %>
                </th>
                 <th scope="col" class="px-6 py-3 font-medium cursor-pointer hover:bg-background-light dark:hover:bg-shadow">
                    <%= render "admin/application/sortable_header", collection_presenter: collection_presenter, attr_name: :status, page: page, collection_field_name: local_assigns[:collection_field_name] %>
                </th>
                <th scope="col" class="px-6 py-3 font-medium cursor-pointer hover:bg-background-light dark:hover:bg-shadow">
                    <%= render "admin/application/sortable_header", collection_presenter: collection_presenter, attr_name: :plan_tier, page: page, collection_field_name: local_assigns[:collection_field_name] %>
                </th>
                <th scope="col" class="px-6 py-3 font-medium">
                    <span class="sr-only">Edit</span>
                </th>
            </tr>
        </thead>
        <tbody>
            <% resources.each do |resource| %>
            <tr class="bg-whiteish dark:bg-shadow border-b border-shadow dark:border-whiteish/50 hover:bg-background-light dark:hover:bg-shadow/50">
                <th scope="row" class="px-6 py-4 font-medium text-blackish dark:text-whiteish whitespace-nowrap">
                    <%= link_to resource.name, admin_user_path(resource), data: { turbo_frame: "admin_main_content", turbo_action: "advance" }, class: "hover:text-primary dark:hover:text-primary" %>
                </th>
                <td class="px-6 py-4">
                     <%= resource.phone %>
                </td>

                <%# S% - Session Compliance %>
                <td class="px-6 py-4">
                    <% s_score = resource.workout_compliance_score ? resource.workout_compliance_score : 0%>
                    <% s_color = s_score >= 80 ? "bg-green-500" : (s_score >= 50 ? "bg-yellow-400" : "bg-red-500") %>
                    <div class="flex items-center space-x-2">
                        <div class="w-full bg-gray-200 rounded-full h-2.5 dark:bg-gray-700 min-w-[60px]" style="--score: <%= s_score %>%">
                            <div class="<%= s_color %> h-2.5 rounded-full" style="width: var(--score)"></div>
                        </div>
                        <span class="text-xs font-medium text-gray-700 dark:text-gray-300"><%= s_score %>%</span>
                    </div>
                </td>

                <%# M% - Metric Adherence %>
                <td class="px-6 py-4">
                    <% m_score = resource.diet_adherence_score ? resource.diet_adherence_score : 0%>
                    <% m_color = m_score >= 80 ? "bg-green-500" : (m_score >= 50 ? "bg-yellow-400" : "bg-red-500") %>
                    <div class="flex items-center space-x-2">
                        <div class="w-full bg-gray-200 rounded-full h-2.5 dark:bg-gray-700 min-w-[60px]" style="--score: <%= m_score %>%">
                            <div class="<%= m_color %> h-2.5 rounded-full" style="width: var(--score)"></div>
                        </div>
                        <span class="text-xs font-medium text-gray-700 dark:text-gray-300"><%= m_score %>%</span>
                    </div>
                </td>

                <td class="px-6 py-4">
                    <% category_colors = {
                        "pelele" => "bg-graphite text-whiteish dark:bg-background-light dark:text-blackish",
                        "civil" => "bg-background-light border border-2 border-primary text-blackish dark:bg-primary dark:text-blackish",
                        "soldado" => "bg-primary text-blackish dark:bg-primary dark:text-blackish"
                    } %>
                    <span class="<%= category_colors[resource.category] || 'bg-background-light text-graphite dark:bg-graphite dark:text-whiteish' %> text-xs font-medium me-2 px-2.5 py-0.5 rounded-full">
                        <%= resource.category&.titleize %>
                    </span>
                </td>
                <td class="px-6 py-4">
                    <% status_colors = {
                        "active" => "bg-primary-100 text-graphite text-xs font-medium px-2.5 py-0.5 rounded dark:bg-primary-900 dark:text-primary-300 mb-1",
                        "lead" => "bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-green-900 dark:text-green-300 mb-1",
                        "churned" => "bg-gray-100 text-gray-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-gray-900 dark:text-gray-300 mb-1",
                        "archived" => "bg-red-100 text-red-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-red-900 dark:text-red-300 mb-1"
                    } %>
                    <span class="<%= status_colors[resource.status] || 'bg-background-light text-graphite' %> text-xs font-medium me-2 px-2.5 py-0.5 rounded-full">
                       <%= resource.status.titleize %>
                    </span>
                </td>
                <td class="px-6 py-4">
                    <%= (resource.active_subscription&.plan_tier || resource.plan_tier)&.titleize || "N/A" %>
                </td>
                <td class="px-6 py-4 text-right">
                    <%= link_to "Edit", edit_admin_user_path(resource), data: { turbo_frame: "modal_frame" }, class: "font-medium text-primary dark:text-primary hover:underline" %>
                </td>
            </tr>
            <% end %>
        </tbody>
    </table>
</div>

<%# Pagination %>
<div class="p-4">
    <%= paginate resources, total_count: resources.total_count %>
</div>
<% end %>
