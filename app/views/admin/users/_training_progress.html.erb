<%# app/views/admin/users/_training_progress.html.erb %>
<%
  all_sessions   = user.training_sessions.order(session_number: :asc)
  completed      = all_sessions.select(&:completed?)
  skipped        = all_sessions.select(&:skipped?)
  total_count    = all_sessions.count
  completed_count = completed.count
  skipped_count   = skipped.count

  current_session = TrainingSession.current_for(user)
%>

<div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite p-6">
  <h3 class="text-lg font-bold text-blackish dark:text-whiteish mb-6">Training Progression</h3>

  <%# Summary Counters %>
  <div class="grid grid-cols-3 gap-4 mb-6">
    <div class="p-4 rounded-lg bg-background-light dark:bg-graphite text-center">
      <span class="block text-xs font-bold text-graphite dark:text-muted uppercase tracking-wider">Total Sessions</span>
      <span class="block mt-1 text-2xl font-bold text-blackish dark:text-whiteish"><%= total_count %></span>
    </div>
    <div class="p-4 rounded-lg bg-background-light dark:bg-graphite text-center">
      <span class="block text-xs font-bold text-graphite dark:text-muted uppercase tracking-wider">Completed</span>
      <span class="block mt-1 text-2xl font-bold text-primary"><%= completed_count %></span>
    </div>
    <div class="p-4 rounded-lg bg-background-light dark:bg-graphite text-center">
      <span class="block text-xs font-bold text-graphite dark:text-muted uppercase tracking-wider">Skipped</span>
      <span class="block mt-1 text-2xl font-bold text-graphite dark:text-muted"><%= skipped_count %></span>
    </div>
  </div>

  <%# Current Position Block %>
  <% if current_session %>
    <div class="mb-6 p-4 rounded-lg border-2 border-primary/40 bg-primary/5 dark:bg-primary/10">
      <div class="flex items-start justify-between">
        <div class="space-y-1">
          <p class="text-xs font-bold text-graphite dark:text-muted uppercase tracking-wider">Current Position</p>
          <p class="text-base font-bold text-blackish dark:text-whiteish"><%= current_session.phase.name %></p>
          <p class="text-sm text-graphite dark:text-muted">
            Cycle <%= current_session.cycle_number %> &middot;
            Session #<%= current_session.session_number %> &middot;
            <%= current_session.workout.name %>
          </p>
        </div>
        <% badge_classes = current_session.pending? ? "bg-graphite/20 text-graphite dark:text-muted" : "bg-primary/20 text-primary" %>
        <span class="px-2 py-0.5 text-xs font-bold rounded border border-current/20 <%= badge_classes %>">
          <%= current_session.status.titleize %>
        </span>
      </div>
    </div>
  <% elsif total_count.zero? %>
    <div class="mb-6 flex flex-col items-center justify-center py-6 text-center border-2 border-dashed border-shadow dark:border-graphite rounded-lg">
      <span class="material-symbols-outlined text-3xl text-shadow dark:text-graphite mb-2">fitness_center</span>
      <p class="text-graphite dark:text-muted text-sm">No training sessions yet.</p>
    </div>
  <% else %>
    <div class="mb-6 p-4 rounded-lg border border-shadow dark:border-graphite bg-background-light dark:bg-graphite">
      <p class="text-sm text-graphite dark:text-muted">Program completed — no active session.</p>
    </div>
  <% end %>

  <%# Session History Table %>
  <% history_sessions = all_sessions.select { |s| s.completed? || s.skipped? }.sort_by(&:session_number).reverse %>
  <% if history_sessions.any? %>
    <div>
      <p class="text-xs font-bold text-graphite dark:text-muted uppercase tracking-wider mb-3">Session History</p>

      <div class="space-y-2" data-controller="disclosure">
        <% history_sessions.each do |session| %>
          <%
            program_execution = session.program_execution
            duration_str = if session.started_at && session.completed_at
              minutes = ((session.completed_at - session.started_at) / 60).round
              "#{minutes}m"
            else
              "—"
            end
          %>

          <div class="rounded-lg border border-shadow dark:border-graphite overflow-hidden">
            <%# Row Header — always visible %>
            <button
              type="button"
              class="w-full flex items-center justify-between px-4 py-3 bg-background-light dark:bg-graphite hover:bg-shadow/30 dark:hover:bg-shadow/50 transition-colors text-left"
              onclick="this.nextElementSibling.classList.toggle('hidden')"
            >
              <div class="flex items-center space-x-3">
                <span class="text-xs font-bold text-graphite dark:text-muted w-6">#<%= session.session_number %></span>

                <% if session.completed? %>
                  <span class="px-2 py-0.5 text-xs font-bold bg-primary/20 text-primary rounded">Completed</span>
                <% else %>
                  <span class="px-2 py-0.5 text-xs font-bold bg-graphite/20 text-graphite dark:text-muted rounded">Skipped</span>
                <% end %>

                <span class="text-sm font-medium text-blackish dark:text-whiteish">
                  <%= session.workout.name %>
                </span>
                <span class="text-xs text-graphite dark:text-muted hidden sm:inline">
                  <%= session.phase.name %>
                </span>
              </div>

              <div class="flex items-center space-x-3 text-right">
                <% if session.completed? %>
                  <span class="text-xs text-graphite dark:text-muted">
                    <%= session.completed_at&.strftime("%b %d, %Y") %>
                  </span>
                  <span class="text-xs font-medium text-blackish dark:text-whiteish"><%= duration_str %></span>
                <% else %>
                  <span class="text-xs text-graphite dark:text-muted">
                    <%= session.skipped_at&.strftime("%b %d, %Y") %>
                  </span>
                <% end %>
                <span class="material-symbols-outlined text-graphite dark:text-muted text-base">expand_more</span>
              </div>
            </button>

            <%# Expanded Detail — hidden by default %>
            <div class="hidden px-4 pb-4 pt-3 border-t border-shadow dark:border-graphite bg-whiteish dark:bg-shadow">
              <% if session.skipped? %>
                <p class="text-sm text-graphite dark:text-muted italic">
                  Skipped<% if session.skip_reason.present? %>: "<%= session.skip_reason %>"<% end %>
                </p>
              <% elsif session.completed? && program_execution %>
                <%
                  logs_by_we_id = program_execution.exercise_logs
                    .includes(:workout_exercise)
                    .index_by(&:workout_exercise_id)
                  workout_exercises = session.workout.workout_exercises.includes(:exercise).order(order_index: :asc)
                %>

                <table class="w-full text-xs">
                  <thead>
                    <tr class="border-b border-shadow dark:border-graphite">
                      <th class="text-left py-2 font-bold text-graphite dark:text-muted uppercase tracking-wider">Exercise</th>
                      <th class="text-center py-2 font-bold text-graphite dark:text-muted uppercase tracking-wider">Prescribed</th>
                      <th class="text-center py-2 font-bold text-graphite dark:text-muted uppercase tracking-wider">Actual Sets</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-shadow dark:divide-graphite">
                    <% workout_exercises.each do |we| %>
                      <% log = logs_by_we_id[we.id] %>
                      <tr>
                        <td class="py-2 font-medium text-blackish dark:text-whiteish"><%= we.exercise.name %></td>
                        <td class="py-2 text-center text-graphite dark:text-muted">
                          <%= we.sets %>×<%= we.reps %><% if we.load.present? %> @ <%= we.load %><% end %>
                        </td>
                        <td class="py-2 text-center">
                          <% if log && log.actual_sets.present? %>
                            <% Array(log.actual_sets).each_with_index do |set, i| %>
                              <span class="inline-block text-blackish dark:text-whiteish">
                                Set <%= i + 1 %>: <%= set["reps"] %>r
                                <% if set["weight"].present? %>@ <%= set["weight"] %>kg<% end %>
                                <% if set["rpe"].present? %>(RPE <%= set["rpe"] %>)<% end %>
                              </span><br>
                            <% end %>
                          <% else %>
                            <span class="text-graphite dark:text-muted italic">Not logged</span>
                          <% end %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>

                <% if session.notes.present? %>
                  <div class="mt-3 pt-3 border-t border-shadow dark:border-graphite">
                    <p class="text-xs font-bold text-graphite dark:text-muted uppercase tracking-wider mb-1">Notes</p>
                    <p class="text-sm text-blackish dark:text-whiteish italic">"<%= session.notes %>"</p>
                  </div>
                <% end %>
              <% else %>
                <p class="text-sm text-graphite dark:text-muted italic">No exercise data recorded.</p>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
