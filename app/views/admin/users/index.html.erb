<%# Page Title %>
<header class="px-4 pt-6 pb-4 mb-4 border-b border-shadow dark:border-graphite">
  <h1 class="text-2xl font-bold text-blackish dark:text-whiteish">Users Management</h1>
  <p class="text-sm text-graphite dark:text-muted mt-1">Manage user accounts, permissions, and profiles</p>
</header>

<%# Header Section %>
<div class="flex flex-col md:flex-row items-center justify-between space-y-3 md:space-y-0 md:space-x-4 p-4">
  <div class="w-full md:w-1/2">
    <form class="flex items-center">
      <label for="search" class="sr-only">Search</label>
      <div class="relative w-full">
        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
          <svg aria-hidden="true" class="w-5 h-5 text-graphite dark:text-muted" fill="currentColor" viewbox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
          </svg>
        </div>
        <input type="text" name="search" id="search" value="<%= params[:search] %>" class="bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-full pl-10 p-2 dark:bg-shadow dark:border-graphite dark:placeholder-graphite dark:text-whiteish dark:focus:ring-primary dark:focus:border-primary" placeholder="Search" required="">
      </div>
    </form>
  </div>
  <div class="w-full md:w-auto flex flex-col md:flex-row space-y-2 md:space-y-0 items-stretch md:items-center justify-end md:space-x-3 flex-shrink-0">
    <%= link_to new_admin_user_path, data: { turbo_frame: "modal_frame" }, class: "flex items-center justify-center text-blackish bg-primary hover:bg-primary/90 focus:ring-4 focus:ring-primary/20 font-medium rounded-lg text-sm px-4 py-2 dark:bg-primary dark:hover:bg-primary/90 focus:outline-none dark:focus:ring-primary/20" do %>
      <svg class="h-3.5 w-3.5 mr-2" fill="currentColor" viewbox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path clip-rule="evenodd" fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" />
      </svg>
      Add user
    <% end %>
  </div>
</div>

<%# Filter Section %>
<div class="px-4 pb-4">
  <div class="bg-whiteish dark:bg-shadow p-4 rounded-lg border border-shadow dark:border-graphite shadow-sm">
    <%= form_with url: admin_users_path, method: :get, data: { turbo_frame: "users_collection", turbo_action: "advance" }, class: "flex flex-wrap items-end gap-4" do |f| %>

      <%# Preserve Search %>
      <%= f.hidden_field :search, value: params[:search] if params[:search].present? %>

      <%# Status Filter %>
      <div class="flex flex-col space-y-1">
        <%= f.label :status, "Status", class: "text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider" %>
        <%= f.select :status, User.statuses.keys.map { |k| [k.titleize, k] }, { include_blank: "All Statuses", selected: params[:status] }, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-40 p-2.5 dark:bg-graphite dark:border-graphite dark:text-whiteish" %>
      </div>

      <%# Plan Tier Filter %>
      <div class="flex flex-col space-y-1">
        <%= f.label :plan_tier, "Plan Tier", class: "text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider" %>
        <%= f.select :plan_tier, User.plan_tiers.keys.map { |k| [k.titleize, k] }, { include_blank: "All Tiers", selected: params[:plan_tier] }, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-40 p-2.5 dark:bg-graphite dark:border-graphite dark:text-whiteish" %>
      </div>

      <%# S% Filter %>
      <div class="flex flex-col space-y-1">
        <%= f.label :s_score, "Session (S%)", class: "text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider" %>
        <%= f.select :s_score, [["High (>80%)", "high"], ["Medium (50-79%)", "medium"], ["Low (<50%)", "low"]], { include_blank: "All S%", selected: params[:s_score] }, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-40 p-2.5 dark:bg-graphite dark:border-graphite dark:text-whiteish" %>
      </div>

      <%# M% Filter %>
      <div class="flex flex-col space-y-1">
        <%= f.label :m_score, "Metric (M%)", class: "text-xs font-semibold text-graphite dark:text-muted uppercase tracking-wider" %>
        <%= f.select :m_score, [["High (>80%)", "high"], ["Medium (50-79%)", "medium"], ["Low (<50%)", "low"]], { include_blank: "All M%", selected: params[:m_score] }, class: "bg-background-light border border-shadow text-blackish text-sm rounded-lg focus:ring-primary focus:border-primary block w-40 p-2.5 dark:bg-graphite dark:border-graphite dark:text-whiteish" %>
      </div>

      <div class="flex gap-2">
        <%= f.submit "Filter", class: "cursor-pointer text-whiteish bg-primary hover:bg-primary/90 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-primary dark:hover:bg-primary/90 focus:outline-none transition-colors" %>
        <%= link_to "Clear", admin_users_path, class: "flex items-center justify-center text-graphite bg-whiteish border border-shadow hover:bg-background-light font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-shadow dark:text-whiteish dark:border-graphite dark:hover:bg-graphite transition-colors" %>
      </div>
    <% end %>
  </div>
</div>

<%# Table Section %>
<%= render(
      "collection",
      collection_presenter: page,
      collection_field_name: resource_name,
      page: page,
      resources: resources,
      table_title: "page-title"
    ) %>

<%= turbo_frame_tag "modal_frame" %>
