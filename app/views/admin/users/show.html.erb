<%# app/views/admin/users/show.html.erb %>
<% user = page.resource %>
<%= turbo_stream_from "user_compliance_#{user.id}" %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-4">
      <%= link_to admin_users_path, class: "p-2 text-graphite bg-whiteish rounded-lg border border-shadow hover:bg-background-light hover:text-blackish dark:bg-shadow dark:border-graphite dark:text-muted dark:hover:bg-shadow/50 dark:hover:text-whiteish" do %>
         <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5H1m0 0 4 4M1 5l4-4"/>
         </svg>
         <span class="sr-only">Back</span>
      <% end %>
      <h1 class="text-2xl font-bold tracking-tight text-blackish dark:text-whiteish">
        <%= user.name %>
      </h1>
    </div>

    <div class="flex space-x-3">
        <%= link_to "Edit User", edit_admin_user_path(user), data: { turbo_frame: "modal_frame" }, class: "button" %>
        <%= button_to "Re-asignar Programa", admin_user_program_assignment_path(user),
            method: :post,
            data: { turbo_confirm: "¿Re-asignar programa a #{user.name}? Se buscará el mejor template disponible." },
            class: "button" %>
        <%= button_to "Generar Link de Pago", admin_user_payment_link_path(user),
            method: :post,
            class: "button" %>
    </div>
  </div>

  <div id="payment_link_result"></div>

  <%# Main Content Grid %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <%# Left Column: User Details %>
    <div class="lg:col-span-1 space-y-6">
      <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-primary/30 p-6">
         <div class="flex flex-col items-center pb-6 border-b border-shadow dark:border-primary/30">
            <div class="w-24 h-24 mb-3 rounded-full bg-primary/20 text-primary flex items-center justify-center text-3xl font-bold">
                <%= user.first_name[0] %><%= user.last_name[0] %>
            </div>
            <h5 class="mb-1 text-xl font-medium text-blackish dark:text-whiteish"><%= user.name %></h5>
            <span class="text-sm text-graphite dark:text-muted"><%= user.email %></span>

            <div class="flex mt-4 space-x-3 md:mt-6">
                 <% category_colors = {
                        "pelele" => "bg-graphite text-whiteish dark:bg-graphite dark:text-whiteish",
                        "civil" => "bg-shadow text-whiteish dark:bg-shadow dark:text-whiteish",
                        "soldado" => "bg-primary text-blackish dark:bg-primary dark:text-blackish"
                    } %>
                <span class="px-3 py-1 text-sm font-medium rounded-full <%= category_colors[user.category] || 'bg-background-light text-graphite' %>">
                   <%= user.category&.titleize %>
                </span>
                 <% status_colors = {
                        "active" => "bg-primary text-blackish dark:bg-primary dark:text-blackish",
                        "lead" => "bg-background-light text-graphite dark:bg-graphite dark:text-whiteish",
                        "churned" => "bg-blackish text-whiteish dark:bg-blackish dark:text-whiteish",
                        "archived" => "bg-blackish text-whiteish dark:bg-blackish dark:text-whiteish"
                    } %>
                <span class="px-3 py-1 text-sm font-medium rounded-full <%= status_colors[user.status] || 'badge-neutral' %>">
                   <%= user.status.titleize %>
                </span>
            </div>
         </div>

         <div class="pt-6 space-y-4">
             <div>
                <dt class="text-sm font-medium text-graphite dark:text-muted">Phone</dt>
                <dd class="text-base font-semibold text-blackish dark:text-whiteish"><%= user.phone.presence || "N/A" %></dd>
             </div>
             <div>
                <dt class="text-sm font-medium text-graphite dark:text-muted">Plan Tier</dt>
                <dd class="text-base font-semibold text-blackish dark:text-whiteish"><%= (user.active_subscription&.plan_tier || user.plan_tier)&.titleize || "N/A" %></dd>
             </div>
             <div>
                <dt class="text-sm font-medium text-graphite dark:text-muted">Member Since</dt>
                <dd class="text-base font-semibold text-blackish dark:text-whiteish"><%= user.created_at.strftime("%B %d, %Y") %></dd>
             </div>
         </div>
      </div>

      <%= render "subscription", subscription: user.active_subscription %>

      <%# Dietary Plan %>
      <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-primary/30 p-6">
          <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-bold text-blackish dark:text-whiteish">Current Dietary Plan</h3>
              <%= link_to "Asignar Plan", new_admin_user_dietary_plan_assignment_path(user),
                  data: { turbo_frame: "modal_frame" },
                  class: "text-sm font-medium text-primary hover:underline" %>
          </div>

          <% if (active_plan = user.user_dietary_plans.active.last) %>
              <div class="space-y-4">
                  <div class="flex items-center justify-between p-3 bg-background-light dark:bg-graphite rounded-lg">
                       <div>
                          <h4 class="font-medium text-blackish dark:text-whiteish">
                              <%= active_plan.dietary_plan&.name || "Custom Plan" %>
                          </h4>
                          <p class="text-xs text-graphite dark:text-muted mt-1">
                              Since <%= active_plan.start_date&.strftime("%b %d, %Y") %>
                          </p>
                       </div>
                       <div class="flex items-center gap-2">
                          <span class="inline-block px-2 py-0.5 text-xs font-bold text-primary bg-primary/10 rounded border border-primary/20">Active</span>
                          <%= button_to admin_user_dietary_plan_path(active_plan), method: :delete,
                              data: { turbo_confirm: "¿Eliminar el plan \"#{active_plan.dietary_plan&.name || 'Custom Plan'}\" de #{user.name}?" },
                              class: "p-1 text-graphite hover:text-red-500 dark:text-muted dark:hover:text-red-400 transition-colors rounded focus:outline-none focus:ring-2 focus:ring-red-400",
                              title: "Eliminar plan" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6" />
                            </svg>
                          <% end %>
                       </div>
                  </div>

                  <div class="grid grid-cols-2 gap-4">
                      <div class="col-span-2 p-4 rounded-lg border border-shadow dark:border-primary/30 text-center">
                          <span class="block text-xs font-bold text-graphite dark:text-muted uppercase tracking-wider">Calories</span>
                          <span class="block mt-1 text-2xl font-bold text-blackish dark:text-whiteish"><%= active_plan.calories_target %></span>
                      </div>
                      <div class="p-4 rounded-lg border border-shadow dark:border-primary/30 text-center">
                          <span class="block text-xs font-bold text-graphite dark:text-muted uppercase tracking-wider">Protein</span>
                          <span class="block mt-1 text-2xl font-bold text-blackish dark:text-whiteish"><%= active_plan.protein_target %>g</span>
                      </div>
                      <div class="p-4 rounded-lg border border-shadow dark:border-primary/30 text-center">
                          <span class="block text-xs font-bold text-graphite dark:text-muted uppercase tracking-wider">Fats</span>
                          <span class="block mt-1 text-2xl font-bold text-blackish dark:text-whiteish"><%= active_plan.fats_target %>g</span>
                      </div>
                      <div class="col-span-2 p-4 rounded-lg border border-shadow dark:border-primary/30 text-center">
                          <span class="block text-xs font-bold text-graphite dark:text-muted uppercase tracking-wider">Carbs</span>
                          <span class="block mt-1 text-2xl font-bold text-blackish dark:text-whiteish"><%= active_plan.carbs_target %>g</span>
                      </div>
                  </div>

                  <% if active_plan.notes.present? %>
                      <div class="text-sm text-graphite dark:text-muted p-3 bg-background-light dark:bg-graphite rounded-lg italic">
                          "<%= active_plan.notes %>"
                      </div>
                  <% end %>
              </div>
          <% else %>
              <div class="flex flex-col items-center justify-center py-6 text-center border-2 border-dashed border-shadow dark:border-primary/30 rounded-lg">
                  <span class="material-symbols-outlined text-3xl text-graphite dark:text-muted mb-2">restaurant_menu</span>
                  <p class="text-graphite dark:text-muted text-sm">No active plan.</p>
              </div>
          <% end %>
      </div>
    </div>

    <%# Right Column: Stats & Activity %>
    <div class="lg:col-span-2 space-y-6">
        <%# Stats Grid %>
        <%= turbo_frame_tag "user_compliance_scores_#{user.id}" do %>
          <%= render "admin/users/compliance_scores", user: user %>
        <% end %>

        <%# Metrics Calendar %>
        <%= render "admin/users/metrics_calendar", user: user, start_date: @start_date, view_type: @view_type, daily_metrics: @daily_metrics, current_weight: @current_weight, weight_trend: @weight_trend %>

        <%# Placeholder for future sections %>
        <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-primary/30 p-6">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-bold text-blackish dark:text-whiteish">Assigned Programs</h3>
              <%= link_to "Asignar Programa", new_admin_user_program_assignment_path(user),
                  data: { turbo_frame: "modal_frame" },
                  class: "text-sm font-medium text-primary hover:underline" %>
            </div>
            <% if user.programs.any? %>
                <ul class="space-y-4">
                    <% user.programs.order(created_at: :desc).each do |program| %>
                        <li class="p-4 bg-background-light dark:bg-graphite rounded-lg space-y-3">
                            <div class="flex items-center justify-between">
                                <div>
                                    <h4 class="font-medium text-blackish dark:text-whiteish">
                                        <%= link_to program.name, admin_program_builder_path(program), class: "hover:text-primary transition-colors focus:outline-none focus:underline" %>
                                    </h4>
                                    <div class="flex items-center space-x-2 mt-1">
                                         <span class="text-xs px-2 py-0.5 bg-primary/10 text-primary rounded border border-primary/20">Week <%= program.current_week %></span>
                                    </div>
                                </div>
                                <%= button_to remove_user_admin_program_path(program), method: :delete,
                                    data: { turbo_confirm: "¿Estás seguro de querer borrar el programa \"#{program.name}\" a #{user.name}?" },
                                    class: "p-2 text-graphite hover:text-red-500 dark:text-muted dark:hover:text-red-400 hover:cursor-pointer transition-colors rounded focus:outline-none focus:ring-2 focus:ring-red-400",
                                    title: "Remover programa" do %>
                                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6" />
                                  </svg>
                                <% end %>
                            </div>

                            <% if (current_routine = program.current_routine) %>
                                <div class="mt-3 pt-3 border-t border-shadow dark:border-primary/30">
                                    <p class="text-xs font-bold text-graphite dark:text-muted uppercase tracking-wider mb-2">Current Routine</p>
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center space-x-2">
                                            <span class="material-symbols-outlined text-sm text-primary">fitness_center</span>
                                            <span class="font-medium text-blackish dark:text-whiteish">
                                                <%= link_to current_routine.name, admin_routine_path(current_routine), data: { turbo: false }, class: "hover:text-primary transition-colors focus:outline-none focus:underline" %>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            <% end %>
                        </li>
                    <% end %>
                </ul>
            <% else %>
                <p class="text-graphite dark:text-muted text-sm">No programs assigned yet.</p>
            <% end %>
        </div>
    </div>
  </div>

  <%# Training Progression %>
  <%= render "admin/users/training_progress", user: user %>

  <%# Progress Photos Gallery %>
  <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-primary/30 p-6">
      <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-bold text-blackish dark:text-whiteish">Progress Photos</h3>
          <span class="text-sm text-graphite dark:text-muted"><%= user.progress_photos.count %> total snaps</span>
      </div>

      <% if user.progress_photos.any? %>
          <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4">
              <% user.progress_photos.with_attached_image.order(date: :desc).each do |photo| %>
                  <% next unless photo.image.attached? %>
                  <div class="group relative rounded-lg overflow-hidden border border-shadow dark:border-primary/30 bg-background-light dark:bg-graphite aspect-[3/4]">
                      <%= link_to admin_progress_photo_path(photo), class: "block w-full h-full" do %>
                          <%= image_tag photo.image, class: "object-cover w-full h-full transition-transform duration-300 group-hover:scale-105" %>
                      <% end %>
                      <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-blackish/80 to-transparent p-3 pt-6 pointer-events-none transition-opacity duration-200">
                          <p class="text-xs text-whiteish font-medium shadow-sm"><%= photo.date.strftime("%b %d, %Y") %></p>
                          <% if photo.note.present? %>
                            <p class="text-[10px] text-whiteish/80 line-clamp-2 mt-0.5"><%= photo.note %></p>
                          <% end %>
                      </div>
                  </div>
              <% end %>
          </div>
      <% else %>
          <div class="flex flex-col items-center justify-center py-8 text-center border-2 border-dashed border-shadow dark:border-primary/30 rounded-lg">
              <span class="material-symbols-outlined text-3xl text-graphite dark:text-muted mb-2">photo_camera</span>
              <p class="text-graphite dark:text-muted text-sm">No progress photos uploaded yet.</p>
          </div>
      <% end %>
  </div>
</div>
<%= turbo_frame_tag "modal_frame" %>
