<%= turbo_frame_tag workout_exercise do %>
   <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border-2 border-primary overflow-hidden">
      <%= form_with model: workout_exercise, url: admin_workout_exercise_path(workout_exercise), method: :patch, class: "flex flex-col h-full" do |f| %>
         <div class="p-4 border-b border-shadow dark:border-graphite flex justify-between items-start bg-background-light dark:bg-shadow/50">
            <div>
               <h3 class="text-lg font-bold text-blackish dark:text-whiteish flex items-center gap-2">
                  <div class="w-8 h-8 rounded-full bg-primary text-blackish font-bold flex items-center justify-center text-sm">
                    <%= workout_exercise.order_index || "-" %>
                  </div>
                  <%= workout_exercise.exercise.name %>
                  <span class="text-xs px-2 py-0.5 rounded bg-primary/20 text-primary uppercase tracking-wide font-bold ml-2">Editing</span>
               </h3>
            </div>
            <div class="flex items-center gap-2">
               <%= link_to "Cancel", admin_routine_path(workout_exercise.workout.routine), class: "text-xs font-bold text-graphite hover:text-blackish dark:text-muted dark:hover:text-whiteish transition-colors px-3 py-2 rounded" %>
               <%= f.submit "Save", class: "text-xs font-bold bg-primary text-blackish hover:bg-primary/90 transition-colors px-4 py-2 rounded cursor-pointer" %>
            </div>
         </div>

         <div class="p-4 space-y-4">
            <% if workout_exercise.errors.any? %>
              <div class="p-3 bg-red-100 text-red-800 rounded-lg text-sm mb-4">
                <ul class="list-disc pl-5">
                  <% workout_exercise.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <!-- Grid 1: Sets, Reps, Warmup -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
               <div>
                  <%= f.label :sets, class: "block text-xs uppercase text-muted mb-1 font-bold tracking-wider" %>
                  <%= f.number_field :sets, class: "w-full bg-background dark:bg-graphite/50 border border-shadow dark:border-graphite rounded-lg px-3 py-2 text-blackish dark:text-whiteish focus:ring-primary focus:border-primary" %>
               </div>
               <div>
                  <%= f.label :reps, class: "block text-xs uppercase text-muted mb-1 font-bold tracking-wider" %>
                  <%= f.text_field :reps, class: "w-full bg-background dark:bg-graphite/50 border border-shadow dark:border-graphite rounded-lg px-3 py-2 text-blackish dark:text-whiteish focus:ring-primary focus:border-primary" %>
               </div>
               <div>
                  <%= f.label :warmup_sets, "Warmup Sets", class: "block text-xs uppercase text-muted mb-1 font-bold tracking-wider" %>
                  <%= f.text_field :warmup_sets, class: "w-full bg-background dark:bg-graphite/50 border border-shadow dark:border-graphite rounded-lg px-3 py-2 text-blackish dark:text-whiteish focus:ring-primary focus:border-primary" %>
               </div>
            </div>

            <!-- Grid 2: RPE, Rest, Load -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
               <div>
                  <%= f.label :early_rpe, "Early RPE", class: "block text-xs uppercase text-muted mb-1 font-bold tracking-wider" %>
                  <%= f.text_field :early_rpe, class: "w-full bg-background dark:bg-graphite/50 border border-shadow dark:border-graphite rounded-lg px-3 py-2 text-blackish dark:text-whiteish focus:ring-primary focus:border-primary" %>
               </div>
               <div>
                  <%= f.label :last_rpe, "Last RPE", class: "block text-xs uppercase text-muted mb-1 font-bold tracking-wider" %>
                  <%= f.text_field :last_rpe, class: "w-full bg-background dark:bg-graphite/50 border border-shadow dark:border-graphite rounded-lg px-3 py-2 text-blackish dark:text-whiteish focus:ring-primary focus:border-primary" %>
               </div>
               <div>
                  <%= f.label :rest_seconds, "Rest (s)", class: "block text-xs uppercase text-muted mb-1 font-bold tracking-wider" %>
                  <%= f.number_field :rest_seconds, class: "w-full bg-background dark:bg-graphite/50 border border-shadow dark:border-graphite rounded-lg px-3 py-2 text-blackish dark:text-whiteish focus:ring-primary focus:border-primary" %>
               </div>
                <div>
                  <%= f.label :load, "Load", class: "block text-xs uppercase text-muted mb-1 font-bold tracking-wider" %>
                  <%= f.text_field :load, placeholder: "e.g. 50kg, Bodyweight", class: "w-full bg-background dark:bg-graphite/50 border border-shadow dark:border-graphite rounded-lg px-3 py-2 text-blackish dark:text-whiteish focus:ring-primary focus:border-primary" %>
               </div>
            </div>

            <div class="border-t border-shadow dark:border-graphite pt-4 mt-2">
               <!-- Grid 3: Intensity & Sub Options -->
               <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                  <div>
                     <%= f.label :intensity_technique, "Intensity Technique", class: "block text-xs uppercase tracking-wider text-primary mb-1 font-bold" %>
                     <%= f.select :intensity_technique, options_for_select(WorkoutExercise::INTENSITY_TECHNIQUES, workout_exercise.intensity_technique), { include_blank: "None" }, class: "w-full bg-background dark:bg-graphite/50 border border-primary/30 rounded-lg px-3 py-2 text-blackish dark:text-whiteish focus:ring-primary focus:border-primary" %>
                  </div>
                  <div>
                     <%= f.label :sub_option_one, "Sub Option 1", class: "block text-xs uppercase tracking-wider text-graphite dark:text-muted mb-1 font-bold" %>
                     <% same_muscle_group = Exercise.where(muscle_group: workout_exercise.exercise.muscle_group).order(:name).pluck(:name, :name) %>
                     <%= f.select :sub_option_one, options_for_select(same_muscle_group, workout_exercise.sub_option_one), { include_blank: "Select Exercise..." }, class: "w-full bg-background dark:bg-graphite/50 border border-shadow dark:border-graphite rounded-lg px-3 py-2 text-blackish dark:text-whiteish focus:ring-primary focus:border-primary" %>
                  </div>
                   <div>
                     <%= f.label :sub_option_two, "Sub Option 2", class: "block text-xs uppercase tracking-wider text-graphite dark:text-muted mb-1 font-bold" %>
                     <% same_muscle_group = Exercise.where(muscle_group: workout_exercise.exercise.muscle_group).order(:name).pluck(:name, :name) %>
                     <%= f.select :sub_option_two, options_for_select(same_muscle_group, workout_exercise.sub_option_two), { include_blank: "Select Exercise..." }, class: "w-full bg-background dark:bg-graphite/50 border border-shadow dark:border-graphite rounded-lg px-3 py-2 text-blackish dark:text-whiteish focus:ring-primary focus:border-primary" %>
                  </div>
               </div>
            </div>
         </div>
      <% end %>
   </div>
<% end %>
