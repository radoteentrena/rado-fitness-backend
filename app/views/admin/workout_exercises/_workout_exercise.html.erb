<%= turbo_frame_tag workout_exercise do %>
   <div class="bg-whiteish dark:bg-shadow rounded-xl shadow-sm border border-shadow dark:border-graphite overflow-hidden group hover:border-primary/50 transition-colors mb-3">
      <div class="p-4 border-b border-shadow dark:border-graphite flex justify-between items-start bg-background-light dark:bg-shadow/50">
         <div>
            <h3 class="text-lg font-bold text-blackish dark:text-whiteish flex items-center gap-2">
               <div class="w-8 h-8 rounded-full bg-primary text-blackish font-bold flex items-center justify-center text-sm">
                 <%= workout_exercise.order_index || "-" %>
               </div>
               <%= workout_exercise.exercise.name %>
               <% if workout_exercise.warmup_sets.present? && workout_exercise.warmup_sets != '0' %>
                 <span class="text-xs px-2 py-0.5 rounded bg-orange-100 text-orange-800 dark:bg-orange-900 dark:text-orange-200 uppercase tracking-wide font-bold">Warmup</span>
               <% end %>
            </h3>
            <p class="text-xs text-muted mt-1 ml-10"><%= workout_exercise.exercise.muscle_group %></p>
         </div>
         <div class="flex items-center gap-4">
            <% if workout_exercise.time_estimate.present? %>
               <div class="text-xs font-semibold text-graphite dark:text-muted flex items-center justify-end gap-1 bg-whiteish dark:bg-graphite px-2 py-1 rounded border border-shadow dark:border-graphite shadow-sm">
                  <span class="material-symbols-outlined text-sm">schedule</span>
                  <%= workout_exercise.time_estimate %>
               </div>
            <% end %>
            <div class="text-right">
              <%= link_to "Edit", edit_admin_workout_exercise_path(workout_exercise), class: "text-xs font-bold text-primary hover:text-primary/80 transition-colors px-2 py-1 rounded border border-primary/20 hover:border-primary/50" %>
            </div>
         </div>
      </div>

      <div class="p-4">
         <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
            <div class="p-3 rounded-lg bg-background-light dark:bg-graphite/50 border border-transparent group-hover:bg-whiteish dark:group-hover:bg-graphite transition-colors">
               <span class="block text-xs uppercase text-muted mb-1 font-bold tracking-wider">Sets x Reps</span>
               <span class="font-bold text-blackish dark:text-whiteish text-lg">
                 <%= workout_exercise.sets %> x <%= workout_exercise.reps %>
               </span>
               <% if workout_exercise.warmup_sets.present? %>
                 <div class="text-xs text-muted mt-1">(+<%= workout_exercise.warmup_sets %> warmup)</div>
               <% end %>
            </div>
            <div class="p-3 rounded-lg bg-background-light dark:bg-graphite/50 border border-transparent group-hover:bg-whiteish dark:group-hover:bg-graphite transition-colors">
               <span class="block text-xs uppercase text-muted mb-1 font-bold tracking-wider">RPE Target</span>
               <span class="font-bold text-blackish dark:text-whiteish text-lg flex items-center gap-1">
                 <%= workout_exercise.early_rpe || "?" %> <span class="text-muted text-xs">to</span> <%= workout_exercise.last_rpe || "?" %>
               </span>
            </div>
            <div class="p-3 rounded-lg bg-background-light dark:bg-graphite/50 border border-transparent group-hover:bg-whiteish dark:group-hover:bg-graphite transition-colors">
               <span class="block text-xs uppercase text-muted mb-1 font-bold tracking-wider">Rest</span>
               <span class="font-bold text-blackish dark:text-whiteish text-lg">
                 <%= workout_exercise.rest_seconds %>s
               </span>
            </div>
             <div class="min-w-0 p-3 rounded-lg bg-background-light dark:bg-graphite/50 border border-transparent group-hover:bg-whiteish dark:group-hover:bg-graphite transition-colors">
               <span class="block text-xs uppercase text-muted mb-1 font-bold tracking-wider">Load</span>
               <span class="block font-bold text-blackish dark:text-whiteish text-lg truncate" title="<%= workout_exercise.load %>">
                 <%= workout_exercise.load.presence || "Bodyweight" %>
               </span>
            </div>
         </div>

         <% if workout_exercise.intensity_technique.present? || workout_exercise.sub_option_one.present? || workout_exercise.sub_option_two.present? %>
            <div class="mt-4 text-sm text-graphite dark:text-muted border-t border-shadow dark:border-graphite pt-3 flex flex-col gap-3">
               <% if workout_exercise.intensity_technique.present? %>
                 <div class="flex gap-2">
                   <span class="material-symbols-outlined text-primary text-base mt-0.5">bolt</span>
                   <div>
                     <strong class="block mb-1 text-xs uppercase tracking-wider text-primary">Intensity Technique</strong>
                     <%= workout_exercise.intensity_technique %>
                   </div>
                 </div>
               <% end %>

               <% if workout_exercise.sub_option_one.present? || workout_exercise.sub_option_two.present? %>
                 <div class="flex gap-4 <%= 'border-t border-shadow dark:border-graphite pt-3' if workout_exercise.intensity_technique.present? %>">
                   <% if workout_exercise.sub_option_one.present? %>
                   <div>
                     <strong class="block mb-1 text-xs uppercase tracking-wider text-graphite dark:text-muted">Sub Option 1</strong>
                     <%= workout_exercise.sub_option_one %>
                   </div>
                   <% end %>
                   <% if workout_exercise.sub_option_two.present? %>
                   <div>
                     <strong class="block mb-1 text-xs uppercase tracking-wider text-graphite dark:text-muted">Sub Option 2</strong>
                     <%= workout_exercise.sub_option_two %>
                   </div>
                   <% end %>
                 </div>
               <% end %>
            </div>
         <% end %>
      </div>
   </div>
<% end %>
