<%= form_with(model: [:admin, @workout], url: @workout.new_record? ? admin_routine_workouts_path(@routine || @workout.routine) : admin_workout_path(@workout), data: { turbo_frame: "_top" }, class: "space-y-6") do |f| %>
  <% if @workout.errors.any? %>
    <div class="p-4 bg-red-900/50 border border-red-500 rounded-lg">
      <h2 class="text-sm font-medium text-red-200"><%= pluralize(@workout.errors.count, "error") %> prohibited this workout from being saved:</h2>
      <ul class="mt-2 text-sm text-red-200 list-disc list-inside">
        <% @workout.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.hidden_field :routine_id, value: @routine&.id || @workout.routine_id %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= f.label :name, "Workout Name", class: "block text-sm font-medium text-whiteish mb-2" %>
      <%= f.text_field :name, class: "w-full bg-graphite border-shadow focus:border-saffron focus:ring focus:ring-opacity-50 text-whiteish rounded-lg rounded-tl-none shadow-sm transition-colors duration-200", placeholder: "e.g. Upper Body Push" %>
    </div>

    <div>
      <%= f.label :day_number, "Day Number (Optional)", class: "block text-sm font-medium text-whiteish mb-2" %>
      <%= f.number_field :day_number, class: "w-full bg-graphite border-shadow focus:border-saffron focus:ring focus:ring-opacity-50 text-whiteish rounded-lg rounded-tl-none shadow-sm transition-colors duration-200" %>
    </div>
  </div>

  <div>
    <%= f.label :description, "Description (Optional)", class: "block text-sm font-medium text-whiteish mb-2" %>
    <%= f.text_area :description, rows: 3, class: "w-full bg-graphite border-shadow focus:border-saffron focus:ring focus:ring-opacity-50 text-whiteish rounded-lg rounded-tl-none shadow-sm transition-colors duration-200", placeholder: "e.g. Focus on chest and shoulders" %>
  </div>

  <div class="flex items-center justify-end gap-4 pt-6 border-t border-shadow">
    <%= link_to "Cancel", admin_routine_path(@routine || @workout.routine), data: { turbo_frame: "_top" }, class: "px-4 py-2 text-sm font-medium text-muted hover:text-whiteish transition-colors duration-200" %>
    <%= f.submit class: "px-6 py-2 bg-saffron hover:bg-saffron-dark text-blackish font-bold rounded-lg rounded-tl-none shadow-sm transition-colors duration-200 cursor-pointer" %>
  </div>
<% end %>
