<div class="mb-6 flex justify-between items-center">
  <h1 class="text-3xl font-black text-whiteish uppercase tracking-tight font-display">
    <%= @workout.new_record? ? "New Workout Day" : "Edit Workout Day" %>
  </h1>
  <%= link_to "Back to Routine", admin_routine_path(@routine || @workout.routine), class: "px-4 py-2 bg-graphite hover:bg-shadow text-whiteish font-medium rounded-lg rounded-tl-none transition-colors duration-200" %>
</div>

<div class="bg-background-light dark:bg-blackish rounded-xl border border-shadow p-6">
  <%= render "form", workout: @workout, routine: @routine %>
</div>
