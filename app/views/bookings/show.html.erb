<% content_for :title, "Llamada confirmada — Rado Fitness" %>

<div class="min-h-screen bg-black text-white flex items-center justify-center p-6 pt-24">
  <div class="w-full max-w-lg border-2 border-saffron p-10 shadow-[8px_8px_0px_0px_#ffffff]">

    <div class="flex items-center gap-3 mb-8">
      <span class="material-symbols-outlined text-saffron text-3xl">check_circle</span>
      <p class="text-xs font-bold uppercase tracking-widest text-saffron">Llamada confirmada</p>
    </div>

    <h1 class="font-display font-black text-3xl uppercase tracking-tight text-white mb-2">
      ¡Todo listo!
    </h1>
    <p class="text-gray-400 text-sm mb-10">
      Tu llamada de inicio con Rado está agendada. Recibirás una invitación en tu email.
    </p>

    <div class="space-y-4 mb-10">
      <div class="flex items-start gap-4">
        <span class="material-symbols-outlined text-saffron mt-0.5">calendar_today</span>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-widest mb-0.5">Fecha y hora</p>
          <p class="font-bold text-white"><%= l @booking.scheduled_at, format: :long %></p>
        </div>
      </div>

      <div class="flex items-start gap-4">
        <span class="material-symbols-outlined text-saffron mt-0.5">schedule</span>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-widest mb-0.5">Duración</p>
          <p class="font-bold text-white">60 minutos</p>
        </div>
      </div>

      <% if @booking.meet_link.present? %>
        <div class="flex items-start gap-4">
          <span class="material-symbols-outlined text-saffron mt-0.5">videocam</span>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-widest mb-0.5">Enlace de videollamada</p>
            <%= link_to @booking.meet_link, @booking.meet_link,
                target: "_blank", rel: "noopener noreferrer",
                class: "font-bold text-saffron hover:underline break-all" %>
          </div>
        </div>
      <% end %>
    </div>

    <%= link_to "Ir al inicio →", root_path,
        class: "inline-block bg-saffron text-black font-display font-black text-sm uppercase tracking-widest px-8 py-4 border-2 border-saffron hover:-translate-y-px hover:-translate-x-px shadow-[6px_6px_0px_0px_#ffffff] hover:shadow-[8px_8px_0px_0px_#ffffff] transition-all duration-150" %>
  </div>
</div>
