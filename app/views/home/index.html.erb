<div class="min-h-screen flex items-center justify-center bg-gray-100 dark:bg-gray-900">
  <div class="max-w-md w-full p-8 bg-white dark:bg-gray-800 rounded-lg shadow-md text-center">
    <h1 class="text-3xl font-bold mb-4 text-gray-900 dark:text-white">Rado Fitness</h1>
    <p class="text-gray-600 dark:text-gray-300 mb-6">Welcome to the training platform.</p>

    <% if user_signed_in? %>
      <div class="space-y-4">
        <p class="text-sm text-gray-500">Signed in as <%= current_user.email %></p>
        <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "inline-block px-6 py-2 bg-red-600 text-white rounded hover:bg-red-700 transition" %>
      </div>
    <% else %>
      <div class="flex justify-center space-x-4">
        <%= link_to "Log In", new_user_session_path, class: "px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition" %>
        <%= link_to "Sign Up", new_user_registration_path, class: "px-6 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-100 dark:hover:bg-gray-700 transition" %>
      </div>
    <% end %>
  </div>
</div>
