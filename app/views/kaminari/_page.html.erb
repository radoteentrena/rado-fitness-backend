<%# Link of the "Page"
  - available local variables
    page:          a page object for "this" page
    url:           url to this page
    current_page:  a page object for the currently displayed page
    total_pages:   total number of pages
    per_page:      number of items to fetch per page
    remote:        data-remote
-%>
<li>
  <%= link_to page, url,
      class: "flex items-center justify-center px-3 h-8 leading-tight #{page.current? ? 'text-blackish border border-primary bg-primary/20 hover:bg-primary/30 hover:text-blackish dark:border-graphite dark:bg-graphite dark:text-whiteish' : 'text-graphite bg-whiteish border border-shadow hover:bg-background-light hover:text-blackish dark:bg-shadow dark:border-graphite dark:text-muted dark:hover:bg-shadow/50 dark:hover:text-whiteish'}",
      data: { turbo_frame: "admin_main_content", turbo_action: "advance" }
  %>
</li>
