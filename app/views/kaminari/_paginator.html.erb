<%# The container tag
  - available local variables
    current_page:  a page object for the currently displayed page
    total_pages:   total number of pages
    per_page:      number of items to fetch per page
    remote:        data-remote
    paginator:     the paginator that renders the pagination tags inside
-%>
<%= paginator.render do -%>
  <nav class="flex items-center justify-between pt-4" aria-label="Table navigation">
    <% total_count = local_assigns[:total_count] || (defined?(resources) && resources.respond_to?(:total_count) ? resources.total_count : 0) %>
    <span class="text-sm font-normal text-graphite dark:text-muted">
      <% start_index = (current_page.number - 1) * per_page + 1 %>
      <% end_index = [current_page.number * per_page, total_count].min %>
      Showing <span class="font-semibold text-blackish dark:text-whiteish"><%= start_index %>-<%= end_index %></span> of <span class="font-semibold text-blackish dark:text-whiteish"><%= total_count %></span>
    </span>
    <ul class="inline-flex -space-x-px text-sm h-8">
      <%= first_page_tag unless current_page.first? %>
      <%= prev_page_tag unless current_page.first? %>
      <% each_page do |page| -%>
        <% if page.display_tag? -%>
          <%= page_tag page %>
        <% elsif !page.was_truncated? -%>
          <%= gap_tag %>
        <% end -%>
      <% end -%>
      <%= next_page_tag unless current_page.last? %>
      <%= last_page_tag unless current_page.last? %>
    </ul>
  </nav>
<% end -%>
