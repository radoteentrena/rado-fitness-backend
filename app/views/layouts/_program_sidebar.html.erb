<div class="py-4 overflow-y-auto">
    <div class="mb-6 px-2">
      <%= link_to admin_program_path(program), class: "flex items-center text-graphite hover:text-primary mb-4 transition-colors" do %>
        <span class="material-symbols-outlined mr-2 text-sm">arrow_back</span>
        <span class="text-xs uppercase tracking-wider font-bold">Back to Program</span>
      <% end %>

      <h2 class="text-lg font-bold text-blackish dark:text-whiteish leading-tight">
        <%= program.name %>
      </h2>
      <p class="text-xs text-muted mt-1">
        <%= program.user&.email || "Template" %>
      </p>
    </div>

    <ul class="space-y-2 font-medium border-t border-shadow dark:border-graphite pt-4">
      <% program.routines.order(:id).each_with_index do |routine, index| %>
         <li>
            <%= link_to admin_routine_path(routine), class: "flex items-center p-2 text-blackish rounded-lg dark:text-whiteish hover:bg-background-light dark:hover:bg-shadow/50 group #{'bg-primary/10 text-primary dark:text-primary' if current_routine == routine}" do %>
               <span class="flex-shrink-0 w-6 h-6 flex items-center justify-center text-xs font-bold rounded-full border #{current_routine == routine ? 'border-primary text-primary' : 'border-muted text-muted'}">
                 <%= index + 1 %>
               </span>
               <span class="flex-1 ms-3 whitespace-nowrap">
                 <%= routine.name %>
               </span>
               <% if current_routine == routine %>
                  <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
               <% end %>
            <% end %>
         </li>
      <% end %>
    </ul>
</div>
