<div class="bg-black text-white min-h-screen py-16 px-4 font-switzer flex items-center justify-center">
  <div class="max-w-lg w-full text-center space-y-10">

    <div>
      <div class="inline-flex items-center justify-center w-16 h-16 border-2 border-saffron mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-saffron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </div>

      <h1 class="text-4xl font-bold uppercase tracking-tight text-white mb-4">
        Ya tenés una cuenta
      </h1>

      <p class="text-gray-400 text-lg mb-2">
        Encontramos tu correo
        <% if @email.present? %>
          <span class="text-saffron font-bold"><%= @email %></span>
        <% end %>
        en nuestro sistema.
      </p>
      <p class="text-gray-400 text-lg">
        Te enviamos un link de pago por correo. También podés activar tu acceso directo desde acá:
      </p>
    </div>

    <% if @payment_url.present? %>
      <%= link_to @payment_url, class: "block w-full border-2 border-saffron bg-saffron py-5 px-12 text-lg font-black uppercase tracking-widest text-black transition-all hover:bg-yellow-500 hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[8px_8px_0px_0px_#ffffff] active:translate-y-1 active:translate-x-1 active:shadow-none" do %>
        Activar mi acceso &#8594;
      <% end %>
    <% end %>

    <div class="border-t border-gray-800 pt-8">
      <p class="text-sm text-gray-600 mb-6">
        ¿No recibiste el correo? Revisá tu carpeta de spam.
      </p>
      <%= link_to "Volver al inicio", root_path, class: "inline-flex justify-center border-2 border-gray-700 bg-transparent py-3 px-8 text-sm font-bold uppercase tracking-widest text-gray-500 transition-all hover:border-gray-500 hover:text-gray-300 focus:outline-none" %>
    </div>

  </div>
</div>
