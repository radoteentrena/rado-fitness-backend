<div class="bg-black text-white min-h-screen py-16 px-4 sm:px-6 lg:px-8 font-switzer flex flex-col pt-24">
  <div class="max-w-2xl mx-auto w-full">

    <div data-controller="multi-step-form" class="w-full pb-32">
      <div class="mb-16">
        <div class="flex justify-center items-center mb-4">
          <span class="text-lg font-bold text-gray-400 tracking-widest uppercase" data-multi-step-form-target="progress">Paso 1 de 16</span>
        </div>
        <div class="w-full h-4 bg-black border-2 border-primary/50 relative overflow-hidden">
          <div class="absolute top-0 left-0 h-full bg-saffron transition-all duration-300 ease-out w-0" data-multi-step-form-target="progressBar"></div>
        </div>
      </div>

      <%= form_with(model: @user, url: onboarding_path, local: true, html: { novalidate: true }, class: "space-y-10", data: { action: "input->multi-step-form#updateButtons change->multi-step-form#updateButtons submit->multi-step-form#validateForm" }) do |f| %>
        <% if @user.errors.any? %>
          <div class="border-2 border-red-500 bg-black p-6 mb-10 shadow-[6px_6px_0px_0px_#ef4444]">
            <p class="text-xl font-bold text-red-500 uppercase tracking-widest mb-2">Hay campos sin completar</p>
            <p class="text-red-400 font-medium">Revisá el formulario desde el principio y completá todos los campos requeridos.</p>
            <% if @user.errors[:email].any? %>
              <p class="text-red-400 font-medium mt-3">→ Correo electrónico: <%= @user.errors[:email].first %></p>
            <% end %>
          </div>
        <% end %>

        <!-- Step 1: Correo electrónico (email check) -->
        <div data-multi-step-form-target="step" class="space-y-10">
          <div class="text-center mb-10">
            <h2 class="text-3xl font-bold text-saffron">Empecemos</h2>
          </div>
          <div>
            <%= f.label :email, "Correo electrónico", class: "block text-xl font-bold text-whiteish mb-3" %>
            <%= f.email_field :email, required: true, pattern: '[^@\s]+@[^@\s]+\.[^@\s]+', data: { "email-check": true }, class: "bg-graphite block w-full appearance-none rounded-none border-2 border-primary/50 bg-black px-6 py-5 text-xl text-white placeholder-white-600 focus:border-saffron focus:outline-none focus:ring-0 focus:shadow-[6px_6px_0px_0px_#F5C34A] focus:-translate-y-1 focus:-translate-x-1 transition-all" %>
            <p class="mt-3 text-sm text-gray-500">Si ya tenés cuenta, te enviamos el link de pago directo a tu correo.</p>
          </div>
        </div>

        <!-- Step 2: Datos Personales -->
        <div data-multi-step-form-target="step" class="hidden space-y-10">
          <div class="text-center mb-10">
             <h2 class="text-3xl font-bold text-saffron">Datos Personales</h2>
          </div>

          <div class="space-y-8">
            <div>
              <%= f.label :first_name, "Nombre", class: "block text-xl font-bold text-whiteish mb-3" %>
              <%= f.text_field :first_name, required: true, maxlength: 50, class: "bg-graphite block w-full appearance-none rounded-none border-2 border-primary/50 bg-black px-6 py-5 text-xl text-white placeholder-white-600 focus:border-saffron focus:outline-none focus:ring-0 focus:shadow-[6px_6px_0px_0px_#F5C34A] focus:-translate-y-1 focus:-translate-x-1 transition-all" %>
            </div>

            <div>
              <%= f.label :last_name, "Apellidos", class: "block text-xl font-bold text-whiteish mb-3" %>
              <%= f.text_field :last_name, required: true, maxlength: 50, class: "bg-graphite block w-full appearance-none rounded-none border-2 border-primary/50 bg-black px-6 py-5 text-xl text-white placeholder-white-600 focus:border-saffron focus:outline-none focus:ring-0 focus:shadow-[6px_6px_0px_0px_#F5C34A] focus:-translate-y-1 focus:-translate-x-1 transition-all" %>
            </div>
          </div>
        </div>

        <%= f.fields_for :onboarding_profile do |p| %>

        <!-- Step 2: Más Sobre Ti -->
        <div data-multi-step-form-target="step" class="hidden space-y-10">
          <div class="text-center mb-10">
             <h2 class="text-3xl font-bold text-saffron">Más Sobre Ti</h2>
          </div>

          <div class="space-y-8">
            <div>
              <label class="block text-xl font-bold text-whiteish mb-4">¿Con qué sexo te identificas?</label>
              <div class="space-y-4">
                <% ['Masculino', 'Femenino', 'Otro'].each do |option| %>
                  <label class="flex items-center gap-5 p-6 border-2 border-primary/50 bg-graphite cursor-pointer transition-all duration-200 [&:has(:checked)]:border-saffron [&:has(:checked)]:bg-graphite [&:has(:checked)]:shadow-[6px_6px_0px_0px_#F5C34A] [&:has(:checked)]:-translate-y-1 [&:has(:checked)]:-translate-x-1">
                    <%= p.radio_button :gender, option, required: true, class: "w-6 h-6 text-saffron bg-black border-2 border-gray-500 focus:ring-saffron focus:ring-offset-black" %>
                    <span class="text-xl font-medium text-white"><%= option %></span>
                  </label>
                <% end %>
              </div>
            </div>

            <div>
              <%= p.label :age, "Edad (solo número)", class: "block text-xl font-bold text-whiteish mb-3" %>
              <%= p.number_field :age, required: true, min: 14, max: 99, class: "bg-graphite block w-full appearance-none rounded-none border-2 border-primary/50 bg-black px-6 py-5 text-xl text-white placeholder-white-600 focus:border-saffron focus:outline-none focus:ring-0 focus:shadow-[6px_6px_0px_0px_#F5C34A] focus:-translate-y-1 focus:-translate-x-1 transition-all" %>
            </div>
          </div>
        </div>

        <!-- Step 3: Métricas Corporales -->
        <div data-multi-step-form-target="step" class="hidden space-y-10">
          <div class="text-center mb-10">
             <h2 class="text-3xl font-bold text-saffron">Métricas Corporales</h2>
          </div>

          <div class="space-y-8">
            <div>
              <%= p.label :weight, "Peso (indique preferiblemente en KG)", class: "block text-xl font-bold text-whiteish mb-3" %>
              <%= p.text_field :weight, placeholder: "Ej: 75 kg", required: true, maxlength: 20, class: "bg-graphite block w-full appearance-none rounded-none border-2 border-primary/50 bg-black px-6 py-5 text-xl text-white placeholder-white-600 focus:border-saffron focus:outline-none focus:ring-0 focus:shadow-[6px_6px_0px_0px_#F5C34A] focus:-translate-y-1 focus:-translate-x-1 transition-all" %>
            </div>

            <div>
              <%= p.label :height, "Estatura", class: "block text-xl font-bold text-whiteish mb-3" %>
              <%= p.text_field :height, placeholder: "Ej: 183cm", required: true, maxlength: 20, class: "bg-graphite block w-full appearance-none rounded-none border-2 border-primary/50 bg-black px-6 py-5 text-xl text-white placeholder-white-600 focus:border-saffron focus:outline-none focus:ring-0 focus:shadow-[6px_6px_0px_0px_#F5C34A] focus:-translate-y-1 focus:-translate-x-1 transition-all" %>
            </div>
          </div>
        </div>

        <!-- Step 4 onwards: uses second fields_for block for onboarding_profile -->
        <% end %>
        <%= f.fields_for :onboarding_profile do |p| %>

        <!-- Step 4: Contacto -->
        <div data-multi-step-form-target="step" class="hidden space-y-10">
          <div class="text-center mb-10">
             <h2 class="text-3xl font-bold text-saffron">Contacto</h2>
          </div>

          <div class="space-y-8">
            <div>
              <label class="block text-xl font-bold text-whiteish mb-3">Celular</label>
              <div class="flex gap-2">
                <select id="phone_prefix_select"
                        data-multi-step-form-target="phonePrefixSelect"
                        data-action="change->multi-step-form#syncPhone"
                        class="w-1/4 shrink-0 appearance-none rounded-none border-2 border-primary/50 bg-graphite px-3 py-5 text-xl text-white focus:border-saffron focus:outline-none focus:ring-0 transition-all">
                  <% CountriesHelper::PHONE_PREFIXES.each do |label, value| %>
                    <option value="<%= value %>"<% if value == "+54" %> selected<% end %>><%= label %></option>
                  <% end %>
                </select>
                <input type="tel"
                       id="phone_number_input"
                       autocomplete="tel"
                       data-multi-step-form-target="phoneNumberInput"
                       data-action="input->multi-step-form#syncPhone"
                       required
                       inputmode="numeric"
                       pattern="[0-9\s]{6,20}"
                       placeholder="412 123 4567"
                       maxlength="20"
                       class="w-3/4 min-w-0 appearance-none rounded-none border-2 border-primary/50 bg-graphite px-6 py-5 text-xl text-white placeholder-gray-600 focus:border-saffron focus:outline-none focus:ring-0 focus:shadow-[6px_6px_0px_0px_#F5C34A] focus:-translate-y-1 focus:-translate-x-1 transition-all">
              </div>
              <%= f.hidden_field :phone, data: { "multi-step-form-target": "phoneField" }, value: "" %>
            </div>
            <div>
              <%= p.label :instagram, "Cuenta de Instagram (Opcional)", class: "block text-xl font-bold text-whiteish mb-3" %>
              <div class="flex">
                <span class="inline-flex items-center border-2 border-primary/50 bg-graphite px-5 text-white-600 text-xl font-bold">@</span>
                <%= p.text_field :instagram, maxlength: 50, class: "bg-graphite block w-full min-w-0 flex-1 ml-[-2px] appearance-none rounded-none border-2 border-primary/50 bg-black px-6 py-5 text-xl text-white placeholder-white-600 focus:border-saffron focus:outline-none focus:ring-0 focus:shadow-[6px_6px_0px_0px_#F5C34A] focus:-translate-y-1 focus:-translate-x-1 relative z-10 transition-all", placeholder: "usuario" %>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 5: Tus Objetivos -->
        <div data-multi-step-form-target="step" class="hidden space-y-10">
          <div class="text-center mb-10">
             <h2 class="text-3xl font-bold text-saffron">Tus Objetivos</h2>
          </div>

          <div class="space-y-4">
             <label class="block text-xl font-bold text-whiteish mb-6">¿Cuáles <span class="text-saffron uppercase">SON</span> tus objetivos? (podés elegir varios)</label>
             <div class="checkbox-group space-y-4" data-required="true">
               <% ['Salud', 'Estética', 'Fuerza', 'Atletismo'].each do |goal| %>
                 <label class="flex items-center gap-5 p-6 border-2 border-primary/50 bg-graphite cursor-pointer transition-all duration-200 [&:has(:checked)]:border-saffron [&:has(:checked)]:bg-graphite [&:has(:checked)]:shadow-[6px_6px_0px_0px_#F5C34A] [&:has(:checked)]:-translate-y-1 [&:has(:checked)]:-translate-x-1">
                    <%= p.check_box :goals, { multiple: true, class: "bg-graphite w-6 h-6 rounded-none text-saffron border-2 border-gray-500 focus:ring-saffron focus:ring-offset-black" }, goal, nil %>
                    <span class="text-xl font-medium text-white"><%= goal %></span>
                 </label>
               <% end %>
               <label class="flex items-center gap-5 p-6 border-2 border-primary/50 bg-graphite cursor-pointer transition-all duration-200 [&:has(:checked)]:border-saffron [&:has(:checked)]:bg-graphite [&:has(:checked)]:shadow-[6px_6px_0px_0px_#F5C34A] [&:has(:checked)]:-translate-y-1 [&:has(:checked)]:-translate-x-1">
                  <%= p.check_box :goals, { multiple: true, class: "bg-graphite w-6 h-6 rounded-none text-saffron border-2 border-gray-500 focus:ring-saffron focus:ring-offset-black", id: "goals-otro-checkbox", data: { action: "change->multi-step-form#toggleGoalsOther" } }, "Otros", nil %>
                  <span class="text-xl font-medium text-white">Otros</span>
               </label>
             </div>

             <div id="goals-other-container" class="hidden conditional-field pt-2">
               <%= p.label :goals_other, "¿Cuáles son esos otros objetivos?", class: "block text-xl font-bold text-whiteish mb-3" %>
               <%= p.text_field :goals_other, maxlength: 100, placeholder: "Ej: Preparación para competencia", data: { conditional_required: true }, class: "bg-graphite block w-full appearance-none rounded-none border-2 border-primary/50 bg-black px-6 py-5 text-xl text-white placeholder-gray-600 focus:border-saffron focus:outline-none focus:ring-0 focus:shadow-[6px_6px_0px_0px_#F5C34A] focus:-translate-y-1 focus:-translate-x-1 transition-all" %>
             </div>
          </div>
        </div>

        <!-- Step 6: Experiencia -->
        <div data-multi-step-form-target="step" class="hidden space-y-10">
          <div class="text-center mb-10">
             <h2 class="text-3xl font-bold text-saffron">Experiencia</h2>
          </div>

          <div class="space-y-12">
            <div>
              <label class="block text-xl font-bold text-whiteish mb-4">¿Cuántos años llevas entrenando?</label>
              <div class="space-y-4">
                <% [["0-1", "Menos de 1 año"], ["1-2", "1 a 2 años"], ["2-5", "2 a 5 años"], ["5+", "Más de 5 años"]].each do |value, label| %>
                  <label class="flex items-center gap-5 p-6 border-2 border-primary/50 bg-graphite cursor-pointer transition-all duration-200 [&:has(:checked)]:border-saffron [&:has(:checked)]:bg-graphite [&:has(:checked)]:shadow-[6px_6px_0px_0px_#F5C34A] [&:has(:checked)]:-translate-y-1 [&:has(:checked)]:-translate-x-1">
                    <%= p.radio_button :training_years, value, required: true, data: { action: "change->multi-step-form#toggleBestLifts" }, class: "w-6 h-6 text-saffron bg-black border-2 border-gray-500 focus:ring-saffron focus:ring-offset-black" %>
                    <span class="text-xl font-medium text-white"><%= label %></span>
                  </label>
                <% end %>
              </div>
            </div>

            <div>
              <%= p.label :experience_level, "Nivel de experiencia (1 = Iniciante, 10 = Avanzado)", class: "block text-xl font-bold text-whiteish mb-4" %>

              <div class="flex items-center space-x-6">
                <span class="text-2xl font-black text-gray-500">1</span>
                <%= p.range_field :experience_level, in: 1..10, step: 1, value: 5, class: "w-full h-4 bg-graphite appearance-none cursor-pointer accent-saffron", oninput: "document.getElementById('experience-level-value').textContent = this.value" %>
                <span class="text-2xl font-black text-saffron">10</span>
              </div>
              <div class="text-center mb-4">
                <span id="experience-level-value" class="text-4xl font-black text-saffron">5</span>
              </div>
            </div>

            <div id="best-lifts-container" class="hidden conditional-field">
              <%= p.label :best_lifts, "Tus mejores marcas en básicos (Ej. Sentadilla 100kg)", class: "block text-xl font-bold text-whiteish mb-3" %>
              <%= p.text_area :best_lifts, rows: 4, class: "bg-graphite block w-full appearance-none rounded-none border-2 border-primary/50 bg-black px-6 py-5 text-xl text-white placeholder-white-600 focus:border-saffron focus:outline-none focus:ring-0 focus:shadow-[6px_6px_0px_0px_#F5C34A] focus:-translate-y-1 focus:-translate-x-1 transition-all" %>
            </div>
          </div>
        </div>

        <!-- Step 7: Exigencia -->
        <div data-multi-step-form-target="step" class="hidden space-y-10">
          <div class="text-center mb-10">
             <h2 class="text-3xl font-bold text-saffron">Exigencia</h2>
          </div>

          <div class="space-y-12">
            <div>
              <label class="block text-xl font-bold text-whiteish mb-4">¿Qué tanta prioridad ocupa el entrenamiento en tu vida?</label>
              <div class="space-y-4">
                <% ['Alto', 'Moderado', 'Bajo'].each do |option| %>
                  <label class="flex items-center gap-5 p-6 border-2 border-primary/50 bg-graphite cursor-pointer transition-all duration-200 [&:has(:checked)]:border-saffron [&:has(:checked)]:bg-graphite [&:has(:checked)]:shadow-[6px_6px_0px_0px_#F5C34A] [&:has(:checked)]:-translate-y-1 [&:has(:checked)]:-translate-x-1">
                    <%= p.radio_button :commitment_level, option, required: true, class: "w-6 h-6 text-saffron bg-black border-2 border-gray-500 focus:ring-saffron focus:ring-offset-black" %>
                    <span class="text-xl font-medium text-white"><%= option %></span>
                  </label>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 8: Frecuencia -->
        <div data-multi-step-form-target="step" class="hidden space-y-10">
          <div class="text-center mb-10">
             <h2 class="text-3xl font-bold text-saffron">Frecuencia</h2>
          </div>

          <div>
            <label class="block text-xl font-bold text-whiteish mb-4">¿Cuántos días a la semana puedes entrenar?</label>
            <div class="space-y-4">
              <% ['2', '3', '4', '+4 veces'].each do |option| %>
                <label class="flex items-center gap-5 p-6 border-2 border-primary/50 bg-graphite cursor-pointer transition-all duration-200 [&:has(:checked)]:border-saffron [&:has(:checked)]:bg-graphite [&:has(:checked)]:shadow-[6px_6px_0px_0px_#F5C34A] [&:has(:checked)]:-translate-y-1 [&:has(:checked)]:-translate-x-1">
                  <%= p.radio_button :training_frequency, option, required: true, class: "w-6 h-6 text-saffron bg-graphite border-2 border-gray-500 focus:ring-saffron focus:ring-offset-black" %>
                  <span class="text-xl font-medium text-white"><%= option %></span>
                </label>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Step 9: Tiempo por sesión -->
        <div data-multi-step-form-target="step" class="hidden space-y-10">
          <div class="text-center mb-10">
             <h2 class="text-3xl font-bold text-saffron">Duración</h2>
          </div>

          <div>
            <label class="block text-xl font-bold text-whiteish mb-4">¿Cuánto tiempo tenés disponible por sesión?</label>
            <div class="space-y-4">
              <% [['45 min', '45 minutos'], ['60 min', '60 minutos'], ['75 min', '75 minutos'], ['90 min', '90 minutos'], ['90+ min', 'Más de 90 minutos']].each do |value, label| %>
                <label class="flex items-center gap-5 p-6 border-2 border-primary/50 bg-graphite cursor-pointer transition-all duration-200 [&:has(:checked)]:border-saffron [&:has(:checked)]:bg-graphite [&:has(:checked)]:shadow-[6px_6px_0px_0px_#F5C34A] [&:has(:checked)]:-translate-y-1 [&:has(:checked)]:-translate-x-1">
                  <%= p.radio_button :time_per_session, value, required: true, class: "w-6 h-6 text-saffron bg-graphite border-2 border-gray-500 focus:ring-saffron focus:ring-offset-black" %>
                  <span class="text-xl font-medium text-white"><%= label %></span>
                </label>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Step 9: Salud Física -->
        <div data-multi-step-form-target="step" class="hidden space-y-10">
          <div class="text-center mb-10">
             <h2 class="text-3xl font-bold text-saffron">Salud Física</h2>
          </div>

          <div class="space-y-12">
            <div>
              <%= p.label :injuries, "¿Tienes alguna lesión o molestia?", class: "block text-xl font-bold text-whiteish mb-3" %>
              <%= p.text_area :injuries, rows: 3, placeholder: "Describe cualquier lesión o molestia actual", class: "bg-graphite block w-full appearance-none rounded-none border-2 border-primary/50 bg-graphite px-6 py-5 text-xl text-white placeholder-gray-600 focus:border-saffron focus:outline-none focus:ring-0 focus:shadow-[6px_6px_0px_0px_#F5C34A] focus:-translate-y-1 focus:-translate-x-1 transition-all" %>
            </div>

            <div>
              <label class="block text-xl font-bold text-whiteish mb-4">¿Practicas algún otro deporte actualmente?</label>
               <div class="space-y-4">
                <% ['Si', 'No'].each do |option| %>
                  <label class="flex items-center gap-5 p-6 border-2 border-primary/50 bg-graphite cursor-pointer transition-all duration-200 [&:has(:checked)]:border-saffron [&:has(:checked)]:bg-graphite [&:has(:checked)]:shadow-[6px_6px_0px_0px_#F5C34A] [&:has(:checked)]:-translate-y-1 [&:has(:checked)]:-translate-x-1">
                    <%= p.radio_button :plays_sports, option, required: true, data: { action: "change->multi-step-form#toggleSportDetails" }, class: "w-6 h-6 text-saffron bg-graphite border-2 border-gray-500 focus:ring-saffron focus:ring-offset-black" %>
                    <span class="text-xl font-medium text-white"><%= option %></span>
                  </label>
                <% end %>
              </div>
            </div>

            <div id="sport-details-container" class="hidden conditional-field">
              <%= p.label :sport_details, "¿Cuál deporte practicás?", class: "block text-xl font-bold text-whiteish mb-3" %>
              <%= p.text_field :sport_details, placeholder: "Ej: Fútbol, natación, ciclismo", class: "bg-graphite block w-full appearance-none rounded-none border-2 border-primary/50 bg-graphite px-6 py-5 text-xl text-white placeholder-white-600 focus:border-saffron focus:outline-none focus:ring-0 focus:shadow-[6px_6px_0px_0px_#F5C34A] focus:-translate-y-1 focus:-translate-x-1 transition-all" %>
            </div>
          </div>
        </div>

        <!-- Step 10: Hábitos alimenticios -->
        <div data-multi-step-form-target="step" class="hidden space-y-10">
          <div class="text-center mb-10">
             <h2 class="text-3xl font-bold text-saffron">Hábitos</h2>
          </div>

          <div class="space-y-12">
            <div>
              <label class="block text-xl font-bold text-whiteish mb-2">¿Cómo consideras tus hábitos alimenticios?</label>
              <p class="text-base text-gray-400 mb-6">Pensá en tu consistencia general: qué tan seguido comés bien, si planificás tus comidas, y si priorizás la proteína y la calidad de los alimentos.</p>
               <div class="space-y-4">
                <% [['Malos', 'Malos — como sin orden, muchos ultraprocesados'], ['Regular', 'Regular — intento comer bien pero fallo seguido'], ['Bueno', 'Bueno — como ordenado la mayoría de los días'], ['Pro', 'Pro — planeo mis comidas y priorizo la nutrición']].each do |value, label| %>
                  <label class="flex items-center gap-5 p-6 border-2 border-primary/50 bg-graphite cursor-pointer transition-all duration-200 [&:has(:checked)]:border-saffron [&:has(:checked)]:bg-graphite [&:has(:checked)]:shadow-[6px_6px_0px_0px_#F5C34A] [&:has(:checked)]:-translate-y-1 [&:has(:checked)]:-translate-x-1">
                    <%= p.radio_button :diet_quality, value, required: true, class: "w-6 h-6 text-saffron bg-graphite border-2 border-gray-500 focus:ring-saffron focus:ring-offset-black" %>
                    <span class="text-xl font-medium text-white"><%= label %></span>
                  </label>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 11: Tu Día a Día -->
        <div data-multi-step-form-target="step" class="hidden space-y-10">
          <div class="text-center mb-10">
             <h2 class="text-3xl font-bold text-saffron">Tu Día a Día</h2>
          </div>

          <div class="space-y-12">
            <div>
              <label class="block text-xl font-bold text-whiteish mb-4">Tipo de trabajo diario</label>
               <div class="space-y-4">
                <% ['Sentado', 'Levemente activo', 'Activo', 'Muy activo'].each do |option| %>
                  <label class="flex items-center gap-5 p-6 border-2 border-primary/50 bg-graphite cursor-pointer transition-all duration-200 [&:has(:checked)]:border-saffron [&:has(:checked)]:bg-graphite [&:has(:checked)]:shadow-[6px_6px_0px_0px_#F5C34A] [&:has(:checked)]:-translate-y-1 [&:has(:checked)]:-translate-x-1">
                    <%= p.radio_button :activity_level, option, required: true, class: "w-6 h-6 text-saffron bg-graphite border-2 border-gray-500 focus:ring-saffron focus:ring-offset-black" %>
                    <span class="text-xl font-medium text-white"><%= option %></span>
                  </label>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 12: Detalles Finales -->
        <div data-multi-step-form-target="step" class="hidden space-y-10">
          <div class="text-center mb-10">
             <h2 class="text-3xl font-bold text-saffron">Detalles Finales</h2>
          </div>

          <div class="space-y-12">
            <div>
              <label class="block text-xl font-bold text-whiteish mb-4">Horas de sueño</label>
              <div class="space-y-4">
                <% ['<4', '4-6', '6-8', '8-10', '+10'].each do |option| %>
                  <label class="flex items-center gap-5 p-6 border-2 border-primary/50 bg-graphite cursor-pointer transition-all duration-200 [&:has(:checked)]:border-saffron [&:has(:checked)]:bg-graphite [&:has(:checked)]:shadow-[6px_6px_0px_0px_#F5C34A] [&:has(:checked)]:-translate-y-1 [&:has(:checked)]:-translate-x-1">
                    <%= p.radio_button :sleep_hours, option, required: true, class: "w-6 h-6 text-saffron bg-graphite border-2 border-gray-500 focus:ring-saffron focus:ring-offset-black" %>
                    <span class="text-xl font-medium text-white"><%= option %></span>
                  </label>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 13: Redes Sociales -->
        <div data-multi-step-form-target="step" class="hidden space-y-10">
          <div class="text-center mb-10">
             <h2 class="text-3xl font-bold text-saffron">Redes Sociales</h2>
          </div>

          <div class="space-y-12">
            <div>
              <label class="block text-xl font-bold text-whiteish mb-4">¿Permites publicar videos entrenando en redes?</label>
              <div class="space-y-4">
                <% ['Si', 'No'].each do |option| %>
                  <label class="flex items-center gap-5 p-6 border-2 border-primary/50 bg-graphite cursor-pointer transition-all duration-200 [&:has(:checked)]:border-saffron [&:has(:checked)]:bg-graphite [&:has(:checked)]:shadow-[6px_6px_0px_0px_#F5C34A] [&:has(:checked)]:-translate-y-1 [&:has(:checked)]:-translate-x-1">
                    <%= p.radio_button :social_media_consent, option, required: true, class: "w-6 h-6 text-saffron bg-graphite border-2 border-gray-500 focus:ring-saffron focus:ring-offset-black" %>
                    <span class="text-xl font-medium text-white"><%= option %></span>
                  </label>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 14: ¡Casi listos! -->
        <div data-multi-step-form-target="step" class="hidden space-y-10">
          <div class="text-center mb-10">
             <h2 class="text-3xl font-bold text-saffron">¡Casi listos!</h2>
          </div>

          <div class="space-y-12">
            <div>
              <label class="block text-xl font-bold text-whiteish mb-4">¿Cómo nos conociste?</label>
               <div class="space-y-4">
                <% ['Redes sociales', 'Publicidad', 'Referencia', 'Cercanía'].each do |option| %>
                  <label class="flex items-center gap-5 p-6 border-2 border-primary/50 bg-graphite cursor-pointer transition-all duration-200 [&:has(:checked)]:border-saffron [&:has(:checked)]:bg-graphite [&:has(:checked)]:shadow-[6px_6px_0px_0px_#F5C34A] [&:has(:checked)]:-translate-y-1 [&:has(:checked)]:-translate-x-1">
                    <%= p.radio_button :referral_source, option, required: true, data: { action: "change->multi-step-form#toggleReferralOther" }, class: "w-6 h-6 text-saffron bg-graphite border-2 border-gray-500 focus:ring-saffron focus:ring-offset-black" %>
                    <span class="text-xl font-medium text-white"><%= option %></span>
                  </label>
                <% end %>
                <label class="flex items-center gap-5 p-6 border-2 border-primary/50 bg-graphite cursor-pointer transition-all duration-200 [&:has(:checked)]:border-saffron [&:has(:checked)]:bg-graphite [&:has(:checked)]:shadow-[6px_6px_0px_0px_#F5C34A] [&:has(:checked)]:-translate-y-1 [&:has(:checked)]:-translate-x-1">
                  <%= p.radio_button :referral_source, "Otro", required: true, data: { action: "change->multi-step-form#toggleReferralOther" }, class: "w-6 h-6 text-saffron bg-graphite border-2 border-gray-500 focus:ring-saffron focus:ring-offset-black" %>
                  <span class="text-xl font-medium text-white">Otro</span>
                </label>
              </div>

              <div id="referral-other-container" class="hidden conditional-field pt-4">
                <%= p.label :referral_source_other, "¿Cómo nos conociste?", class: "block text-xl font-bold text-whiteish mb-3" %>
                <%= p.text_field :referral_source_other, maxlength: 100, placeholder: "Contanos cómo llegaste a nosotros", data: { conditional_required: true }, class: "bg-graphite block w-full appearance-none rounded-none border-2 border-primary/50 bg-black px-6 py-5 text-xl text-white placeholder-gray-600 focus:border-saffron focus:outline-none focus:ring-0 focus:shadow-[6px_6px_0px_0px_#F5C34A] focus:-translate-y-1 focus:-translate-x-1 transition-all" %>
              </div>
            </div>
          </div>
        </div>

        <%# Country — last step, only Enviar button %>
        <div data-multi-step-form-target="step" class="hidden space-y-10">
          <div class="text-center mb-10">
            <h2 class="text-3xl font-bold text-saffron">¿Desde dónde nos escribís?</h2>
          </div>

          <div data-controller="searchable-select" class="relative">
            <input type="text"
                   autocomplete="off"
                   placeholder="Buscar país..."
                   data-searchable-select-target="input"
                   data-action="input->searchable-select#filter focus->searchable-select#open"
                   class="block w-full appearance-none rounded-none border-2 border-primary/50 bg-graphite px-6 py-5 text-xl text-white placeholder-gray-500 focus:border-saffron focus:outline-none focus:ring-0 focus:shadow-[6px_6px_0px_0px_#F5C34A] focus:-translate-y-1 focus:-translate-x-1 transition-all">

            <%= p.hidden_field :country, data: { "searchable-select-target": "hidden" } %>

            <div data-searchable-select-target="list"
                 class="hidden absolute z-20 w-full bg-graphite border-2 border-t-0 border-primary/50 max-h-64 overflow-y-auto">
              <% CountriesHelper::COUNTRIES.each do |name, code| %>
                <button type="button"
                        data-searchable-select-target="option"
                        data-action="click->searchable-select#select"
                        data-name="<%= name %>"
                        data-value="<%= code %>"
                        class="block w-full text-left px-6 py-4 text-lg text-white hover:bg-graphite hover:text-saffron transition-colors border-b border-gray-800 last:border-b-0">
                  <%= name %>
                </button>
              <% end %>
            </div>
          </div>
        </div>

        <% end %>

        <!-- Navigation Buttons -->
        <div class="pt-10 flex flex-col-reverse sm:flex-row gap-6 mt-12 justify-between items-center w-full">
          <button type="button" data-action="multi-step-form#previous" data-multi-step-form-target="previousButton" class="w-full sm:w-auto inline-flex justify-center border-2 border-gray-600 bg-transparent py-4 px-10 text-lg font-bold uppercase tracking-widest text-gray-300 transition-all hover:bg-gray-800 hover:text-white focus:outline-none focus:ring-0 active:translate-y-1 active:translate-x-1 active:shadow-none hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[6px_6px_0px_0px_#4b5563]">
            Atrás
          </button>

          <button type="button" data-action="multi-step-form#next" data-multi-step-form-target="nextButton" class="w-full sm:w-auto inline-flex justify-center border-2 border-saffron bg-saffron py-4 px-12 text-lg font-black uppercase tracking-widest text-black transition-all hover:bg-yellow-500 focus:outline-none focus:ring-0 hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[8px_8px_0px_0px_#ffffff] active:translate-y-1 active:translate-x-1 active:shadow-none">
            Continuar
          </button>

          <div data-multi-step-form-target="submitButton" class="hidden w-full sm:w-auto">
            <%= f.submit "Enviar", class: "w-full inline-flex justify-center border-2 border-saffron bg-saffron py-4 px-12 text-lg font-black uppercase tracking-widest text-black transition-all hover:bg-yellow-500 focus:outline-none cursor-pointer hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[8px_8px_0px_0px_#ffffff] active:translate-y-1 active:translate-x-1 active:shadow-none" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
