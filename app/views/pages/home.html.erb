<%# Hero Section %>
<section class="relative pt-32 pb-16 lg:pt-40 lg:pb-28 overflow-hidden bg-black">
  <div class="absolute inset-0 z-0">
    <%= image_tag "entrenando.jpg", alt: "Gritty gym background with weights", class: "w-full h-full object-cover opacity-20 filter grayscale contrast-125" %>

    <div class="absolute inset-0 bg-linear-to-b from-transparent via-black/80 to-black"></div>
  </div>

  <div
    class="
      relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col
      lg:flex-row gap-12 items-center
    "
  >
    <div class="flex-1 text-center lg:text-left">
      <h1
        class="
          text-5xl sm:text-7xl lg:text-[5rem] font-display font-bold
          uppercase leading-[1.1] tracking-tight mb-6 mt-4
        "
      >
        <span class="text-white block">
          TE ACOMPAÑO
          <br>
          AL FÍSICO
        </span>

        <span class="text-saffron block italic">QUE SIEMPRE QUISISTE</span>
      </h1>

      <p
        class="
          pl-3 text-xl sm:text-2xl text-gray-300 mb-8 max-w-2xl mx-auto
          lg:mx-0 font-light font-body
        "
      >
        Entrenamiento y nutrición adaptados a tu vida.
        <br>
        <span class="text-saffron italic">Sin fórmulas mágicas,</span>
        <br>
        solo resultados basados en datos.
      </p>
    </div>

    <%= image_tag("entrenando.jpg", alt: "Coach Rado", class: "relative z-10 w-[40%] shadow-2xl") %>
  </div>
</section>

