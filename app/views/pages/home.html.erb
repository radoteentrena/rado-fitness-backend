
<%# Header %>
<header class="fixed w-full top-0 z-50 bg-black/95 backdrop-blur-sm border-b border-shadow-grey">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <div class="flex-shrink-0 flex items-center">
        <%= link_to root_path, class: "flex items-center" do %>
          <span class="font-display font-bold text-2xl uppercase tracking-tighter text-white">RADO<span class="text-saffron">TE</span><span class="text-white">ENTRENA</span></span>
        <% end %>
      </div>
      <nav class="flex space-x-4 items-center">
        <% if user_signed_in? %>
          <%= link_to "Dashboard", admin_root_path, class: "text-white hover:text-saffron font-display font-medium uppercase text-sm transition-colors" %>
          <%= button_to "Cerrar sesión", destroy_user_session_path, method: :delete, class: "bg-saffron text-black font-display font-bold uppercase px-4 py-2 text-sm hover:bg-yellow-400 transition-colors" %>
        <% else %>
            <%= link_to "Log In", new_user_session_path, class: "text-white hover:text-saffron font-display font-medium uppercase text-sm transition-colors mr-4" %>
            <%= link_to "Empezar Ahora", new_user_registration_path, class: "bg-saffron text-black font-display font-bold uppercase px-4 py-2 text-sm hover:bg-yellow-400 transition-colors" %>
        <% end %>
      </nav>
    </div>
  </div>
</header>

<%# Hero Section %>
<section class="relative pt-24 pb-12 lg:pt-32 lg:pb-24 overflow-hidden bg-black">
  <div class="absolute inset-0 z-0">
    <img alt="Gritty gym background with weights" class="w-full h-full object-cover opacity-30 filter grayscale contrast-125" src="https://lh3.googleusercontent.com/aida-public/AB6AXuADwJ3e2ZHzhT3JWCtOd0xdapE7anbxN0iwOGoRpCVtNCkni8fz8BRBsnU-pXBSeoYx-HgJIQ__kTSMVSqMQdsb59GAUs53YFCyOdgfRVctppASbDSe9fvl7tAyzZSUabgMGegouKKnxkczovfxy8rVXLpg2EmdU5kSXuJMMNlYWFAjHHIZhLYAT02i2TqWJgczXKIl7RnB9v-aPC-0ARlK6Yc_BE8mVfI-XaCRCvNm9CxKcS8CZ18yUn1KxVrUb3OQodCt14vSVAly"/>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/80 to-black"></div>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col lg:flex-row gap-12 items-center">
    <div class="flex-1 text-center lg:text-left">
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-display font-bold uppercase leading-none tracking-tight mb-6 text-saffron">
        CONSTRUYE UN FÍSICO <br/><span class="text-white">ESTÉTICO Y DOMINANTE</span>
      </h1>
      <p class="text-xl sm:text-2xl text-gray-300 mb-8 max-w-2xl mx-auto lg:mx-0 font-light font-body">
        Entrenamiento de fuerza inteligente enfocado en hipertrofia y proporciones. <span class="font-bold text-saffron">Sin tonterías, solo resultados.</span>
      </p>
      <div class="lg:hidden">
        <%= link_to "EMPEZAR AHORA", new_user_registration_path, class: "inline-block w-full bg-saffron text-black font-display font-bold uppercase text-lg px-8 py-4 hover:bg-yellow-400 transition-colors text-center shadow-lg shadow-saffron/20" %>
      </div>
    </div>

    <%# Start Now Form / Call to Action Box %>
    <div class="w-full lg:w-96 flex-shrink-0 bg-graphite p-6 sm:p-8 shadow-2xl border border-shadow-grey relative" id="hero-form">
      <div class="absolute top-0 left-0 w-full h-1 bg-saffron"></div>
      <h3 class="text-2xl font-display font-bold uppercase text-center mb-2 text-white">Sé la mejor versión de vos mismo</h3>
      <p class="text-center text-sm text-gray-400 mb-6 font-body">Recibe tu plan de transformación hoy.</p>

      <%= form_with url: new_user_registration_path, method: :get, class: "space-y-4" do |f| %>
        <div>
          <label class="sr-only" for="name">Nombre</label>
          <%= f.text_field :name, placeholder: "Tu Nombre", class: "block w-full bg-shadow-grey border-gray-700 text-white placeholder-gray-500 focus:ring-saffron focus:border-saffron sm:text-sm px-4 py-3" %>
        </div>
        <div>
          <label class="sr-only" for="email">Email</label>
           <%= f.email_field :email, placeholder: "Tu Email", class: "block w-full bg-shadow-grey border-gray-700 text-white placeholder-gray-500 focus:ring-saffron focus:border-saffron sm:text-sm px-4 py-3" %>
        </div>
        <div>
          <label class="sr-only" for="goal">Objetivo Principal</label>
          <%= f.select :goal, options_for_select([["Tu Objetivo Principal", "", {disabled: true, selected: true}], ["Ganar Músculo (Hipertrofia)", "hypertrophy"], ["Perder Grasa / Definición", "cutting"], ["Recomposición Corporal", "recomp"]]), {}, class: "block w-full bg-shadow-grey border-gray-700 text-white placeholder-gray-500 focus:ring-saffron focus:border-saffron sm:text-sm px-4 py-3" %>
        </div>
        <%= f.submit "EMPEZAR AHORA", class: "w-full bg-saffron text-black font-display font-bold uppercase text-lg px-4 py-3 hover:bg-yellow-400 transition-colors shadow-md cursor-pointer" %>
        <p class="text-xs text-center text-gray-500 mt-4 font-body">Respetamos tu privacidad. Sin spam.</p>
      <% end %>
    </div>
  </div>
</section>

