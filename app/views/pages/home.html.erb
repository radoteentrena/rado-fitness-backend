<%# Header %>
<header class="fixed w-full top-0 z-50 bg-black/95 backdrop-blur-sm border-b border-shadow-grey">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <div class="flex-shrink-0 flex items-center">
        <%= link_to root_path, class: "flex items-center" do %>
          <span class="font-display font-bold text-2xl uppercase tracking-tighter text-white">RADO<span class="text-saffron">TE</span><span class="text-white">ENTRENA</span></span>
        <% end %>
      </div>
      <nav class="flex space-x-4 items-center">
        <% if user_signed_in? %>
          <%= link_to "Dashboard", admin_root_path, class: "text-white hover:text-saffron font-display font-medium uppercase text-sm transition-colors" %>
          <%= button_to "CERRAR SESIÓN", destroy_user_session_path, method: :delete, class: "bg-saffron text-black font-display font-bold uppercase px-4 py-2 text-sm hover:bg-yellow-400 transition-colors" %>
        <% else %>
            <%= link_to "LOG IN", new_user_session_path, class: "text-white hover:text-saffron font-display font-medium uppercase text-sm transition-colors mr-4" %>
            <%= link_to "COMIENZA", new_onboarding_path, class: "inline-flex justify-center border-2 border-saffron bg-saffron py-3 px-8 text-sm font-black uppercase tracking-widest text-black transition-all hover:bg-yellow-500 hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[6px_6px_0px_0px_#ffffff] active:translate-y-1 active:translate-x-1 active:shadow-none" %>
        <% end %>
      </nav>
    </div>
  </div>
</header>

<%# Hero Section %>
<section class="relative pt-32 pb-16 lg:pt-40 lg:pb-28 overflow-hidden bg-black">
  <div class="absolute inset-0 z-0">
    <img alt="Gritty gym background with weights" class="w-full h-full object-cover opacity-20 filter grayscale contrast-125" src="https://lh3.googleusercontent.com/aida-public/AB6AXuADwJ3e2ZHzhT3JWCtOd0xdapE7anbxN0iwOGoRpCVtNCkni8fz8BRBsnU-pXBSeoYx-HgJIQ__kTSMVSqMQdsb59GAUs53YFCyOdgfRVctppASbDSe9fvl7tAyzZSUabgMGegouKKnxkczovfxy8rVXLpg2EmdU5kSXuJMMNlYWFAjHHIZhLYAT02i2TqWJgczXKIl7RnB9v-aPC-0ARlK6Yc_BE8mVfI-XaCRCvNm9CxKcS8CZ18yUn1KxVrUb3OQodCt14vSVAly"/>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/80 to-black"></div>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col lg:flex-row gap-12 items-center">
    <div class="flex-1 text-center lg:text-left">
      <h1 class="text-5xl sm:text-7xl lg:text-[5rem] font-display font-bold uppercase leading-[1.1] tracking-tight mb-6 mt-4">
        <span class="text-white block">CONSTRUYE EL FÍSICO</span>
        <span class="text-saffron block italic">QUE SIEMPRE QUISISTE</span>
      </h1>
      <p class="text-xl sm:text-2xl text-gray-300 mb-8 max-w-2xl mx-auto lg:mx-0 font-light font-body">
        Entrenamiento profesional diseñado para maximizar tu fuerza<br/>
        y <span class="text-saffron">esculpir tu estética.</span>
      </p>
      <div class="lg:hidden text-center mt-8">
         <span class="text-gray-400 font-body text-sm">Empieza abajo 👇</span>
      </div>
    </div>

    <%# Start Now Form / Call to Action Box %>
    <%= image_tag("entrenando.jpg", alt: "Coach Rado", class: "relative z-10 w-[40%] shadow-2xl") do %>
      <%= link_to "COMIENZA", new_onboarding_path, class: "inline-flex justify-center border-2 border-saffron bg-saffron py-3 px-8 text-sm font-black uppercase tracking-widest text-black transition-all hover:bg-yellow-500 hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[6px_6px_0px_0px_#ffffff] active:translate-y-1 active:translate-x-1 active:shadow-none" %>
    <% end %>
  </div>
</section>

<%# Social Proof / Testimonials %>
<section class="pb-16 pt-8 border-b border-shadow-grey bg-black">
  <div class="w-full text-center">
    <div class="flex justify-center items-center space-x-1 mb-4">
      <% 5.times do %>
        <span class="material-symbols-outlined text-saffron fill-current text-xl">star</span>
      <% end %>
    </div>
    <p class="text-lg font-medium text-white mb-10 font-body">
      Más de <span class="text-saffron font-bold">1000 Alumnos</span> han construido su mejor versión.
    </p>

    <div class="w-full grid grid-cols-2 md:grid-cols-4 aspect-auto">
      <%= image_tag "testimonial_1.png", alt: "Testimonial 1", class: "w-full h-[400px] object-cover" %>
      <%= image_tag "testimonial_2.png", alt: "Testimonial 2", class: "w-full h-[400px] object-cover" %>
      <%= image_tag "testimonial_3.png", alt: "Testimonial 3", class: "w-full h-[400px] object-cover" %>
      <%= image_tag "testimonial_4.png", alt: "Testimonial 4", class: "w-full h-[400px] object-cover" %>
    </div>
  </div>
</section>

<%# Features Section %>
<section class="py-24 bg-black">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl sm:text-5xl font-display font-bold uppercase text-white mb-4">
        LOS PILARES DEL <span class="text-saffron">ÉXITO FÍSICO</span>
      </h2>
      <p class="max-w-2xl mx-auto text-gray-400 font-body text-sm sm:text-base">
        Dejá de entrenar sin rumbo. Aplico ciencia y esfuerzo para resultados visibles y duraderos.
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-shadow-grey p-10 border-t-4 border-saffron shadow-lg">
        <div class="w-12 h-12 bg-[#2d281a] rounded-full flex items-center justify-center mb-6">
          <span class="material-symbols-outlined text-saffron">fitness_center</span>
        </div>
        <h3 class="text-lg font-display font-bold uppercase mb-4 text-saffron">FUERZA REAL</h3>
        <p class="text-gray-300 text-sm leading-relaxed font-body">
          Incrementá tus cargas progresivamente y construí una base sólida de fuerza real.
        </p>
      </div>
      <div class="bg-shadow-grey p-10 border-t-4 border-saffron shadow-lg">
        <div class="w-12 h-12 bg-[#2d281a] rounded-full flex items-center justify-center mb-6">
          <span class="material-symbols-outlined text-saffron">accessibility_new</span>
        </div>
        <h3 class="text-lg font-display font-bold uppercase mb-4 text-saffron">ESTÉTICA DESEADA</h3>
        <p class="text-gray-300 text-sm leading-relaxed font-body">
          Vos me comunicás tu sentido de la estética y yo te armo el plan para lograrlo, priorizando un físico armonioso y atlético.
        </p>
      </div>
      <div class="bg-shadow-grey p-10 border-t-4 border-saffron shadow-lg">
        <div class="w-12 h-12 bg-[#2d281a] rounded-full flex items-center justify-center mb-6">
          <span class="material-symbols-outlined text-saffron">psychology</span>
        </div>
        <h3 class="text-lg font-display font-bold uppercase mb-4 text-saffron">TRANSFORMACIÓN TOTAL</h3>
        <p class="text-gray-300 text-sm leading-relaxed font-body">
          El mindset es clave para todo aspecto de tu vida, aquí no es diferente. Vamos a construir tu disciplina para que puedas ser fiel a tus objetivos.
        </p>
      </div>
    </div>
  </div>
</section>

<%# About/Evolution Section %>
<section class="py-0 relative overflow-hidden bg-black border-t border-shadow-grey">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="flex flex-col lg:flex-row gap-16 items-center">
      <div class="lg:w-1/2 relative">
        <div class="absolute -inset-10 bg-saffron/5 blur-3xl transform rotate-3"></div>
        <%= image_tag("rao.png", alt: "Coach Rado", class: "relative z-10 w-full shadow-2xl grayscale border-4 border-graphite")%>
      </div>
      <div class="lg:w-1/2">
        <h4 class="text-saffron font-bold uppercase tracking-widest text-xs mb-3 font-display">MI FILOSOFÍA</h4>
        <h2 class="text-4xl sm:text-5xl lg:text-5xl font-display font-bold uppercase text-white mb-8 border-b border-shadow-grey pb-8">
          FUERZA + ESTÉTICA
        </h2>
        <div class="prose prose-lg text-gray-300 font-body text-[15px] leading-relaxed">
          <p class="mb-5">
            Durante años, vi personas fuertes pero sin forma, o estéticas. Me negué a aceptar ese compromiso.
          </p>
          <p class="mb-5">
            Desarrollé un método que fusiona el powerlifting con el culturismo de alta frecuencia. El resultado es un físico que no solo impone presencia, sino que rinde al máximo nivel. No entrenamos para "participar", entrenamos para dominar.
          </p>
        </div>
        <button class="inline-flex justify-center border-2 border-white bg-transparent py-4 px-10 text-sm font-black uppercase tracking-widest text-white transition-all hover:bg-white hover:text-black focus:outline-none focus:ring-0 hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[6px_6px_0px_0px_#ffffff] active:translate-y-1 active:translate-x-1 active:shadow-none mt-6">
          CONOCE MI MÉTODO
        </button>
      </div>
    </div>
  </div>
</section>

<%# App/Coach Section %>
<section class="py-24 bg-shadow-grey">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col-reverse lg:flex-row justify-between items-center gap-16">
      <div class="lg:w-1/2 space-y-8">
        <div>
          <h2 class="text-4xl sm:text-5xl lg:text-[2.75rem] leading-tight font-display font-bold uppercase text-white mb-2">
            COMIENZA CON <br/><span class="text-saffron">MI APP DE<br/>ENTRENAMIENTO</span>
          </h2>
        </div>

        <div>
           <h4 class="text-sm font-display font-bold uppercase tracking-widest text-gray-300 mb-6 border-b border-gray-700 pb-2 inline-block">PROGRAMAS DE FUERZA Y ESTÉTICA</h4>
           <p class="text-gray-400 text-[15px] font-body leading-relaxed mb-8">
             He volcado toda mi experiencia en powerlifting y culturismo en esta aplicación. Accede a las rutinas exactas de hipertrofia y los ciclos de fuerza que utilizo para construir un físico de élite. Sin rellenos, solo entrenamiento efectivo.
           </p>

           <ul class="space-y-4 font-body text-[15px] text-gray-300 mb-10">
             <li class="flex items-center gap-3">
               <span class="material-symbols-outlined text-saffron text-[20px] fill-current">check_circle</span>
               Periodización para ganancias constantes
             </li>
             <li class="flex items-center gap-3">
               <span class="material-symbols-outlined text-saffron text-[20px] fill-current">check_circle</span>
               Técnica y ejecución detallada
             </li>
             <li class="flex items-center gap-3">
               <span class="material-symbols-outlined text-saffron text-[20px] fill-current">check_circle</span>
               Seguimiento de progreso real
             </li>
           </ul>
        </div>

            <%= link_to "COMIENZA", new_onboarding_path, class: "inline-flex justify-center border-2 border-saffron bg-saffron py-4 px-12 text-lg font-black uppercase tracking-widest text-black transition-all hover:bg-yellow-500 focus:outline-none focus:ring-0 hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[8px_8px_0px_0px_#ffffff] active:translate-y-1 active:translate-x-1 active:shadow-none" %>
      </div>
      <div class="lg:w-5/12 relative flex justify-center lg:justify-end">
        <%= image_tag("app.png", alt: "Fitness App Interface on Phone", class: "relative z-10 w-full max-w-[320px] mx-auto lg:mx-0 drop-shadow-2xl rounded-[2.5rem] shadow-saffron/10 shadow-3xl")%>
      </div>
    </div>
  </div>
</section>

<%# FAQ Section %>
<section class="py-24 bg-black">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-display font-bold uppercase text-center mb-12 text-white">
      PREGUNTAS <span class="text-saffron">FRECUENTES</span>
    </h2>
    <div class="space-y-4 font-body">
      <details class="group bg-shadow-grey px-6 py-5 rounded-md cursor-pointer marker:content-['']">
        <summary class="flex justify-between items-center font-bold text-gray-200">
          <span>¿Es este programa para principiantes?</span>
          <span class="transition group-open:rotate-180 text-saffron">
            <svg fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <p class="text-gray-400 mt-4 text-[15px] leading-relaxed group-open:animate-fadeIn">
          Sí. El programa adapta el volumen e intensidad a tu nivel actual. Sin embargo, requiere compromiso y constancia desde el primer día.
        </p>
      </details>

      <details class="group bg-shadow-grey px-6 py-5 rounded-md cursor-pointer marker:content-['']">
        <summary class="flex justify-between items-center font-bold text-gray-200">
          <span>¿Cuánto tiempo necesito entrenar al día?</span>
          <span class="transition group-open:rotate-180 text-saffron">
            <svg fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <p class="text-gray-400 mt-4 text-[15px] leading-relaxed group-open:animate-fadeIn">
          Entre 60 y 75 minutos. Nos centramos en calidad, no cantidad. Series efectivas, descansos adecuados y máxima intensidad en sesiones de 3 a 5 días por semana según el plan.
        </p>
      </details>

      <details class="group bg-shadow-grey px-6 py-5 rounded-md cursor-pointer marker:content-['']">
        <summary class="flex justify-between items-center font-bold text-gray-200">
          <span>¿Necesito suplementos obligatorios?</span>
          <span class="transition group-open:rotate-180 text-saffron">
            <svg fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <p class="text-gray-400 mt-4 text-[15px] leading-relaxed group-open:animate-fadeIn">
          No. Los suplementos son opcionales y solo para cubrir déficits. La base del éxito físico radica en un entrenamiento brutal, buena recuperación y nutrición adecuada basada en comida real.
        </p>
      </details>

      <details class="group bg-shadow-grey px-6 py-5 rounded-md cursor-pointer marker:content-['']">
        <summary class="flex justify-between items-center font-bold text-gray-200">
          <span>¿Cuántas supremas de pollo me como por semana?</span>
          <span class="transition group-open:rotate-180 text-saffron">
            <svg fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <p class="text-gray-400 mt-4 text-[15px] leading-relaxed group-open:animate-fadeIn">
          Entre 60 y 75.
        </p>
      </details>

      <details class="group bg-shadow-grey px-6 py-5 rounded-md cursor-pointer marker:content-['']">
        <summary class="flex justify-between items-center font-bold text-gray-200">
          <span>¿Qué rank soy en el lolcito?</span>
          <span class="transition group-open:rotate-180 text-saffron">
            <svg fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <p class="text-gray-400 mt-4 text-[15px] leading-relaxed group-open:animate-fadeIn">
          Bronze 3
        </p>
      </details>
    </div>
  </div>
</section>

<%# Footer CTA %>
<section class="py-24 bg-saffron text-center">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-4xl sm:text-6xl lg:text-[4rem] font-display font-bold uppercase mb-6 text-black tracking-tight">
      NO ESPERES AL LUNES
    </h2>
    <p class="text-lg sm:text-xl text-black font-medium mb-10 max-w-xl mx-auto font-body">
      El físico que deseas está al otro lado del dolor y la disciplina. Empieza hoy.
    </p>
      <%= link_to "COMIENZA", new_onboarding_path, class: "inline-flex justify-center border-2 border-black bg-black py-4 px-12 text-lg font-black uppercase tracking-widest text-white transition-all hover:bg-gray-900 focus:outline-none focus:ring-0 hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[8px_8px_0px_0px_#000000] active:translate-y-1 active:translate-x-1 active:shadow-none" %>
  </div>
</section>

