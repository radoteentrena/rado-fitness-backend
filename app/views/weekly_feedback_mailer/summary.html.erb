<!DOCTYPE html>
<html>
<head>
  <meta content="text/html; charset=UTF-8" http-equiv="Content-Type">
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background-color: #1a1a1a; color: #e5e5e5; padding: 40px 20px;">
  <div style="max-width: 560px; margin: 0 auto; background-color: #1a1a1a; border: 2px solid #333; padding: 40px;">

    <div style="font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.12em; color: #F5C228; margin-bottom: 18px;">
      Rado Te Entrena
    </div>

    <h1 style="font-size: 17px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 14px; color: #fff;">
      Resumen semanal
    </h1>

    <p style="font-size: 13px; line-height: 1.6; color: #999; margin: 0 0 8px;">
      Hola <strong style="color: #fff;"><%= @user.first_name %></strong>,
    </p>

    <p style="font-size: 13px; line-height: 1.6; color: #999; margin: 0 0 20px;">
      <%= @feedback_text %>
    </p>

    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 20px;">
      <tr>
        <td width="33%" style="padding-right: 8px;">
          <div style="background-color: #111; border: 1px solid #2f2f2f; padding: 16px; text-align: center;">
            <div style="font-size: 10px; color: #555; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px;">Entrenamientos</div>
            <div style="font-size: 22px; font-weight: 900; color: #F5C228;"><%= @workouts_this_week %><span style="font-size: 12px; color: #555;">/sem</span></div>
          </div>
        </td>
        <td width="33%" style="padding-right: 8px; padding-left: 8px;">
          <div style="background-color: #111; border: 1px solid #2f2f2f; padding: 16px; text-align: center;">
            <div style="font-size: 10px; color: #555; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px;">Adherencia</div>
            <div style="font-size: 22px; font-weight: 900; color: #F5C228;"><%= @diet_adherence %><span style="font-size: 12px; color: #555;">%</span></div>
          </div>
        </td>
        <td width="33%" style="padding-left: 8px;">
          <div style="background-color: #111; border: 1px solid #2f2f2f; padding: 16px; text-align: center;">
            <div style="font-size: 10px; color: #555; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px;">Peso</div>
            <div style="font-size: 22px; font-weight: 900; color: #fff;"><%= @current_weight %><span style="font-size: 12px; color: #555;">kg</span></div>
          </div>
        </td>
      </tr>
    </table>

    <a href="<%= @dashboard_url %>"
       style="display: block; text-align: center; background-color: #F5C228; color: #111; border: 2px solid #F5C228; font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.12em; padding: 14px 24px; text-decoration: none; margin: 0 0 20px;">
      Ver detalle completo &#8594;
    </a>

    <p style="font-size: 11px; color: #444; line-height: 1.5; margin: 0;">
      ¿Preguntas sobre tu semana? Respondé este mail.
    </p>

  </div>
</body>
</html>
